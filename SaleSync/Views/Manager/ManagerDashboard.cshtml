@model SaleSync.Models.CashierDashboardViewModel
@{
    Layout = null;
}<!DOCTYPE html><html lang="en"><head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Manager Dashboard - SyncScale</title>
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <style>
        /* Logic-specific styles only, no UI changes */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center; }
        .auth-modal { background: white; padding: 25px; border-radius: 15px; width: 320px; text-align: center; box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
        .auth-modal input { width: 100%; padding: 10px; margin: 15px 0; border: 1px solid #ddd; border-radius: 8px; }
        .auth-btn { background: #f46a05; color: white; border: none; padding: 10px; width: 100%; border-radius: 8px; cursor: pointer; font-weight: bold; }
        .action-btn-group { display: flex; gap: 8px; justify-content: center; }
        .btn-mini { width: 28px; height: 28px; border-radius: 50%; border: none; cursor: pointer; font-weight: bold; display: flex; align-items: center; justify-content: center; }
        .btn-confirm-mini { background: #d1fae5; color: #065f46; }
        .btn-confirm-mini:hover { background: #065f46; color: white; }
        .btn-void-mini { background: #fee2e2; color: #b91c1c; }
        .btn-void-mini:hover { background: #b91c1c; color: white; }
        .status-voided { background: #fee2e2; color: #b91c1c; padding: 4px 12px; border-radius: 15px; font-size: 11px; font-weight: 700; }
    </style>
</head><body>

    <div id="voidModal" class="modal-overlay">
        <div class="auth-modal">
            <h3 style="color: #4a2511;">Authorize Void</h3>
            <p style="font-size: 12px; color: #8c5b3e; margin-top: 5px;">Enter your Manager password to void <br><strong>Order #ORD-<span id="displayId"></span></strong></p>
            <input type="password" id="mgrPass" placeholder="Password" />
            <button class="auth-btn" onclick="confirmManagerVoid()">Verify & Void</button>
            <p onclick="closeModal()" style="margin-top:15px; cursor:pointer; font-size:12px; color:#999;">Cancel</p>
        </div>
    </div>

    <div class="dashboard-container">

        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title" style="font-size: 24px; font-weight: 800; color: #ffffff;">SyncScale</div>
                    <div class="logo-subtitle" style="font-size: 13px; color: #dcbca5;">Coffee & Pastries</div>
                </div>

                <div class="profile-section" style="display: flex; align-items: center; gap: 15px; margin-bottom: 40px;">
                    <div class="profile-circle" style="width: 45px; height: 45px; background: #f46a05; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #fff;">👤</div>
                    <div>
                        <h2 class="admin-name" style="font-size: 16px; font-weight: 700; color: #ffffff; margin: 0;">Manager</h2>
                        <div style="font-size: 12px; color: #dcbca5;">System Access</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a asp-controller="Manager" asp-action="Dashboard" class="menu-btn active">❖ Dashboard</a>
                    <a asp-controller="Manager" asp-action="Analytics" class="menu-btn">📊 Analytics</a>
                    <a asp-controller="Manager" asp-action="Products" class="menu-btn">🏷️ Products</a>
                    <a asp-controller="Manager" asp-action="Inventory" class="menu-btn">📦 Inventory</a>
                </nav>
            </div>

            <div class="logout-section" style="margin-top: auto;">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn" style="background: transparent; border: none; width: 100%; text-align: left; cursor: pointer; color: #dcbca5; padding: 14px 20px;">
                        ⎋ Log Out
                    </button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-header" style="margin-bottom: 30px;">
                <h1 class="greeting-title" style="font-size: 32px; font-weight: 800; color: #4a2511;">Good Morning! ☕</h1>
                <p style="color: #b58361;">Welcome back! Here's what's brewing today.</p>
            </div>

            <div class="summary-dashboard" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px;">
                <div class="summary-card" style="background: #ffffff; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(74, 37, 17, 0.04);">
                    <div class="card-icon-box" style="width: 40px; height: 40px; background: #ab4a03; color: white; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 15px;">📦</div>
                    <div class="card-label" style="font-size: 13px; font-weight: 600; color: #8c5b3e; margin-bottom: 5px;">Total Items</div>
                    <div class="card-value" style="font-size: 24px; font-weight: 800; color: #4a2511;">1,247</div>
                </div>

                <div class="summary-card" style="background: #ffffff; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(74, 37, 17, 0.04);">
                    <div class="card-icon-box" style="width: 40px; height: 40px; background: #0b8a53; color: white; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 15px;">📈</div>
                    <div class="card-label" style="font-size: 13px; font-weight: 600; color: #8c5b3e; margin-bottom: 5px;">Today's Sales</div>
                    <div class="card-value" style="font-size: 24px; font-weight: 800; color: #4a2511;">₱@Model.TodayTotalSales.ToString("N2")</div>
                </div>

                <div class="summary-card" style="background: #ffffff; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(74, 37, 17, 0.04);">
                    <div class="card-icon-box" style="width: 40px; height: 40px; background: #f46a05; color: white; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 15px;">📁</div>
                    <div class="card-label" style="font-size: 13px; font-weight: 600; color: #8c5b3e; margin-bottom: 5px;">Transactions</div>
                    <div class="card-value" style="font-size: 24px; font-weight: 800; color: #4a2511;">@Model.TodayTransactionCount</div>
                </div>

                <div class="summary-card" style="background: #ffffff; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(74, 37, 17, 0.04);">
                    <div class="card-icon-box" style="width: 40px; height: 40px; background: #e02424; color: white; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 15px;">⚠️</div>
                    <div class="card-label" style="font-size: 13px; font-weight: 600; color: #8c5b3e; margin-bottom: 5px;">Low Stock</div>
                    <div class="card-value" style="font-size: 24px; font-weight: 800; color: #4a2511;">7</div>
                </div>
            </div>

            <div class="recent-sales-card" style="margin-bottom: 30px;">
                <div class="card-header-flex">
                    <div>
                        <h2 class="widget-title">Recent Sales</h2>
                        <div class="widget-subtitle">Latest transactions from today</div>
                    </div>
                    <a asp-controller="Manager" asp-action="Analytics" class="view-all-link">View Full Report &rarr;</a>
                </div>

                <div class="table-responsive">
                    <table class="recent-sales-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Time</th>
                                <th>Cashier</th>
                                <th>Items</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                                <th style="text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentSales != null && Model.RecentSales.Any())
                            {
                                foreach (var sale in Model.RecentSales)
                                {
                                    <tr>
                                        <td class="order-id">#ORD-@sale.SaleId</td>
                                        <td>@sale.SaleDate.ToString("hh:mm tt")</td>
                                        <td><span class="cashier-badge">@sale.CashierName</span></td>
                                        <td>@sale.ItemsSummary</td>
                                        <td style="font-weight: 800; color: #4a2511;">₱@sale.TotalAmount.ToString("N2")</td>
                                        <td>
                                            @if (string.Equals(sale.Status, "Completed", StringComparison.OrdinalIgnoreCase)) { <span class="status-badge status-completed">Completed</span> }
                                            else if (string.Equals(sale.Status, "Voided", StringComparison.OrdinalIgnoreCase)) { <span class="status-voided">Voided</span> }
                                            else { <span class="status-badge status-pending">Pending</span> }
                                        </td>
                                        <td style="text-align: center;">
                                            <div class="action-btn-group">
                                                @if (string.IsNullOrEmpty(sale.Status) || string.Equals(sale.Status, "Pending", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <button class="btn-mini btn-confirm-mini" onclick="updateStatus(@sale.SaleId, 'Completed')" title="Complete Order">✓</button>
                                                    <button class="btn-mini btn-void-mini" onclick="openVoidModal(@sale.SaleId)" title="Void Order">✕</button>
                                                }
                                                else
                                                {
                                                    <span style="color: #ccc; font-size: 10px; font-weight: 800;">LOCKED</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" style="text-align: center; padding: 30px; color: #8c5b3e;">No sales records found for today.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <script>
        let selectedSaleId = null;

        function updateStatus(saleId, status) {
            if(!confirm(`Confirm Order #ORD-${saleId} as ${status}?`)) return;
            
            // 1. FIX: Format data as URLSearchParams so ASP.NET can bind the parameters correctly
            const formData = new URLSearchParams();
            formData.append('saleId', saleId);
            formData.append('status', status);

            // 2. FIX: Target the correct method name (UpdateOrderStatus)
            fetch('/Manager/UpdateOrderStatus', {
                method: 'POST',
                body: formData // No headers needed for URLSearchParams, browser handles it!
            }).then(res => res.ok ? location.reload() : alert("Update failed. Check server console."));
        }

        function openVoidModal(saleId) {
            selectedSaleId = saleId;
            document.getElementById('displayId').innerText = saleId;
            document.getElementById('voidModal').style.display = 'flex';
        }

        function closeModal() { document.getElementById('voidModal').style.display = 'none'; }

        function confirmManagerVoid() {
            const passValue = document.getElementById('mgrPass').value;
            if(!passValue) return alert("Please enter your password");

            // 1. FIX: Format data for C# binding
            const formData = new URLSearchParams();
            formData.append('saleId', selectedSaleId);
            formData.append('status', 'Voided');

            // 2. FIX: Point to UpdateOrderStatus so it successfully updates the database
            fetch('/Manager/UpdateOrderStatus', { 
                method: 'POST',
                body: formData
            }).then(async res => {
                if(res.ok) {
                    location.reload();
                } else {
                    alert("Unauthorized: Void failed");
                }
            }).catch(err => {
                console.error("Error:", err);
                alert("Server error. Check if the controller method exists.");
            });
        }
    </script>
</body></html>