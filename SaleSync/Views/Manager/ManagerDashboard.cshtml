@model List<SaleSync.Models.InventoryItems>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Manager Dashboard - SyncScale</title>
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-container">

        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title" style="font-size: 24px; font-weight: 800; color: #ffffff;">SyncScale</div>
                    <div class="logo-subtitle" style="font-size: 13px; color: #dcbca5;">Coffee & Pastries</div>
                </div>

                <div class="profile-section" style="display: flex; align-items: center; gap: 15px; margin-bottom: 40px;">
                    <div class="profile-circle" style="width: 45px; height: 45px; background: #f46a05; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #fff;">👤</div>
                    <div>
                        <h2 class="admin-name" style="font-size: 16px; font-weight: 700; color: #ffffff; margin: 0;">Manager</h2>
                        <div style="font-size: 12px; color: #dcbca5;">System Access</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a asp-controller="Manager" asp-action="Dashboard"
                           class="menu-btn active">
                        ❖ Dashboard
                    </a>

                    <a asp-controller="Manager" asp-action="Analytics"
                           class="menu-btn">
                        📊 Analytics
                    </a>

                    <a asp-controller="Manager" asp-action="Inventory"
                           class="menu-btn">
                        📦 Inventory
                    </a>
                </nav>
            </div>

            <div class="logout-section" style="margin-top: auto;">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn" style="background: transparent; border: none; width: 100%; text-align: left; cursor: pointer; color: #dcbca5; padding: 14px 20px;">
                        ⎋ Log Out
                    </button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-header" style="margin-bottom: 30px;">
                <h1 class="greeting-title" style="font-size: 32px; font-weight: 800; color: #4a2511;">Good Morning! ☕</h1>
                <p style="color: #b58361;">Welcome back! Here's what's brewing today.</p>
            </div>

            <div class="summary-dashboard" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px;">
                <div class="summary-card" style="background: #ffffff; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(74, 37, 17, 0.04);">
                    <div class="card-icon-box" style="width: 40px; height: 40px; background: #ab4a03; color: white; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 15px;">📦</div>
                    <div class="card-label" style="font-size: 13px; font-weight: 600; color: #8c5b3e; margin-bottom: 5px;">Total Items</div>
                    <div class="card-value" style="font-size: 24px; font-weight: 800; color: #4a2511;">1,247</div>
                </div>

                <div class="summary-card" style="background: #ffffff; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(74, 37, 17, 0.04);">
                    <div class="card-icon-box" style="width: 40px; height: 40px; background: #0b8a53; color: white; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 15px;">📈</div>
                    <div class="card-label" style="font-size: 13px; font-weight: 600; color: #8c5b3e; margin-bottom: 5px;">Today's Sales</div>
                    <div class="card-value" style="font-size: 24px; font-weight: 800; color: #4a2511;">₱650.00</div>
                </div>

                <div class="summary-card" style="background: #ffffff; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(74, 37, 17, 0.04);">
                    <div class="card-icon-box" style="width: 40px; height: 40px; background: #f46a05; color: white; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 15px;">📁</div>
                    <div class="card-label" style="font-size: 13px; font-weight: 600; color: #8c5b3e; margin-bottom: 5px;">Categories</div>
                    <div class="card-value" style="font-size: 24px; font-weight: 800; color: #4a2511;">24</div>
                </div>

                <div class="summary-card" style="background: #ffffff; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(74, 37, 17, 0.04);">
                    <div class="card-icon-box" style="width: 40px; height: 40px; background: #e02424; color: white; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 15px;">⚠️</div>
                    <div class="card-label" style="font-size: 13px; font-weight: 600; color: #8c5b3e; margin-bottom: 5px;">Low Stock</div>
                    <div class="card-value" style="font-size: 24px; font-weight: 800; color: #4a2511;">7</div>
                </div>
            </div>

            <div class="recent-sales-card" style="margin-bottom: 30px;">
                <div class="card-header-flex">
                    <div>
                        <h2 class="widget-title">Recent Sales</h2>
                        <div class="widget-subtitle">Latest transactions from today</div>
                    </div>
                    <a asp-controller="Manager" asp-action="Analytics" class="view-all-link">View Full Report &rarr;</a>
                </div>

                <div class="table-responsive">
                    <table class="recent-sales-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Time</th>
                                <th>Cashier</th>
                                <th>Items</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="order-id">#ORD-1025</td>
                                <td>10:45 AM</td>
                                <td><span class="cashier-badge">Cashier_01</span></td>
                                <td>2x Spanish Latte, 1x Croissant</td>
                                <td>₱265.00</td>
                                <td><span class="status-badge status-completed">Completed</span></td>
                            </tr>
                            <tr>
                                <td class="order-id">#ORD-1024</td>
                                <td>10:32 AM</td>
                                <td><span class="cashier-badge">Cashier_02</span></td>
                                <td>1x Matcha Milk Tea</td>
                                <td>₱95.00</td>
                                <td><span class="status-badge status-completed">Completed</span></td>
                            </tr>
                            <tr>
                                <td class="order-id">#ORD-1023</td>
                                <td>10:15 AM</td>
                                <td><span class="cashier-badge">Cashier_01</span></td>
                                <td>1x Silog Meal, 1x Americano</td>
                                <td>₱150.00</td>
                                <td><span class="status-badge status-completed">Completed</span></td>
                            </tr>
                            <tr>
                                <td class="order-id">#ORD-1022</td>
                                <td>09:50 AM</td>
                                <td><span class="cashier-badge">Cashier_01</span></td>
                                <td>3x Cheese Ensaymada</td>
                                <td>₱135.00</td>
                                <td><span class="status-badge status-pending">Pending</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </main>
    </div>
</body>
</html>