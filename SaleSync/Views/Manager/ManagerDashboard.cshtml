@model SaleSync.Models.CashierDashboardViewModel
@{
    Layout = null;
    string homeController = "Manager";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Manager Dashboard - Cafero</title>
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

    <div id="voidModal" class="modal-overlay">
        <div class="auth-modal">
            <h3>Authorize Void</h3>
            <p>Enter your Manager password to void <br><strong>Order #ORD-<span id="displayId"></span></strong></p>
            <input type="password" id="mgrPass" placeholder="Password" />
            <button class="auth-btn" onclick="confirmManagerVoid()">Verify & Void</button>
            <p onclick="closeModal()">Cancel</p>
        </div>
    </div>

    <div class="dashboard-container">
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">Cafero</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <h2 class="admin-name">Manager</h2>
                        <div class="admin-role">Manager</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="/@homeController/Dashboard" class="menu-btn active"> Dashboard</a>
                    <a href="/@homeController/PointOfSale" class="menu-btn"> POS</a>
                    <a href="/Admin/Analytics" class="menu-btn"> Analytics</a>
                    <a href="/Admin/Products" class="menu-btn"> Products</a>
                    <a href="/Admin/Inventory" class="menu-btn"> Inventory</a>
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="btn-logout">
                        ⎋ Log Out
                    </button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-header">
                <h1 class="greeting-title">Good Morning! ☕</h1>
                <p class="greeting-subtitle">Welcome back! Here's what's brewing today.</p>
            </div>

            <div class="summary-dashboard">
                <div class="summary-card">
                    <div class="card-icon-box">📦</div>
                    <div class="card-label">Total Items</div>
                    <div class="card-value">1,247</div>
                </div>

                <div class="summary-card">
                    <div class="card-icon-box">📈</div>
                    <div class="card-label">Today's Sales</div>
                    <div class="card-value">₱@Model.TodayTotalSales.ToString("N2")</div>
                </div>

                <div class="summary-card">
                    <div class="card-icon-box">📁</div>
                    <div class="card-label">Transactions</div>
                    <div class="card-value">@Model.TodayTransactionCount</div>
                </div>

                <div class="summary-card">
                    <div class="card-icon-box">⚠️</div>
                    <div class="card-label">Low Stock</div>
                    <div class="card-value">7</div>
                </div>
            </div>

            <div class="recent-sales-card">
                <div class="card-header-flex">
                    <div>
                        <h2 class="widget-title">Recent Sales</h2>
                        <div class="widget-subtitle">Latest transactions from today</div>
                    </div>
                    <a href="/Admin/Analytics" class="view-all-link">View Full Report &rarr;</a>
                </div>

                <div class="table-responsive">
                    <table class="recent-sales-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Time</th>
                                <th>Cashier</th>
                                <th>Items</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentSales != null && Model.RecentSales.Any())
                            {
                                @foreach (var sale in Model.RecentSales)
                                {
                                    <tr class="table-row-hover" onclick="toggleDetails(@sale.SaleId)">
                                        <td class="td-bold">#ORD-@sale.SaleId</td>
                                        <td>@sale.SaleDate.ToString("hh:mm tt")</td>
                                        <td><span class="badge-cashier">@sale.CashierName</span></td>
                                        <td>@sale.ItemsSummary</td>
                                        <td class="td-price">₱@sale.TotalAmount.ToString("N2")</td>
                                        <td>
                                            @if (sale.Status == "Completed")
                                            {
                                                <span class="badge-completed">Completed</span>
                                            }
                                            else if (sale.Status == "Voided")
                                            {

                                                <span class="status-voided">Voided</span>
                                            }
                                            else
                                            {

                                                <span class="badge-pending">Pending</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="action-btn-group">
                                                @if (sale.Status == "Pending" || string.IsNullOrEmpty(sale.Status))
                                                {
                                                    <button class="btn-mini btn-confirm-mini" onclick="event.stopPropagation(); updateStatus(@sale.SaleId, 'Completed')">✓</button>
                                                    <button class="btn-mini btn-void-mini" onclick="event.stopPropagation(); openVoidModal(@sale.SaleId)">✕</button>
                                                }
                                                else
                                                {
                                                    <span class="locked-badge">LOCKED</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>

                                    <tr id="details-@sale.SaleId" class="details-row">
                                        <td colspan="7">
                                            <div class="details-wrapper">
                                                <div>
                                                    <h4 class="details-header">📦 Items Sold</h4>
                                                    <ul id="items-list-@sale.SaleId" class="details-list">
                                                        <li>Loading...</li>
                                                    </ul>
                                                </div>
                                                <div>
                                                    <h4 class="details-header">📉 Ingredients Deducted</h4>
                                                    <ul id="ing-list-@sale.SaleId" class="details-list">
                                                        <li>Loading...</li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <script>
        let selectedSaleId = null;

        function updateStatus(saleId, status) {
        Swal.fire({
        title: 'Confirm Update?',
        text: `Mark Order #ORD-${saleId} as ${status}?`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#f46a05',
        cancelButtonColor: '#4a2511',
        confirmButtonText: 'Yes, confirm'
        }).then((result) => {
        if (result.isConfirmed) {
        fetch('/Manager/UpdateSaleStatus', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ saleId: saleId, status: status })
        }).then(res => {
        if(res.ok) location.reload();
        else Swal.fire('Error', 'Update failed.', 'error');
        });
        }
        });
        }

        function openVoidModal(saleId) {
        selectedSaleId = saleId;
        document.getElementById('displayId').innerText = saleId;
        document.getElementById('voidModal').classList.add('visible');
        }

        function closeModal() {
        document.getElementById('voidModal').classList.remove('visible');
        document.getElementById('mgrPass').value = '';
        }

        function confirmManagerVoid() {
        const passValue = document.getElementById('mgrPass').value;
        if(!passValue) {
        Swal.fire('Required', 'Please enter your password.', 'warning');
        return;
        }

        fetch('/Manager/VerifyAndVoid', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
        saleId: selectedSaleId,
        pass: passValue
        })
        }).then(async res => {
        if(res.ok) {
        Swal.fire({
        title: 'Voided!',
        text: 'Order status updated to Voided.',
        icon: 'success',
        confirmButtonColor: '#4a2511'
        }).then(() => location.reload());
        } else {
        const err = await res.json();
        Swal.fire('Denied', err.message || "Unauthorized access.", 'error');
        }
        });
        }

        async function toggleDetails(saleId) {
        const row = document.getElementById(`details-${saleId}`);
        row.classList.toggle('visible');

        if (row.classList.contains('visible')) {
        try {
        const res = await fetch(`/Manager/GetOrderDetails?saleId=${saleId}`);
        if(res.ok) {
        const data = await res.json();
        const itemsUl = document.getElementById(`items-list-${saleId}`);
        itemsUl.innerHTML = data.items.map(i => `<li>${i}</li>`).join('');
        const ingUl = document.getElementById(`ing-list-${saleId}`);
        ingUl.innerHTML = data.ingredients.length > 0 ?
        data.ingredients.map(i => `<li>${i}</li>`).join('') :
        `<li class="no-ingredients">No ingredients tied to this order.</li>`;
        }
        } catch (err) {
        console.error("Failed to load details");
        }
        }
        }
    </script>
</body>
</html>