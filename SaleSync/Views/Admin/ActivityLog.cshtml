@model List<SaleSync.Models.ActivityLog>
@{
    Layout = null;
    string homeController = User.IsInRole("Manager") ? "Manager" : "Admin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Activity Log - Cafero</title>
    <link rel="stylesheet" href="~/css/ActivityLog.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">Cafero</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <h2 class="admin-name">@(User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? User.Identity?.Name ?? "User")</h2>
                        <div class="admin-role">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="/@homeController/Dashboard" class="menu-btn">
                        Dashboard
                    </a>
                    <a href="/Admin/QueueOrder" class="menu-btn">Queue</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ActivityLog" class="menu-btn active">
                            Activity Log
                        </a>
                    }

                    <a href="/Admin/Analytics" class="menu-btn">
                        Analytics
                    </a>
                    <a href="/Admin/Products" class="menu-btn">
                        Products
                    </a>
                    <a href="/Admin/Inventory" class="menu-btn">
                        Inventory
                    </a>
                    <a href="/Admin/ArchivedProducts" class="menu-btn">Archived</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ManageAccounts" class="menu-btn">
                            Accounts
                        </a>
                    }
                    <a href="/Admin/WebCustomization" class="menu-btn">Customization</a>

                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout" id="logoutForm">
                    <button type="button" class="menu-btn logout-btn" onclick="confirmLogout()">
                        Log Out
                    </button>
                </form>
            </div>
        </aside>
        <div class="mobile-header">
            <button class="hamburger-btn" onclick="toggleSidebar()">
                <i class="fas fa-bars"></i>
            </button>
            <div class="mobile-brand">Cafero</div>
        </div>

        <main class="main-content slide-up">
            <div class="page-header">
                <h1 class="greeting-title">System Activity Log </h1>
                <p class="greeting-subtitle">Complete audit trail of all system actions and user behavior.</p>
            </div>

            <div class="log-container">
                <div class="filter-bar">
                    <input type="date" id="filterDate" class="filter-input" title="Filter by Date">

                    <select id="filterUser" class="filter-input" title="Filter by User Role">
                        <option value="">All Roles</option>
                        <option value="admin">Admin</option>
                        <option value="manager">Manager</option>
                        <option value="cashier">Cashier</option>
                    </select>

                    <select id="filterAction" class="filter-input" title="Filter by Action Type">
                        <option value="">All Actions</option>
                        <option value="access">System Access</option>
                        <option value="voided">Order Voided</option>
                        <option value="inventory">Inventory Actions</option>
                        <option value="product">Product Actions</option>
                        <option value="account">Account Actions</option>
                    </select>

                    <button class="btn-filter" onclick="applyFilters()">▼ Apply Filters</button>
                    <button class="btn-filter btn-clear-filter" onclick="clearFilters()">✕ Clear</button>
                </div>

                <div class="table-responsive">
                    <table class="activity-table" id="logTable">
                        <thead>
                            <tr>
                                <th>Timestamp</th>
                                <th>User</th>
                                <th>Action Type</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var log in Model)
                                {
                                    <tr class="log-row">
                                        <td class="log-date">@log.Timestamp.ToString("MMM dd, yyyy | hh:mm tt")</td>
                                        <td class="log-user">
                                            <strong>@log.Username</strong>
                                            <span class="log-user-role">(@log.Role)</span>
                                        </td>
                                        <td class="log-action">
                                            @{
                                                string colorClass = "badge-access";
                                                if (log.ActionType.Contains("Void") || log.ActionType.Contains("Deactivate") || log.ActionType.Contains("Delete"))
                                                    colorClass = "badge-void";
                                                else if (log.ActionType.Contains("Edit") || log.ActionType.Contains("Update") || log.ActionType.Contains("Create"))
                                                    colorClass = "badge-update";
                                            }
                                            <span class="badge @colorClass">@log.ActionType</span>
                                        </td>
                                        <td>
                                            <div class="log-details-text">@log.Details</div>

                                            @if (!string.IsNullOrWhiteSpace(log.OldValues) || !string.IsNullOrWhiteSpace(log.NewValues))
                                            {
                                                <button class="btn-mini"
                                                        data-old="@log.OldValues"
                                                        data-new="@log.NewValues"
                                                        onclick="viewChanges(this)">
                                                    🔍 View Data Changes
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr id="emptyRow">
                                    <td colspan="4" class="table-empty-state">No activity recorded yet. Start making changes to see them here!</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <script>
        function confirmLogout() {
        Swal.fire({
        title: 'Are you sure?',
        text: "You will be logged out of your session.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Yes, log out',
        cancelButtonText: 'Cancel'
        }).then((result) => {
        if (result.isConfirmed) {
        document.getElementById('logoutForm').submit();
        }
        });
        }
        function applyFilters() {
        const dateValue = document.getElementById('filterDate').value;
        const userValue = document.getElementById('filterUser').value.toLowerCase();
        const actionValue = document.getElementById('filterAction').value.toLowerCase();

        const rows = document.querySelectorAll('.log-row');

        rows.forEach(row => {
        const dateText = row.querySelector('.log-date').innerText;
        const userText = row.querySelector('.log-user').innerText.toLowerCase();
        const actionText = row.querySelector('.log-action').innerText.toLowerCase();

        let showRow = true;

        if (dateValue) {
        const datePart = dateText.split('|')[0].trim();
        const d = new Date(datePart);

        const localFormatted = d.getFullYear() + '-' +
        String(d.getMonth() + 1).padStart(2, '0') + '-' +
        String(d.getDate()).padStart(2, '0');

        if (localFormatted !== dateValue) showRow = false;
        }

        if (userValue && !userText.includes(userValue)) {
        showRow = false;
        }

        if (actionValue && !actionText.includes(actionValue)) {
        showRow = false;
        }

        row.style.display = showRow ? '' : 'none';
        });
        }

        function clearFilters() {
        document.getElementById('filterDate').value = '';
        document.getElementById('filterUser').value = '';
        document.getElementById('filterAction').value = '';
        applyFilters();
        }

        function viewChanges(btn) {
        const oldStr = btn.getAttribute('data-old');
        const newStr = btn.getAttribute('data-new');

        let oldObj = oldStr ? JSON.parse(oldStr) : {};
        let newObj = newStr ? JSON.parse(newStr) : {};

        let allKeys = new Set([...Object.keys(oldObj), ...Object.keys(newObj)]);

        let html = '<table class="audit-modal-table">';
        html += '<tr><th>Field / Item</th><th>Old Value</th><th>New Value</th></tr>';

        function formatData(val) {
        if (val === undefined || val === null) return '<i>None</i>';
        if (typeof val === 'object') {
        return `<pre class="audit-pre-block">${JSON.stringify(val, null, 2)}</pre>`;
        }
        return val;
        }

        allKeys.forEach(key => {
        let oldRaw = oldObj[key];
        let newRaw = newObj[key];

        let hasChanged = JSON.stringify(oldRaw) !== JSON.stringify(newRaw);
        let rowClass = hasChanged ? 'audit-row-changed' : 'audit-row-unstyled';

        let oldDisplay = formatData(oldRaw);
        let newDisplay = formatData(newRaw);

        html += `<tr class="${rowClass}">
        <td>${key}</td>
        <td class="audit-cell-old">${oldDisplay}</td>
        <td class="audit-cell-new">${newDisplay}</td>
        </tr>`;
        });

        html += '</table>';

        Swal.fire({
        title: 'Data Audit',
        html: html,
        width: '700px',
        confirmButtonColor: '#f46a05'
        });
        }
        function toggleSidebar() {
        const sidebar = document.querySelector('.sidebar');
        const overlay = document.querySelector('.sidebar-overlay');

        sidebar.classList.toggle('mobile-open');
        overlay.classList.toggle('mobile-open');
        }
    </script>
</body>
</html>