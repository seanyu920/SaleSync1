@model List<SaleSync.Models.ActivityLog>
@{
    Layout = null;
    string homeController = User.IsInRole("Manager") ? "Manager" : "Admin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Activity Log - Cafero</title>
    <link rel="stylesheet" href="~/css/ActivityLog.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div>
                <div class="logo-section" style="margin-bottom: 30px;">
                    <div class="logo-title">Cafero</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>
                <div class="profile-section" style="display: flex; align-items: center; justify-content: flex-start; gap: 15px; margin-bottom: 40px;">
                    <div class="profile-circle" style="width: 45px; height: 45px; flex-shrink: 0; background: #f46a05; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #fff;">👤</div>
                    <div>
                        <div class="admin-name" style="font-size: 16px; font-weight: 700; color: #fff;">Admin</div>
                        <div class="admin-role" style="font-size: 12px; color: #dcbca5;">Administrator</div>
                    </div>
                </div>
                <nav class="sidebar-menu">
                    <a href="/@homeController/Dashboard" class="menu-btn">❖ Dashboard</a>
                    <a href="/@homeController/PointOfSale" class="menu-btn">🛒 Point of Sale</a>
                    
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ActivityLog" class="menu-btn active">📋 Activity Log</a>
                    }
                    
                    <a href="/Admin/Analytics" class="menu-btn">📊 Analytics</a>
                    <a href="/Admin/Products" class="menu-btn">🏷️ Products</a>
                    <a href="/Admin/Inventory" class="menu-btn">📦 Inventory</a>
                    
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ManageAccounts" class="menu-btn">💳 Accounts</a>
                    }
                </nav>
            </div>
            <div class="logout-section" style="margin-top: auto;">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn" style="background: transparent; border: none; width: 100%; text-align: left; cursor: pointer; color: #dcbca5; padding: 14px 20px;">
                        ⎋ Log Out
                    </button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-header">
                <h1 class="greeting-title">System Activity Log 📋</h1>
                <p class="greeting-subtitle">Complete audit trail of all system actions and user behavior.</p>
            </div>

            <div class="log-container">
                <div class="filter-bar">
                    <input type="date" id="filterDate" class="filter-input" title="Filter by Date">
                    
                    <select id="filterUser" class="filter-input" title="Filter by User Role">
                        <option value="">All Roles</option>
                        <option value="admin">Admin</option>
                        <option value="manager">Manager</option>
                        <option value="cashier">Cashier</option>
                    </select>
                    
                    <select id="filterAction" class="filter-input" title="Filter by Action Type">
                        <option value="">All Actions</option>
                        <option value="access">System Access</option>
                        <option value="voided">Order Voided</option>
                        <option value="inventory">Inventory Actions</option>
                        <option value="product">Product Actions</option>
                        <option value="account">Account Actions</option>
                    </select>
                    
                    <button class="btn-filter" onclick="applyFilters()">▼ Apply Filters</button>
                    <button class="btn-filter" style="background: #fdfaf6; color: #8c5b3e; border: 1px solid #dcbca5;" onclick="clearFilters()">✕ Clear</button>
                </div>

                <table class="activity-table" id="logTable">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>User</th>
                            <th>Action Type</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var log in Model)
                            {
                                <tr class="log-row">
                                    <td style="font-weight: bold;" class="log-date">@log.Timestamp.ToString("MMM dd, yyyy | hh:mm tt")</td>
                                    <td class="log-user"><strong>@log.Username</strong> <span style="font-size: 11px; color: #888;">(@log.Role)</span></td>
                                    <td class="log-action">
                                        @{
                                            string colorClass = "badge-access";
                                            if (log.ActionType.Contains("Void") || log.ActionType.Contains("Deactivate") || log.ActionType.Contains("Delete"))
                                                colorClass = "badge-void";
                                            else if (log.ActionType.Contains("Edit") || log.ActionType.Contains("Update") || log.ActionType.Contains("Create"))
                                                colorClass = "badge-update";
                                        }
                                        <span class="badge @colorClass">@log.ActionType</span>
                                    </td>
                                    <td>
                                        <div style="color: #4a2511;">@log.Details</div>
                                        
                                        @if (!string.IsNullOrWhiteSpace(log.OldValues) || !string.IsNullOrWhiteSpace(log.NewValues))
                                        {
                                            <button class="btn-mini"
                                                    style="width: auto; padding: 4px 10px; margin-top: 8px; background: #fdfaf6; border: 1px solid #dcbca5; color: #8c5b3e; border-radius: 4px; font-size: 11px; cursor: pointer;"
                                                    data-old="@log.OldValues"
                                                    data-new="@log.NewValues"
                                                    onclick="viewChanges(this)">
                                                🔍 View Data Changes
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr id="emptyRow">
                                <td colspan="4" style="text-align: center; padding: 40px; color: #b58361;">No activity recorded yet. Start making changes to see them here!</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script>
        // ⭐ THE NEW FILTERING LOGIC ⭐
        function applyFilters() {
        const dateValue = document.getElementById('filterDate').value; // Format: YYYY-MM-DD
        const userValue = document.getElementById('filterUser').value.toLowerCase();
        const actionValue = document.getElementById('filterAction').value.toLowerCase();

        const rows = document.querySelectorAll('.log-row');

        rows.forEach(row => {
        const dateText = row.querySelector('.log-date').innerText; // "Apr 29, 2026 | 03:07 PM"
        const userText = row.querySelector('.log-user').innerText.toLowerCase();
        const actionText = row.querySelector('.log-action').innerText.toLowerCase();

        let showRow = true;

        // 1. Check Date Match
        if (dateValue) {
        // Extract just the "Apr 29, 2026" part and convert to Date object
        const datePart = dateText.split('|')[0].trim();
        const d = new Date(datePart);
                    
        // Format back to YYYY-MM-DD to compare safely without timezone issues
        const localFormatted = d.getFullYear() + '-' +
        String(d.getMonth() + 1).padStart(2, '0') + '-' +
        String(d.getDate()).padStart(2, '0');
                    
        if (localFormatted !== dateValue) showRow = false;
        }

        // 2. Check User Role Match
        if (userValue && !userText.includes(userValue)) {
        showRow = false;
        }

        // 3. Check Action Match
        if (actionValue && !actionText.includes(actionValue)) {
        showRow = false;
        }

        // Toggle the row visibility
        row.style.display = showRow ? '' : 'none';
        });
        }

        // Helper to quickly clear all filters
        function clearFilters() {
        document.getElementById('filterDate').value = '';
        document.getElementById('filterUser').value = '';
        document.getElementById('filterAction').value = '';
        applyFilters(); // Re-run to show all rows
        }

        // The JSON Data Difference Table Viewer
        function viewChanges(btn) {
        const oldStr = btn.getAttribute('data-old');
        const newStr = btn.getAttribute('data-new');

        let oldObj = oldStr ? JSON.parse(oldStr) : {};
        let newObj = newStr ? JSON.parse(newStr) : {};

        let allKeys = new Set([...Object.keys(oldObj), ...Object.keys(newObj)]);

        let html = '<table style="width:100%; text-align:left; border-collapse: collapse; font-size: 13px; margin-top: 10px;">';
        html += '<tr style="border-bottom: 2px solid #dcbca5;"><th style="padding: 8px; color: #8c5b3e;">Field / Item</th><th style="padding: 8px; color: #8c5b3e;">Old Value</th><th style="padding: 8px; color: #8c5b3e;">New Value</th></tr>';

        function formatData(val) {
        if (val === undefined || val === null) return '<i>None</i>';
        if (typeof val === 'object') {
        return `<pre style="margin: 0; white-space: pre-wrap; word-wrap: break-word; font-family: monospace; font-size: 11px; background: transparent; border: none; padding: 0;">${JSON.stringify(val, null, 2)}</pre>`;
        }
        return val;
        }

        allKeys.forEach(key => {
        let oldRaw = oldObj[key];
        let newRaw = newObj[key];

        let hasChanged = JSON.stringify(oldRaw) !== JSON.stringify(newRaw);
        let bg = hasChanged ? '#fff8f0' : 'transparent';
                
        let oldDisplay = formatData(oldRaw);
        let newDisplay = formatData(newRaw);

        let textDecor = (hasChanged && typeof oldRaw !== 'object') ? 'line-through' : 'none';
        let textWeight = (hasChanged && typeof newRaw !== 'object') ? 'bold' : 'normal';

        html += `<tr style="border-bottom: 1px solid #eee; background: ${bg}; vertical-align: top;">
        <td style="padding: 10px; font-weight:bold; color:#4a2511;">${key}</td>
        <td style="padding: 10px; color: ${hasChanged ? '#b91c1c' : '#666'}; text-decoration: ${textDecor}">${oldDisplay}</td>
        <td style="padding: 10px; color: ${hasChanged ? '#065f46' : '#666'}; font-weight: ${textWeight}">${newDisplay}</td>
        </tr>`;
        });
            
        html += '</table>';

        Swal.fire({
        title: 'Data Audit',
        html: html,
        width: '700px',
        confirmButtonColor: '#f46a05'
        });
        }
    </script>
</body>
</html>