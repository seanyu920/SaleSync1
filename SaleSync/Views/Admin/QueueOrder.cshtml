@model List<SaleHistoryItem>
@{
    ViewData["Title"] = "Queue Orders";
    Layout = null;
    bool isManager = User.IsInRole("Manager");
    string homeController = isManager ? "Manager" : "Admin";
    string displayRole = isManager ? "Manager" : "Admin";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "QueueOrder";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cafero</title>

    <!-- Framework Requirements matching your setup -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/QueueOrder.css" asp-append-version="true" />

    <!-- SweetAlert2 Library for Elegant Dark-Themed Popups -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

    <div class="dashboard-container">

        <!-- Sidebar Panel Component -->
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">Cafero</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <h2 class="admin-name">@displayRole</h2>
                        <div class="admin-role">System Access</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="/@homeController/Dashboard" class="menu-btn @(currentAction == "Dashboard" ? "active" : "")">
                        Dashboard
                    </a>

                    <a href="/@homeController/QueueOrder" class="menu-btn @(currentAction == "QueueOrder" || currentAction == "QueueOrders" ? "active" : "")">
                        Queue
                    </a>

                    @if (!User.IsInRole("Admin"))
                    {
                        <a href="/@homeController/PointOfSale" class="menu-btn @(currentAction == "PointOfSale" ? "active" : "")">
                            POS
                        </a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ActivityLog" class="menu-btn @(currentAction == "ActivityLog" ? "active" : "")">
                            Activity Log
                        </a>
                    }

                    <a href="/Admin/Analytics" class="menu-btn @(currentAction == "Analytics" ? "active" : "")">
                        Analytics
                    </a>

                    <a href="/Admin/Products" class="menu-btn @(currentAction == "Products" ? "active" : "")">
                        Products
                    </a>

                    <a href="/Admin/Inventory" class="menu-btn @(currentAction == "Inventory" ? "active" : "")">
                        Inventory
                    </a>

                    <a href="/Admin/ArchivedProducts" class="menu-btn @(currentAction == "ArchivedProducts" || currentAction == "Archive" ? "active" : "")">
                        Archived
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ManageAccounts" class="menu-btn @(currentAction == "ManageAccounts" ? "active" : "")">
                            Accounts
                        </a>
                    }
                    <a href="/Admin/WebCustomization" class="menu-btn @(currentAction == "WebCustomization" ? "active" : "")">
                        Customization
                    </a>
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn">
                        Log Out
                    </button>
                </form>
            </div>
        </aside>

        <!-- Main Workspace Grid -->
        <main class="main-content">
            <div class="queue-header">
                <div>
                    <h1>Live Production Queue</h1>
                    <p>Orders sorted oldest to newest. Complete orders to trigger automated ingredient level deductions.</p>
                </div>
                <div class="queue-stats">
                    <span class="stat-badge badge-pending">Pending: @Model.Count(o => o.Status == "Pending")</span>
                    <span class="stat-badge badge-preparing">Preparing: @Model.Count(o => o.Status == "Preparing" || o.Status == "Processing")</span>
                </div>
            </div>

            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info text-center" style="padding: 60px; background: #1a1d1b; border: 1px dashed #3a3d3b; border-radius: 12px; margin-top: 30px;">
                    <i class="fas fa-check-circle text-success" style="font-size: 54px; margin-bottom: 15px;"></i>
                    <h3 style="color: #fff; margin-bottom: 5px;">All caught up!</h3>
                    <p style="color: #a0a5a1; margin: 0;">There are no active orders inside the production pipeline right now.</p>
                </div>
            }
            else
            {
                <div class="queue-grid">
                    @foreach (var order in Model)
                    {
                        <div class="queue-card status-@order.Status">
                            <div>
                                <div class="card-header-info">
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <span class="order-id">#ORD-@order.SaleId</span>

                                        @{
                                            string badgeClass = "badge-q-default";
                                            string iconClass = "fas fa-clock";
                                            string currentStatus = order.Status ?? "Pending";

                                            switch (currentStatus)
                                            {
                                                case "Pending":
                                                    badgeClass = "badge-q-pending";
                                                    iconClass = "fas fa-hourglass-half animate-pulse";
                                                    break;
                                                case "Preparing":
                                                case "Processing":
                                                    badgeClass = "badge-q-preparing";
                                                    iconClass = "fas fa-mug-hot";
                                                    break;
                                                case "Delivery":
                                                case "Out for Delivery":
                                                    badgeClass = "badge-q-delivery";
                                                    iconClass = "fas fa-shipping-fast";
                                                    break;
                                                case "Completed":
                                                case "Done":
                                                    badgeClass = "badge-q-done";
                                                    iconClass = "fas fa-check-double";
                                                    break;
                                            }
                                        }
                                        <span class="badge-q @badgeClass">
                                            <i class="@iconClass"></i> @currentStatus
                                        </span>
                                    </div>
                                    <span class="order-time"><i class="far fa-clock"></i> @order.SaleDate.ToString("hh:mm tt")</span>
                                </div>

                                <h3 class="customer-name">
                                    @(string.IsNullOrEmpty(order.CustomerName) ? "Walk-In Customer" : order.CustomerName)
                                </h3>

                                <div class="order-meta">
                                    <span class="meta-tag"><i class="fas fa-utensils"></i> @(order.OrderType ?? "Dine-In")</span>
                                    <span class="meta-tag"><i class="fas fa-wallet"></i> @(order.PaymentMethod ?? "Cash")</span>
                                </div>

                                <div class="items-box">
                                    <span class="items-box-label">Items Summary:</span>
                                    @order.ItemsSummary
                                </div>
                            </div>

                            <div class="card-actions">
                                <button class="btn-action btn-view" onclick="openDetailsModal(@order.SaleId)">
                                    <i class="fas fa-eye"></i> Details
                                </button>

                                @if (order.Status == "Pending")
                                {
                                    <button class="btn-action btn-start" onclick="updateStatus(@order.SaleId, 'Preparing')">
                                        <i class="fas fa-coffee"></i> Prepare
                                    </button>
                                }
                                else if (order.Status == "Preparing" || order.Status == "Processing")
                                {
                                    <button class="btn-action btn-complete" onclick="updateStatus(@order.SaleId, 'Completed')">
                                        <i class="fas fa-check"></i> Complete
                                    </button>
                                }

                                <button class="btn-action btn-void" onclick="openVoidModal(@order.SaleId)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </main>
    </div>

    <!-- Order Details Modal -->
    <div id="detailsModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modalOrderTitle" style="margin:0; font-weight:700;">Order Breakdown</h3>
                <button class="modal-close" onclick="closeModal('detailsModal')">&times;</button>
            </div>
            <div>
                <h4 style="margin: 0 0 10px 0; color: #ffffff;">Menu Items Ordered</h4>
                <ul id="modalItemsList" class="list-group"></ul>

                <h4 style="margin: 20px 0 10px 0; color: #ffffff;">Deductible Ingredients Profile</h4>
                <ul id="modalIngredientsList" class="list-group" style="color: #a0a5a1;"></ul>
            </div>
        </div>
    </div>

    <!-- Secure Void Override Prompt Modal -->
    <div id="voidModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3 style="margin:0; font-weight:700;">Authorize Order Void</h3>
                <button class="modal-close" onclick="closeModal('voidModal')">&times;</button>
            </div>
            <div>
                <p style="margin:0 0 12px 0; color:#a0a5a1; font-size:14px; line-height:1.5;">Please input your manager account credentials to authorize voiding ticket <strong id="voidTargetLabel" style="color:#ffc107;"></strong>.</p>
                <input type="hidden" id="voidSaleId" />
                <input type="password" id="managerPassword" class="form-control" placeholder="Enter administrative password" />
                <div style="display:flex; gap:10px; margin-top:20px;">
                    <button class="btn-action btn-view" onclick="closeModal('voidModal')" style="flex:1;">Cancel</button>
                    <button class="btn-action btn-void" onclick="submitVoid()" style="flex:1; width:auto; font-weight:700;">Confirm Override</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Script Controllers using SweetAlert2 -->
    <script>
        // 1. Handle Order Status Progression (Prepare / Complete)
        async function updateStatus(saleId, targetStatus) {
        try {
        const res = await fetch('/@homeController/UpdateSaleStatus', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ saleId: saleId, status: targetStatus })
        });

        if (res.ok) {
        await Swal.fire({
        icon: 'success',
        title: 'Pipeline Updated',
        text: `Order #ORD-${saleId} moved to ${targetStatus}.`,
        background: '#1e201f',
        color: '#ffffff',
        timer: 1500,
        showConfirmButton: false
        });
        location.reload();
        } else {
        let serverErrorMessage = 'Could not modify status pipelines successfully.';
        try {
        const errorData = await res.json();
        if (errorData && errorData.message) {
        serverErrorMessage = errorData.message;
        }
        } catch (jsonErr) {}

        Swal.fire({
        icon: 'error',
        title: 'Pipeline Error',
        text: serverErrorMessage,
        background: '#1e201f',
        color: '#ffffff',
        confirmButtonColor: '#dc3545'
        });
        }
        } catch (err) {
        console.error('Status Error:', err);
        Swal.fire({
        icon: 'error',
        title: 'Network Error',
        text: 'Failed to communicate with the server infrastructure.',
        background: '#1e201f',
        color: '#ffffff',
        confirmButtonColor: '#dc3545'
        });
        }
        }

        // 2. Fetch and View Production Recipe Details
        async function openDetailsModal(saleId) {
        try {
        document.getElementById('modalOrderTitle').innerText = `Order Details: #ORD-${saleId}`;
        const itemsList = document.getElementById('modalItemsList');
        const ingList = document.getElementById('modalIngredientsList');

        itemsList.innerHTML = '<li>Loading production lists...</li>';
        ingList.innerHTML = '<li>Calculating inventory weights...</li>';
        document.getElementById('detailsModal').style.display = 'flex';

        const res = await fetch(`/@homeController/GetOrderDetails?saleId=${saleId}`);
        if (!res.ok) throw new Error('Server returned error status');

        const data = await res.json();
        itemsList.innerHTML = '';
        ingList.innerHTML = '';

        if (data.items && data.items.length > 0) {
        data.items.forEach(i => itemsList.innerHTML += `<li><i class="fas fa-shopping-basket" style="color:#888e8a; margin-right:8px;"></i> ${i}</li>`);
        } else {
        itemsList.innerHTML = '<li>No menu items found for this record.</li>';
        }

        if (data.ingredients && data.ingredients.length > 0) {
        data.ingredients.forEach(i => ingList.innerHTML += `<li><i class="fas fa-leaf" style="color:#3dbf78; margin-right:8px;"></i> ${i}</li>`);
        } else {
        ingList.innerHTML = '<li>No recipe tracking parameters needed for this order configuration.</li>';
        }
        } catch (err) {
        console.error('Data Pull Error:', err);
        closeModal('detailsModal');
        Swal.fire({
        icon: 'error',
        title: 'Fetch Failed',
        text: 'Unable to query recipe item information parameters.',
        background: '#1e201f',
        color: '#ffffff',
        confirmButtonColor: '#dc3545'
        });
        }
        }

        // 3. Admin Authorization Controls for Voiding
        function openVoidModal(saleId) {
        document.getElementById('voidSaleId').value = saleId;
        document.getElementById('voidTargetLabel').innerText = `#ORD-${saleId}`;
        document.getElementById('managerPassword').value = '';
        document.getElementById('voidModal').style.display = 'flex';
        }

        async function submitVoid() {
        const saleId = parseInt(document.getElementById('voidSaleId').value);
        const pass = document.getElementById('managerPassword').value;

        if (!pass) {
        Swal.fire({
        icon: 'warning',
        title: 'Access Denied',
        text: 'Management clearance passphrase required.',
        background: '#1e201f',
        color: '#ffffff',
        confirmButtonColor: '#ffc107'
        });
        return;
        }

        try {
        const res = await fetch('/@homeController/VerifyAndVoid', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ saleId: saleId, pass: pass })
        });

        if (res.ok) {
        closeModal('voidModal');
        await Swal.fire({
        icon: 'success',
        title: 'Ticket Voided',
        text: `Order #ORD-${saleId} has been successfully canceled.`,
        background: '#1e201f',
        color: '#ffffff',
        timer: 1500,
        showConfirmButton: false
        });
        location.reload();
        } else {
        let errorMessage = 'An unexpected system error occurred.';
        if (res.status === 401) {
        errorMessage = 'Invalid management credentials. Override denied.';
        } else {
        try {
        const errorData = await res.json();
        if (errorData && errorData.message) errorMessage = errorData.message;
        } catch (e) {}
        }

        Swal.fire({
        icon: 'error',
        title: res.status === 401 ? 'Unauthorized' : 'System Error',
        text: errorMessage,
        background: '#1e201f',
        color: '#ffffff',
        confirmButtonColor: '#dc3545'
        });
        }
        } catch (err) {
        console.error('Void Error Tracker:', err);
        Swal.fire({
        icon: 'error',
        title: 'Network Error',
        text: 'Failed to securely connect to authorization terminal.',
        background: '#1e201f',
        color: '#ffffff',
        confirmButtonColor: '#dc3545'
        });
        }
        }

        // 4. Modal Window Interface Handlers
        function closeModal(modalId) {
        document.getElementById(modalId).style.display = 'none';
        }

        window.onclick = function(event) {
        if (event.target.classList.contains('modal-overlay')) {
        event.target.style.display = 'none';
        }
        }
    </script>
</body>
</html>