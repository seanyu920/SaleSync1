@model SaleSync.Models.AnalyticsViewModel
@{
    Layout = null;
    bool isManager = User.IsInRole("Manager");
    string homeController = isManager ? "Manager" : "Admin";
    string displayRole = isManager ? "Manager" : "Admin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@displayRole Analytics - Cafero</title>
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        .kpi-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 25px;
        }

        .kpi-card {
        background: var(--bg-card, #1e1e24);
        border: 1px solid var(--border, rgba(255,255,255,0.08));
        border-radius: 12px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.15);
        transition: transform 0.2s ease;
        }

        .kpi-card:hover {
        transform: translateY(-3px);
        }

        .kpi-icon-wrapper {
        width: 50px;
        height: 50px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        background: rgba(201, 168, 76, 0.12);
        color: var(--gold, #C9A84C);
        }

        .kpi-details h3 {
        margin: 0;
        font-size: 13px;
        color: var(--muted, rgba(242, 237, 228, 0.6));
        text-transform: uppercase;
        letter-spacing: 0.5px;
        }

        .kpi-details p {
        margin: 5px 0 0 0;
        font-size: 22px;
        font-weight: 700;
        color: var(--cream, #f2ede4);
        }
        /* Tweaking the main layouts to comfortably fit our new 2-column charts layout */
        .analytics-main-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
        }

        @@media (max-width: 1024px) {
        .analytics-main-grid {
        grid-template-columns: 1fr;
        }
        }

        .charts-flex-column {
        display: flex;
        季direction: column;
        flex-direction: column;
        gap: 20px;
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">Cafero</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <h2 class="admin-name">@displayRole</h2>
                        <div class="admin-role">System Access</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="/@homeController/Dashboard" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="fas fa-chart-line"></i> Dashboard
                    </a>
                    <a href="/Admin/QueueOrder" class="menu-btn"><i class="fas fa-list-ol"></i> Queue</a>


                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ActivityLog" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "ActivityLog" ? "active" : "")">
                            <i class="fas fa-clipboard-list"></i> Activity Log
                        </a>
                    }

                    <a href="/Admin/Analytics" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "Analytics" ? "active" : "")">
                        <i class="fas fa-chart-pie"></i> Analytics
                    </a>
                    

                    <a href="/Admin/Products" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "Products" ? "active" : "")">
                        <i class="fas fa-tags"></i> Products
                    </a>

                    <a href="/Admin/Inventory" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "Inventory" ? "active" : "")">
                        <i class="fas fa-box-open"></i> Inventory
                    </a>
                    <a href="/Admin/ArchivedProducts" class="menu-btn"><i class="fas fa-archive"></i> Archived</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ManageAccounts" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "ManageAccounts" ? "active" : "")">
                            <i class="fas fa-credit-card"></i> Accounts
                        </a>
                    }
                    <a href="/Admin/WebCustomization" class="menu-btn"><i class="fas fa-tags"></i> Customization</a>
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn">
                        <i class="fas fa-sign-out-alt"></i> Log Out
                    </button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-header">
                <div>
                    <h1 class="greeting-title">Analytics Overview 📊</h1>
                    <p class="greeting-subtitle">Deep dive into your sales and performance metrics.</p>
                </div>

                <div class="timeframe-filter" style="margin-top: 12px;">
                    <select id="analyticsTimeframe" title="Select Timeframe" style="padding: 8px 12px; background: var(--bg-card); color: var(--cream); border: 1px solid var(--border); border-radius: 8px; font-family: inherit; outline: none; cursor: pointer;">
                        <option value="today" selected="@(Model.SelectedTimeframe == "today")">📅 Today</option>
                        <option value="week" selected="@(Model.SelectedTimeframe == "week")">📅 This Week</option>
                        <option value="month" selected="@(Model.SelectedTimeframe == "month")">📅 This Month</option>
                        <option value="year" selected="@(Model.SelectedTimeframe == "year")">📅 This Year</option>
                    </select>
                </div>
            </div>

            <div class="kpi-row">
                <div class="kpi-card">
                    <div class="kpi-icon-wrapper"><i class="fas fa-wallet"></i></div>
                    <div class="kpi-details">
                        <h3>Gross Revenue</h3>
                        <p>₱@Model.TotalRevenue.ToString("N2")</p>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon-wrapper"><i class="fas fa-receipt"></i></div>
                    <div class="kpi-details">
                        <h3>Total Transactions</h3>
                        <p>@Model.TotalTransactions.ToString("N0")</p>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon-wrapper"><i class="fas fa-calculator"></i></div>
                    <div class="kpi-details">
                        <h3>Average Order Value</h3>
                        <p>₱@Model.AverageOrderValue.ToString("N2")</p>
                    </div>
                </div>
            </div>

            <div class="analytics-main-grid">

                <div class="charts-flex-column">
                    <div class="chart-card">
                        <h2 class="widget-title">Gross Sales Volume</h2>
                        <div style="position: relative; height: 280px; width: 100%;">
                            <canvas id="salesChart"></canvas>
                        </div>
                    </div>

                    <div class="chart-card">
                        <h2 class="widget-title">Peak Business Hours (Hourly Foot Traffic)</h2>
                        <div style="position: relative; height: 280px; width: 100%;">
                            <canvas id="peakHoursChart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="charts-flex-column">
                    <div class="chart-card">
                        <h2 class="widget-title">Best Sellers</h2>
                        <div class="best-selling-list">
                            @if (Model.BestSellers != null && Model.BestSellers.Any())
                            {
                                foreach (var item in Model.BestSellers)
                                {
                                    <div class="best-selling-item" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                                        <span class="item-name">@item.ProductName</span>
                                        <span class="item-sold" style="background: rgba(201,168,76,0.15); color: var(--gold, #C9A84C); padding: 2px 8px; border-radius: 20px; font-weight: bold; font-size: 12px;">@item.TotalSold sold</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div style="text-align: center; color: var(--muted); padding: 20px 0; font-size: 13px;">
                                    No sales transactions recorded within this tracking range.
                                </div>
                            }
                        </div>
                    </div>

                    <div class="chart-card">
                        <h2 class="widget-title">Payment Methods</h2>
                        <div class="pie-chart-container" style="position: relative; height: 210px;">
                            <canvas id="paymentChart"></canvas>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {

        // --- 1. Dynamic Sales Bar Chart Initialization ---
        const salesLabels = @Html.Raw(Json.Serialize(Model.SalesLabels));
        const salesValues = @Html.Raw(Json.Serialize(Model.SalesValues));

        const salesCanvas = document.getElementById('salesChart');
        if (salesCanvas && salesLabels.length > 0) {
        const ctx = salesCanvas.getContext('2d');
        new Chart(ctx, {
        type: 'bar',
        data: {
        labels: salesLabels,
        datasets: [{
        label: 'Gross Revenue (₱)',
        data: salesValues,
        backgroundColor: '#C9A84C',
        borderRadius: 6
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
        y: {
        beginAtZero: true,
        grid: { color: 'rgba(255, 255, 255, 0.05)' },
        ticks: { color: 'rgba(242, 237, 228, 0.6)' }
        },
        x: {
        grid: { display: false },
        ticks: { color: 'rgba(242, 237, 228, 0.6)' }
        }
        }
        }
        });
        }

        // --- 2. NEW: Peak Hours Curved Spline Line Chart ---
        const peakHourLabels = @Html.Raw(Json.Serialize(Model.PeakHourLabels));
        const peakHourCounts = @Html.Raw(Json.Serialize(Model.PeakHourOrderCounts));

        const peakCanvas = document.getElementById('peakHoursChart');
        if (peakCanvas && peakHourLabels.length > 0) {
        const ctx = peakCanvas.getContext('2d');
        new Chart(ctx, {
        type: 'line',
        data: {
        labels: peakHourLabels,
        datasets: [{
        label: 'Orders Processed',
        data: peakHourCounts,
        borderColor: '#C9A84C',
        backgroundColor: 'rgba(201, 168, 76, 0.08)',
        fill: true,
        tension: 0.35, // Gives that smooth aesthetic curve
        pointBackgroundColor: '#f2ede4',
        pointRadius: 4
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
        y: {
        beginAtZero: true,
        min: 0,
        ticks: { stepSize: 1, color: 'rgba(242, 237, 228, 0.6)' },
        grid: { color: 'rgba(255, 255, 255, 0.05)' }
        },
        x: {
        grid: { display: false },
        ticks: { color: 'rgba(242, 237, 228, 0.6)' }
        }
        }
        }
        });
        } else if (peakCanvas) {
        const ctx = peakCanvas.getContext('2d');
        ctx.font = "14px sans-serif";
        ctx.fillStyle = "rgba(242, 237, 228, 0.4)";
        ctx.textAlign = "center";
        ctx.fillText("No hourly trend activity found for this range.", peakCanvas.width / 2, peakCanvas.height / 2);
        }

        // --- 3. Dynamic Payment Doughnut Chart ---
        const paymentLabels = @Html.Raw(Json.Serialize(Model.PaymentLabels));
        const paymentValues = @Html.Raw(Json.Serialize(Model.PaymentValues));

        const paymentCanvas = document.getElementById('paymentChart');
        if (paymentCanvas && paymentLabels.length > 0) {
        const paymentCtx = paymentCanvas.getContext('2d');
        new Chart(paymentCtx, {
        type: 'doughnut',
        data: {
        labels: paymentLabels,
        datasets: [{
        data: paymentValues,
        backgroundColor: ['#C9A84C', '#DDB95E', '#A18232', '#E7CB7C'],
        borderWidth: 0
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: {
        position: 'bottom',
        labels: { color: 'rgba(242, 237, 228, 0.8)', padding: 10, boxWidth: 12 }
        }
        },
        cutout: '73%' // Slightly thinner doughnut circle for an elegant profile
        }
        });
        }

        // --- 4. Route Reloading Event Listener ---
        const timeframeSelect = document.getElementById('analyticsTimeframe');
        if (timeframeSelect) {
        timeframeSelect.addEventListener('change', function() {
        window.location.href = `/${'@homeController'}/Analytics?timeframe=` + this.value;
        });
        }
        });
    </script>
</body>
</html>