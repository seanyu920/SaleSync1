@model dynamic
@{
    Layout = null;
    bool isManager = User.IsInRole("Manager");
    string homeController = isManager ? "Manager" : "Admin";
    string displayRole = isManager ? "Manager" : "Admin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@displayRole Analytics - Cafero</title>
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="dashboard-container">
        <!-- ==========================================================================
           SIDEBAR
           ========================================================================== -->
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">Cafero</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <h2 class="admin-name">@displayRole</h2>
                        <div class="admin-role">System Access</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="/@homeController/Dashboard" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="fas fa-chart-line"></i> Dashboard
                    </a>

                    <a href="/@homeController/PointOfSale" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "PointOfSale" ? "active" : "")">
                        <i class="fas fa-shopping-cart"></i> POS
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ActivityLog" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "ActivityLog" ? "active" : "")">
                            <i class="fas fa-clipboard-list"></i> Activity Log
                        </a>
                    }

                    <a href="/Admin/Analytics" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "Analytics" ? "active" : "")">
                        <i class="fas fa-chart-pie"></i> Analytics
                    </a>

                    <a href="/Admin/Products" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "Products" ? "active" : "")">
                        <i class="fas fa-tags"></i> Products
                    </a>

                    <a href="/Admin/Inventory" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "Inventory" ? "active" : "")">
                        <i class="fas fa-box-open"></i> Inventory
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ManageAccounts" class="menu-btn @(ViewContext.RouteData.Values["action"]?.ToString() == "ManageAccounts" ? "active" : "")">
                            <i class="fas fa-credit-card"></i> Accounts
                        </a>
                    }
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn">
                        <i class="fas fa-sign-out-alt"></i> Log Out
                    </button>
                </form>
            </div>
        </aside>

        <!-- ==========================================================================
           MAIN CONTENT
           ========================================================================== -->
        <main class="main-content">
            <div class="page-header">
                <div>
                    <h1 class="greeting-title">Analytics Overview 📊</h1>
                    <p class="greeting-subtitle">Deep dive into your sales and performance metrics.</p>
                </div>

                <div class="timeframe-filter" style="margin-top: 12px;">
                    <!-- Added a style block directly to clean up select element baseline visibility -->
                    <select id="analyticsTimeframe" title="Select Timeframe" style="padding: 8px 12px; background: var(--bg-card); color: var(--cream); border: 1px solid var(--border); border-radius: 8px; font-family: inherit; outline: none; cursor: pointer;">
                        <option value="today">📅 Today</option>
                        <option value="week" selected>📅 This Week</option>
                        <option value="month">📅 This Month</option>
                        <option value="year">📅 This Year</option>
                        <option value="custom">⚙️ Custom Range...</option>
                    </select>
                </div>
            </div>

            <div class="analytics-grid">
                <!-- Left Column: Main Bar Chart -->
                <div class="chart-column">
                    <div class="chart-card">
                        <h2 class="widget-title">Sales Analytics</h2>
                        <!-- Fixed size canvas wrapper container to prevent the stretching issue -->
                        <div style="position: relative; height: 340px; width: 100%;">
                            <canvas id="salesChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Sidebar Widgets -->
                <div class="widgets-column">
                    <div class="chart-card">
                        <h2 class="widget-title">Best Sellers</h2>
                        <div class="best-selling-list">
                            <div class="best-selling-item">
                                <span class="item-name">Americano</span>
                                <span class="item-sold">120 sold</span>
                            </div>
                            <div class="best-selling-item">
                                <span class="item-name">Wintermelon</span>
                                <span class="item-sold">98 sold</span>
                            </div>
                            <div class="best-selling-item">
                                <span class="item-name">Green Apple</span>
                                <span class="item-sold">85 sold</span>
                            </div>
                        </div>
                    </div>

                    <div class="chart-card">
                        <h2 class="widget-title">Payment Methods</h2>
                        <div class="pie-chart-container">
                            <canvas id="paymentChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- ==========================================================================
       JAVASCRIPT LOGIC
       ========================================================================== -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {

        // 1. Sales Bar Chart Configuration
        const salesCanvas = document.getElementById('salesChart');
        if (salesCanvas) {
        const ctx = salesCanvas.getContext('2d');
        new Chart(ctx, {
        type: 'bar',
        data: {
        labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
        datasets: [{
        label: 'Sales Output',
        data: [12, 19, 8, 15, 22, 17, 25],
        // Tailored palette matched to the theme's core gold/earth color palette
        backgroundColor: ['#C9A84C', '#DDB95E', 'rgba(201, 168, 76, 0.4)', '#C9A84C', '#DDB95E', 'rgba(201, 168, 76, 0.4)', '#C9A84C'],
        borderRadius: 6
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: { display: false }
        },
        scales: {
        y: {
        beginAtZero: true,
        grid: { color: 'rgba(255, 255, 255, 0.05)' },
        ticks: { color: 'rgba(242, 237, 228, 0.6)' }
        },
        x: {
        grid: { display: false },
        ticks: { color: 'rgba(242, 237, 228, 0.6)' }
        }
        }
        }
        });
        }

        // 2. Payment Donut Chart Configuration
        const paymentCanvas = document.getElementById('paymentChart');
        if (paymentCanvas) {
        const paymentCtx = paymentCanvas.getContext('2d');
        new Chart(paymentCtx, {
        type: 'doughnut',
        data: {
        labels: ['Cash', 'GCash', 'Card'],
        datasets: [{
        data: [50, 30, 20],
        backgroundColor: ['#C9A84C', '#DDB95E', 'rgba(201, 168, 76, 0.3)'],
        borderWidth: 0
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: {
        position: 'bottom',
        labels: { color: 'rgba(242, 237, 228, 0.8)', padding: 15 }
        }
        },
        cutout: '72%'
        }
        });
        }

        // Timeframe Selector Action Event
        const timeframeSelect = document.getElementById('analyticsTimeframe');
        if (timeframeSelect) {
        timeframeSelect.addEventListener('change', function() {
        console.log("Timeframe changed to: " + this.value);
        });
        }
        });
    </script>
</body>
</html>