@model SaleSync.Models.CashierDashboardViewModel
@{
    Layout = null;
}<!DOCTYPE html><html lang="en"><head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Dashboard - SyncScale</title>
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <style>
        /* Security Modal Styles */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center; }
        .auth-modal { background: white; padding: 25px; border-radius: 15px; width: 320px; text-align: center; box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
        .auth-modal input { width: 100%; padding: 10px; margin: 15px 0; border: 1px solid #ddd; border-radius: 8px; }
        .auth-btn { background: #f46a05; color: white; border: none; padding: 10px; width: 100%; border-radius: 8px; cursor: pointer; font-weight: bold; }
        
        /* Action Button Styles */
        .action-btn-group { display: flex; gap: 8px; justify-content: center; }
        .btn-mini { width: 28px; height: 28px; border-radius: 50%; border: none; cursor: pointer; font-weight: bold; transition: 0.2s; display: flex; align-items: center; justify-content: center; }
        .btn-confirm-mini { background: #d1fae5; color: #065f46; }
        .btn-confirm-mini:hover { background: #065f46; color: white; }
        .btn-void-mini { background: #fee2e2; color: #b91c1c; }
        .btn-void-mini:hover { background: #b91c1c; color: white; }
        
        /* Badges */
        .status-voided { background: #fee2e2; color: #b91c1c; padding: 4px 12px; border-radius: 15px; font-size: 11px; font-weight: 700; display: inline-block; }
    </style>
</head>
<body>

    <div id="voidModal" class="modal-overlay">
        <div class="auth-modal">
            <h3 style="color: #4a2511;">Authorize Void</h3>
            <p style="font-size: 12px; color: #8c5b3e; margin-top: 5px;">Enter your Admin password to void <br><strong>Order #ORD-<span id="displayId"></span></strong></p>
            <input type="password" id="adminPass" placeholder="Admin Password" />
            <button class="auth-btn" onclick="confirmAdminVoid()">Verify & Void</button>
            <p onclick="closeModal()" style="margin-top:15px; cursor:pointer; font-size:12px; color:#999;">Cancel</p>
        </div>
    </div>

    <div class="dashboard-container">

        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">Cafero</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <div class="admin-name">Admin</div>
                        <div class="admin-role">Administrator</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a asp-controller="Admin" asp-action="Dashboard" class="menu-btn active">❖ Dashboard</a>
                    <a asp-controller="Admin" asp-action="Analytics" class="menu-btn">📊 Analytics</a>
                    <a asp-controller="Admin" asp-action="Products" class="menu-btn">🏷️ Products</a>
                    <a asp-controller="Admin" asp-action="Inventory" class="menu-btn">📦 Inventory</a>
                    <a asp-controller="Admin" asp-action="ManageAccounts" class="menu-btn">💳 Accounts</a>
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn">⎋ Log Out</button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            
            <div class="page-header">
                <h1 class="greeting-title">Good Morning! ☕</h1>
                <p class="greeting-subtitle">Welcome back! Here's what's brewing today.</p>
            </div>

            <div class="summary-dashboard">
                <div class="summary-card">
                    <div class="card-icon-box icon-orange">📦</div>
                    <div class="card-label">Total Inventory Items</div>
                    <div class="card-value">1,247</div>
                    <span class="trend-badge trend-yellow">+ 12% from last month</span>
                </div>

                <div class="summary-card">
                    <div class="card-icon-box icon-green">📈</div>
                    <div class="card-label">Total Sales Today</div>
                    <div class="card-value">₱@Model.TodayTotalSales.ToString("N2")</div>
                    <span class="trend-badge trend-green">Real-time sync</span>
                </div>

                <div class="summary-card">
                    <div class="card-icon-box icon-light-orange">📁</div>
                    <div class="card-label">Total Transactions</div>
                    <div class="card-value">@Model.TodayTransactionCount</div>
                    <span class="trend-badge trend-orange">Updated today</span>
                </div>

                <div class="summary-card">
                    <div class="card-icon-box icon-red">⚠️</div>
                    <div class="card-label">Low Stock Alerts</div>
                    <div class="card-value">7</div>
                    <span class="trend-badge trend-red">Requires attention</span>
                </div>
            </div>

            <div class="recent-sales-card">
                <div class="card-header-flex">
                    <div>
                        <h2 class="widget-title">Recent Sales</h2>
                        <p class="widget-subtitle">Latest transactions from today</p>
                    </div>
                    <a href="#" class="view-all-link">View Full Report &rarr;</a>
                </div>
                
                <div class="table-responsive">
                    <table class="recent-sales-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Time</th>
                                <th>Cashier</th>
                                <th>Items</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                                <th style="text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.RecentSales != null && Model.RecentSales.Any())
                        {
                            @foreach (var sale in Model.RecentSales)
                            {
                                <tr onclick="toggleDetails(@sale.SaleId)" style="cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='#fcf9f5'" onmouseout="this.style.background='transparent'">
                                    <td class="td-bold">#ORD-@sale.SaleId</td>
                                    <td>@sale.SaleDate.ToString("hh:mm tt")</td>
                                    <td><span class="badge-cashier">@sale.CashierName</span></td>
                                    <td>@sale.ItemsSummary</td>
                                    <td class="td-price">₱@sale.TotalAmount.ToString("N2")</td>
                                    <td>
                                        @if (sale.Status == "Completed") { <span class="badge-completed" style="background: #d1fae5; color: #065f46; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">Completed</span> }
                                        else if (sale.Status == "Voided") { <span class="status-voided" style="background: #fee2e2; color: #b91c1c; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">Voided</span> }
                                        else { <span class="badge-pending" style="background: #fef3c7; color: #92400e; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">Pending</span> }
                                    </td>
                                    <td style="text-align: center;">
                                        <div class="action-btn-group">
                                            @if (sale.Status == "Pending" || string.IsNullOrEmpty(sale.Status))
                                            {
                                              <button class="btn-mini btn-confirm-mini" onclick="event.stopPropagation(); updateStatus(@sale.SaleId, 'Completed')">✓</button>
                                              <button class="btn-mini btn-void-mini" onclick="event.stopPropagation(); openVoidModal(@sale.SaleId)">✕</button>
                                            }
                                            else
                                            {
                                                <span style="color: #dcbca5; font-size: 11px; font-weight: bold;">LOCKED</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                
                                <tr id="details-@sale.SaleId" class="details-row" style="display: none; background: #faf8f5;">
                                    <td colspan="7" style="padding: 0;">
                                        <div style="padding: 15px 25px; border-left: 4px solid #f46a05; display: flex; gap: 50px; text-align: left; margin: 5px 15px 15px 15px; background: white; border-radius: 8px; box-shadow: inset 0 0 10px rgba(0,0,0,0.02);">
                                            <div style="flex: 1;">
                                                <h4 style="margin: 0 0 8px 0; color: #8c5b3e; font-size: 13px; text-transform: uppercase;">📦 Items Sold</h4>
                                                <ul id="items-list-@sale.SaleId" style="margin: 0; padding-left: 20px; font-size: 14px; color: #4a2511; line-height: 1.6;">
                                                    <li>Loading...</li>
                                                </ul>
                                            </div>
                                            <div style="flex: 1.5;">
                                                <h4 style="margin: 0 0 8px 0; color: #8c5b3e; font-size: 13px; text-transform: uppercase;">📉 Ingredients Deducted</h4>
                                                <ul id="ing-list-@sale.SaleId" style="margin: 0; padding-left: 20px; font-size: 14px; color: #4a2511; line-height: 1.6;">
                                                    <li>Loading...</li>
                                                </ul>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                    </table>
                </div>
            </div>

        </main>
    </div>

    <script>
        let selectedSaleId = null;

        function updateStatus(saleId, status) {
            if(!confirm(`Confirm Order #ORD-${saleId} as ${status}?`)) return;
            fetch('/Admin/UpdateSaleStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ saleId: saleId, status: status })
            }).then(res => res.ok ? location.reload() : alert("Update failed"));
        }

        function openVoidModal(saleId) {
            selectedSaleId = saleId;
            document.getElementById('displayId').innerText = saleId;
            document.getElementById('voidModal').style.display = 'flex';
        }

        function closeModal() { document.getElementById('voidModal').style.display = 'none'; }

        function confirmAdminVoid() {
            const passValue = document.getElementById('adminPass').value;
            if(!passValue) return alert("Please enter your password");

            fetch('/Admin/VerifyAndVoid', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    saleId: selectedSaleId, 
                    pass: passValue 
                })
            }).then(async res => {
                if(res.ok) {
                    location.reload();
                } else {
                    const err = await res.json();
                    alert(err.message || "Unauthorized");
                }
            });
        } // <--- THIS CLOSING BRACE WAS MISSING!

        // Opens the row and fetches the live ingredient deduction math
        async function toggleDetails(saleId) {
            const row = document.getElementById(`details-${saleId}`);
            const isExpanding = row.style.display === 'none';
            
            // Auto-close any other open rows
            document.querySelectorAll('.details-row').forEach(r => r.style.display = 'none');
            
            if (isExpanding) {
                row.style.display = 'table-row';
                
                try {
                    // Fetching from the Admin Controller!
                    const res = await fetch(`/Admin/GetOrderDetails?saleId=${saleId}`);
                    if(res.ok) {
                        const data = await res.json();
                        
                        const itemsUl = document.getElementById(`items-list-${saleId}`);
                        itemsUl.innerHTML = data.items.map(i => `<li>${i}</li>`).join('');
                        
                        const ingUl = document.getElementById(`ing-list-${saleId}`);
                        if (data.ingredients.length > 0) {
                            ingUl.innerHTML = data.ingredients.map(i => `<li>${i}</li>`).join('');
                        } else {
                            ingUl.innerHTML = `<li style="color: #999; list-style: none; margin-left: -20px;">No ingredients tied to this order.</li>`;
                        }
                    }
                } catch (err) {
                    console.error("Failed to load details");
                }
            }
        }
    </script>
</body></html>