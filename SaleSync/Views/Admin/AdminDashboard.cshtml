@model SaleSync.Models.CashierDashboardViewModel
@{
    Layout = null;
    string homeController = "Admin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Dashboard - Cafero</title>
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Real-Time Chat SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
</head>
<body>

    <div class="dashboard-container">
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">Cafero</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <h2 class="admin-name">@(User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? User.Identity?.Name ?? "User")</h2>
                        <div class="admin-role">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? User.FindFirst("Role")?.Value ?? "User")</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="/@homeController/Dashboard" class="menu-btn active">Dashboard</a>
                    <a href="/Admin/QueueOrder" class="menu-btn">Queue</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ActivityLog" class="menu-btn">Activity Log</a>
                    }

                    <a href="/Admin/Analytics" class="menu-btn">Analytics</a>
                    <a href="/Admin/Products" class="menu-btn">Products</a>
                    <a href="/Admin/Inventory" class="menu-btn">Inventory</a>

                    <a href="/Admin/ArchivedProducts" class="menu-btn">Archived</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ManageAccounts" class="menu-btn">Accounts</a>
                    }
                    <a href="/Admin/WebCustomization" class="menu-btn">Customization</a>
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout" id="logoutForm">
                    <button type="button" class="menu-btn logout-btn" onclick="confirmLogout()">
                        Log Out
                    </button>
                </form>
            </div>
        </aside>

        <div class="mobile-header">
            <button class="hamburger-btn" onclick="toggleSidebar()">
                <i class="fas fa-bars"></i>
            </button>
            <div class="mobile-brand">Cafero</div>
        </div>

        <div class="sidebar-overlay" onclick="toggleSidebar()"></div>
        <main class="main-content slide-up">

            <div class="top-navbar">
                <div class="search-wrapper">
                    <i class="fas fa-search"></i>
                    <input type="text" class="search-input" placeholder="Search transactions, products, or inventory..." />
                </div>
                <div class="top-nav-controls">
                    <div class="datetime-display">
                        <div id="currentDate"></div>
                        <div id="currentTime"></div>
                    </div>
                    <div class="notification-bell">
                        <i class="fas fa-bell"></i>
                        <span class="bell-badge"></span>
                    </div>
                    <div class="user-dropdown">
                        <span>Active Terminal: <strong>Station 1</strong></span>
                        <i class="fas fa-angle-down"></i>
                    </div>
                </div>
            </div>

            <div class="page-header dashboard-header-card">
                <div>
                    <p class="header-label">Today's Net Sales</p>
                    <h1 class="header-sales-value">₱@Model.TodayTotalSales.ToString("N2")</h1>
                </div>
                <div class="system-status-container">
                    <p class="status-label">System Status</p>
                    <div class="status-indicator-flex">
                        <span class="status-dot animate-pulse"></span>
                        <span class="status-text">Online & Syncing</span>
                    </div>
                </div>
            </div>

            <div class="summary-dashboard">
                <div class="summary-card">
                    <div class="card-icon-box icon-orange"><i class="fas fa-list"></i></div>
                    <div>
                        <div class="card-label">All Transactions</div>
                        <div class="card-value">@(Model.RecentSales?.Count ?? 0)</div>
                    </div>
                </div>

                <div class="summary-card">
                    <div class="card-icon-box icon-green"><i class="fas fa-hourglass-half"></i></div>
                    <div>
                        <div class="card-label">Pending Orders</div>
                        <div class="card-value">@(Model.RecentSales?.Count(s => s.Status == "Pending" || string.IsNullOrEmpty(s.Status)) ?? 0)</div>
                    </div>
                </div>

                <div class="summary-card">
                    <div class="card-icon-box icon-light-orange"><i class="fas fa-check-circle"></i></div>
                    <div>
                        <div class="card-label">Completed Sales</div>
                        <div class="card-value">@Model.TodayTransactionCount</div>
                    </div>
                </div>

                <div class="summary-card">
                    <div class="card-icon-box icon-red"><i class="fas fa-exclamation-triangle"></i></div>
                    <div>
                        <div class="card-label">Low Stock Alerts</div>
                        <div class="card-value">1</div>
                    </div>
                </div>
            </div>

            <div class="pos-grid-container">
                <div class="pos-card-wrapper">
                    <div class="pos-card-header">
                        <div>
                            <div class="pos-card-title"><i class="fas fa-chart-line"></i> Sales This Week</div>
                            <div class="weekly-sales-value">
                                ₱@((Model.TodayTotalSales * 5.8m).ToString("N2"))
                            </div>
                        </div>
                        <span class="rolling-label">Past 7 Days Rolling</span>
                    </div>
                    <div class="chart-container">
                        <canvas id="weeklySalesChart"></canvas>
                    </div>
                </div>

                <div class="pos-card-wrapper">
                    <div class="pos-card-header">
                        <div class="pos-card-title"><i class="fas fa-history"></i> Recent Transactions</div>
                        <a href="/Admin/DailyReport" class="view-all-link">View All &rarr;</a>
                    </div>
                    <div class="table-responsive">
                        <table class="pos-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Customer</th>
                                    <th>Total</th>
                                    <th>Method</th>
                                    <th>Status</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentSales != null && Model.RecentSales.Any())
                                {
                                    @foreach (var sale in Model.RecentSales.Take(5))
                                    {
                                        <tr>
                                            <td class="sale-id">#@sale.SaleId</td>
                                            <td>@(sale.CustomerName ?? "Walk-in")</td>
                                            <td>₱@sale.TotalAmount.ToString("N2")</td>
                                            <td>@(sale.PaymentMethod ?? "Cash")</td>
                                            <td>
                                                @if (sale.Status == "Completed")
                                                {
                                                    <span class="badge badge-success">Completed</span>
                                                }
                                                else if (sale.Status == "Cancelled" || sale.Status == "Voided")
                                                {
                                                    <span class="badge badge-danger">Cancelled</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-warning">Pending</span>
                                                }
                                            </td>
                                            <td class="text-muted">@sale.SaleDate.ToString("hh:mm tt")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td class="sale-id">#8036</td>
                                        <td>Walk-in</td>
                                        <td>₱79.00</td>
                                        <td>Cash</td>
                                        <td><span class="badge badge-warning">Pending</span></td>
                                        <td class="text-muted">07:34 PM</td>
                                    </tr>
                                    <tr>
                                        <td class="sale-id">#8035</td>
                                        <td>Walk-in</td>
                                        <td>₱158.00</td>
                                        <td>GCash</td>
                                        <td><span class="badge badge-success">Completed</span></td>
                                        <td class="text-muted">07:12 PM</td>
                                    </tr>
                                    <tr>
                                        <td class="sale-id">#7036</td>
                                        <td>Juan Dela Cruz</td>
                                        <td>₱89.00</td>
                                        <td>Card</td>
                                        <td><span class="badge badge-success">Completed</span></td>
                                        <td class="text-muted">03:46 PM</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="pos-grid-container">
                <div class="pos-card-wrapper">
                    <div class="pos-card-header">
                        <div class="pos-card-title"><i class="fas fa-crown"></i> Best Selling Products</div>
                        <span class="volume-label">By Volume</span>
                    </div>
                    <!-- Scrollable Wrapper Added Below -->
                    <div class="table-responsive">
                        <table class="pos-table">
                            <thead>
                                <tr>
                                    <th>Product Name</th>
                                    <th>Units Sold</th>
                                    <th class="text-right">Revenue Generated</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Spanish Latte (Iced)</td>
                                    <td>
                                        <div class="progress-info">
                                            <span>142 units</span>
                                        </div>
                                        <div class="progress-container"><div class="progress-bar" style="width: 92%;"></div></div>
                                    </td>
                                    <td class="text-right revenue-val">₱22,720.00</td>
                                </tr>
                                <tr>
                                    <td>Café Americana (Hot)</td>
                                    <td>
                                        <div class="progress-info">
                                            <span>98 units</span>
                                        </div>
                                        <div class="progress-container"><div class="progress-bar" style="width: 68%;"></div></div>
                                    </td>
                                    <td class="text-right revenue-val">₱10,780.00</td>
                                </tr>
                                <tr>
                                    <td>Cream Cheese Ensaymada</td>
                                    <td>
                                        <div class="progress-info">
                                            <span>75 units</span>
                                        </div>
                                        <div class="progress-container"><div class="progress-bar" style="width: 51%;"></div></div>
                                    </td>
                                    <td class="text-right revenue-val">₱6,375.00</td>
                                </tr>
                                <tr>
                                    <td>Caramel Macchiato</td>
                                    <td>
                                        <div class="progress-info">
                                            <span>64 units</span>
                                        </div>
                                        <div class="progress-container"><div class="progress-bar" style="width: 43%;"></div></div>
                                    </td>
                                    <td class="text-right revenue-val">₱10,880.00</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="pos-card-wrapper">
                    <div class="pos-card-header">
                        <div class="pos-card-title"><i class="fas fa-boxes"></i> Low Stock Details</div>
                        <a href="/Admin/Inventory" class="manage-link">Manage</a>
                    </div>
                    <!-- Scrollable Wrapper Added Below -->
                    <div class="table-responsive">
                        <table class="pos-table">
                            <thead>
                                <tr>
                                    <th>Item Stock</th>
                                    <th>Current Qty</th>
                                    <th>Status</th>
                                    <th class="text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Espresso Coffee Beans</td>
                                    <td>2.5 kg</td>
                                    <td><span class="badge badge-danger">Critical</span></td>
                                    <td class="text-right"><button class="btn-restock" onclick="location.href='/Admin/Inventory'">Restock</button></td>
                                </tr>
                                <tr>
                                    <td>Whole Milk (1L Cartons)</td>
                                    <td>12 units</td>
                                    <td><span class="badge badge-warning">Low</span></td>
                                    <td class="text-right"><button class="btn-restock" onclick="location.href='/Admin/Inventory'">Restock</button></td>
                                </tr>
                                <tr>
                                    <td>Caramel Syrup Base</td>
                                    <td>1.2 L</td>
                                    <td><span class="badge badge-warning">Low</span></td>
                                    <td class="text-right"><button class="btn-restock" onclick="location.href='/Admin/Inventory'">Restock</button></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="bottom-three-column-grid">
                <div class="pos-card-wrapper">
                    <div class="pos-card-header">
                        <div class="pos-card-title"><i class="fas fa-bolt"></i> Quick Manager Actions</div>
                    </div>
                    <div class="action-button-grid">
                        <button class="action-btn" onclick="location.href='/@homeController/Queue'"><i class="fas fa-shopping-cart"></i>New Order</button>
                        <button class="action-btn" onclick="location.href='/Admin/Products'"><i class="fas fa-plus-circle"></i>Add Product</button>
                        <button class="action-btn" onclick="location.href='/Admin/Inventory'"><i class="fas fa-dolly"></i>Add Inventory</button>
                        <button class="action-btn" onclick="location.href='/Admin/Analytics'"><i class="fas fa-file-invoice-dollar"></i>Sales Report</button>
                    </div>
                </div>

                <div class="pos-card-wrapper">
                    <div class="pos-card-header">
                        <div class="pos-card-title"><i class="fas fa-wallet"></i> Payment Breakdown</div>
                    </div>
                    <div class="payment-chart-canvas-wrapper">
                        <canvas id="paymentMethodsChart"></canvas>
                    </div>
                </div>

                <div class="pos-card-wrapper">
                    <div class="pos-card-header">
                        <div class="pos-card-title"><i class="fas fa-bell"></i> Live Notifications</div>
                    </div>
                    <div class="notification-list">
                        <div class="notification-item">
                            <div class="notification-info">
                                <p>New web pickup order received (#ORD-8036)</p>
                                <div class="notification-time">2 mins ago</div>
                            </div>
                        </div>
                        <div class="notification-item alert-node">
                            <div class="notification-info">
                                <p>Inventory Alert: Espresso Beans fall below safety margin</p>
                                <div class="notification-time">14 mins ago</div>
                            </div>
                        </div>
                        <div class="notification-item success-node">
                            <div class="notification-info">
                                <p>System database backup completed securely</p>
                                <div class="notification-time">1 hour ago</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <!-- ── SLIDE-OUT CHAT DRAWER FOR ADMIN ── -->
    <div class="admin-chat-drawer" id="adminChatDrawer">
        <div class="admin-chat-header">
            <div class="admin-chat-header-left">
                <span class="chat-status-dot"></span>
                <h3>Customer Live Chat</h3>
            </div>
            <button class="close-drawer-btn" onclick="toggleAdminChat()">✕</button>
        </div>

        <div class="admin-chat-contact-bar">
            <select id="adminChatContactSelect" onchange="switchAdminChatContact(this.value)">
                <option value="">Select a contact…</option>
            </select>
        </div>

        <div class="admin-chat-body" id="adminChatMessages">
            <div class="system-message">No active messages. Waiting for customers...</div>
        </div>

        <div class="admin-chat-footer">
            <input type="text" id="adminChatInput" placeholder="Type a reply to customer..." onkeypress="handleAdminChatKey(event)" />
            <button class="admin-chat-send-btn" onclick="sendAdminReply()">Send</button>
        </div>
    </div>

    <!-- Floating Gold Chat Trigger Button -->
    <button class="admin-chat-trigger" onclick="toggleAdminChat()" id="adminChatTrigger">
        <i class="fas fa-comments"></i>
        <span class="admin-chat-alert-badge" id="adminChatBadge" style="display: none;"></span>
    </button>

    <script>
        function confirmLogout() {
        Swal.fire({
        title: 'Are you sure?',
        text: "You will be logged out of your session.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Yes, log out',
        cancelButtonText: 'Cancel'
        }).then((result) => {
        if (result.isConfirmed) {
        document.getElementById('logoutForm').submit();
        }
        });
        }

        // Global variables/functions for Chat Drawer functionality
        let chatConn;
        let adminChatWith = null; // username of the contact currently open in the drawer

        // Must match the users.username value (the "Username" claim set at
        // login), not the display/full name used elsewhere on this page.
        const adminChatCurrentUser = "@(User.FindFirst("Username")?.Value ?? "")";

        function toggleAdminChat() {
        const drawer = document.getElementById("adminChatDrawer");
        drawer.classList.toggle("open");

        if (drawer.classList.contains("open")) {
        // Hide notification badge when drawer is opened
        document.getElementById("adminChatBadge").style.display = "none";
        loadAdminChatContacts();
        }
        }

        function handleAdminChatKey(event) {
        if (event.key === 'Enter') {
        sendAdminReply();
        }
        }

        function sendAdminReply() {
        const input = document.getElementById("adminChatInput");
        const msg = input.value.trim();
        if (!msg || !adminChatWith) return;

        // The server derives the sender from the authenticated connection.
        chatConn.invoke("SendMessage", adminChatWith, msg)
        .catch(err => console.error("Error sending admin message:", err));

        input.value = "";
        }

        async function loadAdminChatContacts() {
        const select = document.getElementById("adminChatContactSelect");
        if (select.dataset.loaded === "true") return;

        try {
        const res = await fetch('/Chat/GetContacts');
        if (!res.ok) return;
        const contacts = await res.json();

        contacts.forEach(c => {
        const opt = document.createElement("option");
        opt.value = c.username;
        opt.textContent = `${c.username} (${c.role})`;
        select.appendChild(opt);
        });

        select.dataset.loaded = "true";

        if (contacts.length > 0 && !adminChatWith) {
        select.value = contacts[0].username;
        switchAdminChatContact(contacts[0].username);
        }
        } catch (err) {
        console.error("Failed to load chat contacts:", err);
        }
        }

        async function switchAdminChatContact(username) {
        adminChatWith = username || null;
        const area = document.getElementById("adminChatMessages");
        area.innerHTML = '<div class="system-message">No active messages. Waiting for customers...</div>';

        if (!adminChatWith) return;

        try {
        const res = await fetch(`/Chat/GetChatHistory?chatWith=${encodeURIComponent(adminChatWith)}`);
        if (!res.ok) return;
        const history = await res.json();

        if (history.length > 0) {
        const placeholder = area.querySelector('.system-message');
        if (placeholder) placeholder.remove();
        }

        history.forEach(m => renderAdminChatMessage(m.sender, m.text, m.time));
        } catch (err) {
        console.error("Failed to load chat history:", err);
        }
        }

        function renderAdminChatMessage(sender, message, timeString) {
        const area = document.getElementById("adminChatMessages");
        const row = document.createElement("div");

        if (sender === adminChatCurrentUser) {
        row.className = "admin-msg-row staff";
        row.innerHTML = `
        <div class="admin-bubble">${escapeHTML(message)}</div>
        <span class="admin-meta">You · ${escapeHTML(timeString)}</span>
        `;
        } else {
        row.className = "admin-msg-row customer";
        row.innerHTML = `
        <div class="admin-bubble">${escapeHTML(message)}</div>
        <span class="admin-meta">${escapeHTML(sender)} · ${escapeHTML(timeString)}</span>
        `;
        }

        area.appendChild(row);
        area.scrollTop = area.scrollHeight;
        }

        function escapeHTML(str) {
        return str.replace(/[&<>'"]/g,
        tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
        );
        }

        document.addEventListener("DOMContentLoaded", function() {
        // Clock Logic
        function updateClock() {
        const now = new Date();
        const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
        document.getElementById('currentDate').innerText = now.toLocaleDateString('en-US', options);

        let hours = now.getHours();
        let minutes = now.getMinutes();
        const ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        document.getElementById('currentTime').innerText = hours + ':' + minutes + ' ' + ampm;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // Weekly Sales Chart Logic
        const rawTodaySales = parseFloat("@Model.TodayTotalSales") || 8500;
        const ctxWeekly = document.getElementById('weeklySalesChart').getContext('2d');
        new Chart(ctxWeekly, {
        type: 'line',
        data: {
        labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
        datasets: [{
        label: 'Sales (₱)',
        data: [
        rawTodaySales * 0.85,
        rawTodaySales * 0.95,
        rawTodaySales * 1.1,
        rawTodaySales,
        rawTodaySales * 1.25,
        rawTodaySales * 1.4,
        rawTodaySales * 1.3
        ],
        borderColor: '#D4AF37',
        backgroundColor: 'rgba(212, 175, 55, 0.05)',
        borderWidth: 3,
        fill: true,
        tension: 0.35
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } }
        }
        });

        // Payment Methods Chart Logic
        const ctxPayment = document.getElementById('paymentMethodsChart').getContext('2d');
        new Chart(ctxPayment, {
        type: 'doughnut',
        data: {
        labels: ['Cash', 'GCash', 'Card'],
        datasets: [{
        data: [55, 30, 15],
        backgroundColor: ['#D4AF37', '#2ECC71', '#F39C12'],
        borderWidth: 0
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'right' } },
        cutout: '72%'
        }
        });

        // ── Real-Time SignalR Connection Setup ──
        chatConn = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .build();

        chatConn.start()
        .then(() => console.log("Dashboard SignalR Chat Connected!"))
        .catch(err => console.error("SignalR Startup Error:", err));

        chatConn.on("ReceiveMessage", function (sender, receiver, message, time) {
        // The hub only delivers messages involving this account (see ChatHub
        // group routing), so just check whether it belongs to the open thread.
        const belongsToOpenThread = adminChatWith &&
        (sender === adminChatWith || receiver === adminChatWith);

        if (belongsToOpenThread) {
        const placeholder = document.getElementById("adminChatMessages").querySelector('.system-message');
        if (placeholder) placeholder.remove();

        renderAdminChatMessage(sender, message, time);
        }

        if (sender !== adminChatCurrentUser && !belongsToOpenThread) {
        // A message came in from a contact that isn't the open thread.
        const drawer = document.getElementById("adminChatDrawer");
        if (!drawer.classList.contains("open")) {
        document.getElementById("adminChatBadge").style.display = "block";
        }
        }
        });
        });

        function toggleSidebar() {
        const sidebar = document.querySelector('.sidebar');
        const overlay = document.querySelector('.sidebar-overlay');

        sidebar.classList.toggle('mobile-open');
        overlay.classList.toggle('mobile-open');
        }
    </script>
</body>
</html>