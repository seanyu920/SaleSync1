@model SaleSync.Models.CashierDashboardViewModel
@{
    Layout = null;
    string homeController = "Admin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Dashboard - Cafero</title>
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

    <div id="voidModal" class="modal-overlay">
        <div class="auth-modal">
            <h3 style="color: #4a2511;">Authorize Void</h3>
            <p style="font-size: 12px; color: #8c5b3e; margin-top: 5px;">Enter your Admin password to void <br><strong>Order #ORD-<span id="displayId"></span></strong></p>
            <input type="password" id="adminPass" placeholder="Admin Password" />
            <button class="auth-btn" onclick="confirmAdminVoid()">Verify & Void</button>
            <p onclick="closeModal()" style="margin-top:15px; cursor:pointer; font-size:12px; color:#999;">Cancel</p>
        </div>
    </div>

    <div class="dashboard-container">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div>
                <div class="logo-section" style="margin-bottom: 30px;">
                    <div class="logo-title">Cafero</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section" style="display: flex; align-items: center; gap: 15px; margin-bottom: 40px; padding: 0 10px;">
                    <div class="profile-circle" style="width: 45px; height: 45px; flex-shrink: 0; background: #f46a05; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #fff;">👤</div>
                    <div>
                        <h2 class="admin-name" style="font-size: 16px; font-weight: 700; color: #ffffff; margin: 0;">Admin</h2>
                        <div style="font-size: 12px; color: #dcbca5;">Administrator</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="/@homeController/Dashboard" class="menu-btn active">❖ Dashboard</a>
                    <a href="/@homeController/PointOfSale" class="menu-btn">🛒 POS</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ActivityLog" class="menu-btn">📋 Activity Log</a>
                    }
                    
                    <a href="/Admin/Analytics" class="menu-btn">📊 Analytics</a>
                    <a href="/Admin/Products" class="menu-btn">🏷️ Products</a>
                    <a href="/Admin/Inventory" class="menu-btn">📦 Inventory</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ManageAccounts" class="menu-btn">💳 Accounts</a>
                    }
                </nav>
            </div>
            
            <div class="logout-section" style="margin-top: auto;">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn" style="background: transparent; border: none; width: 100%; text-align: left; cursor: pointer; color: #dcbca5; padding: 14px 20px;">
                        ⎋ Log Out
                    </button>
                </form>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="main-content">
            
            <!-- ⭐ THE NEW ENTERPRISE HEADER ⭐ -->
            <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; background: #fff; padding: 25px 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); margin-bottom: 25px; border: 1px solid #eaddd3;">
                <div>
                    <p style="margin: 0; font-size: 13px; color: #8c5b3e; text-transform: uppercase; letter-spacing: 1px; font-weight: 700;">Today's Net Sales</p>
                    <h1 style="margin: 5px 0 0 0; font-size: 42px; color: #4a2511; font-weight: 800;">₱@Model.TodayTotalSales.ToString("N2")</h1>
                </div>
                <div style="text-align: right;">
                    <p style="margin: 0; font-size: 13px; color: #8c5b3e; font-weight: 600;">System Status</p>
                    <div style="display: flex; align-items: center; justify-content: flex-end; gap: 8px; margin-top: 8px;">
                        <span style="display: inline-block; width: 10px; height: 10px; background: #0b8a53; border-radius: 50%; box-shadow: 0 0 8px rgba(11, 138, 83, 0.6);"></span>
                        <span style="font-size: 14px; font-weight: 700; color: #0b8a53;">Online & Syncing</span>
                    </div>
                </div>
            </div>

            <!-- ⭐ 4 PERFECTLY ALIGNED STAT CARDS -->
            <div class="summary-dashboard">
                <!-- Card 1: All Transactions -->
                <div class="summary-card stat-clickable" onclick="switchView('sales')">
                    <div class="card-icon-box icon-orange" style="background: #8c5b3e;">📋</div>
                    <div class="card-label">All Transactions</div>
                    <div class="card-value">@(Model.RecentSales?.Count ?? 0)</div>
                </div>
                
                <!-- Card 2: Pending Orders -->
                <div class="summary-card stat-clickable" onclick="switchView('pending')">
                    <div class="card-icon-box icon-green">⏳</div>
                    <div class="card-label">Pending Orders</div>
                    <div class="card-value">@(Model.RecentSales?.Count(s => s.Status == "Pending" || string.IsNullOrEmpty(s.Status)) ?? 0)</div>
                </div>
                
                <!-- Card 3: Completed Transactions -->
                <div class="summary-card stat-clickable" onclick="switchView('completed')">
                    <div class="card-icon-box icon-light-orange">📁</div>
                    <div class="card-label">Completed Sales</div>
                    <div class="card-value">@Model.TodayTransactionCount</div>
                </div>
                
                <!-- Card 4: Low Stock -->
                <div class="summary-card stat-clickable" onclick="switchView('lowstock')">
                    <div class="card-icon-box icon-red">⚠️</div>
                    <div class="card-label">Low Stock Alerts</div>
                    <div class="card-value">7</div>
                </div>
            </div>

            <!-- ⭐ VIEW 1: ALL TRANSACTIONS -->
            <div class="recent-sales-card" id="salesViewContainer">
                <div class="card-header-flex">
                    <div>
                        <h2 class="widget-title">All Transactions</h2>
                        <p class="widget-subtitle">Every transaction processed today</p>
                    </div>
                    <a href="/Admin/DailyReport" class="view-all-link">View Full Report &rarr;</a>
                </div>
                <div class="table-responsive">
                    <table class="recent-sales-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Time</th>
                                <th>Cashier</th>
                                <th>Items</th>
                                <th>Mode of Payment</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentSales != null && Model.RecentSales.Any())
                            {
                                @foreach (var sale in Model.RecentSales)
                                {
                                    <tr>
                                        <td class="td-bold">#ORD-@sale.SaleId</td>
                                        <td>@sale.SaleDate.ToString("hh:mm tt")</td>
                                        <td><span class="badge-cashier" style="background: #fdf0dc; color: #a16c1b; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">@sale.CashierName</span></td>
                                        <td>@sale.ItemsSummary</td>
                                        <td><span style="font-weight: 600; color: #8c5b3e;">Cash</span></td>
                                        <td class="td-price">₱@sale.TotalAmount.ToString("N2")</td>
                                        <td>
                                            @if (sale.Status == "Completed")
                                            {
                                                <span class="badge-completed" style="background: #d1fae5; color: #065f46; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">Completed</span>
                                            }
                                            else if (sale.Status == "Voided")
                                            {

                                                <span class="status-voided" style="background: #fee2e2; color: #b91c1c; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">Voided</span>
                                            }
                                            else
                                            {

                                                <span class="badge-pending" style="background: #fef3c7; color: #92400e; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">Pending</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ⭐ VIEW 2: PENDING ORDERS -->
            <div class="recent-sales-card hidden-view" id="pendingViewContainer">
                <div class="card-header-flex">
                    <div>
                        <h2 class="widget-title">Pending Orders</h2>
                        <p class="widget-subtitle">Transactions waiting to be processed</p>
                    </div>
                    <a href="/Admin/DailyReport" class="view-all-link">View Full Report &rarr;</a>
                </div>
                <div class="table-responsive">
                    <table class="recent-sales-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Time</th>
                                <th>Cashier</th>
                                <th>Items</th>
                                <th>Mode of Payment</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                                <th style="text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                bool hasPending = false;
                            }
                            @if (Model.RecentSales != null && Model.RecentSales.Any())
                            {
                                @foreach (var sale in Model.RecentSales)
                                {
                                    @if (sale.Status == "Pending" || string.IsNullOrEmpty(sale.Status))
                                    {
                                        hasPending = true;
                                        <tr>
                                            <td class="td-bold">#ORD-@sale.SaleId</td>
                                            <td>@sale.SaleDate.ToString("hh:mm tt")</td>
                                            <td><span class="badge-cashier" style="background: #fdf0dc; color: #a16c1b; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">@sale.CashierName</span></td>
                                            <td>@sale.ItemsSummary</td>
                                            <td><span style="font-weight: 600; color: #8c5b3e;">Cash</span></td>
                                            <td class="td-price">₱@sale.TotalAmount.ToString("N2")</td>
                                            <td><span class="badge-pending" style="background: #fef3c7; color: #92400e; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">Pending</span></td>
                                            <td style="text-align: center;">
                                                <div class="action-btn-group">
                                                    <button class="btn-mini btn-confirm-mini" onclick="updateStatus(@sale.SaleId, 'Completed')">✓</button>
                                                    <button class="btn-mini btn-void-mini" onclick="openVoidModal(@sale.SaleId)">✕</button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                            @if (!hasPending)
                            {
                                <tr>
                                    <td colspan="8" style="text-align: center; padding: 25px; color: #8c5b3e;">No pending orders. You're all caught up!</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ⭐ VIEW 3: COMPLETED TRANSACTIONS -->
            <div class="recent-sales-card hidden-view" id="completedViewContainer">
                <div class="card-header-flex">
                    <div>
                        <h2 class="widget-title">Completed Transactions</h2>
                        <p class="widget-subtitle" style="color: #0b8a53; font-weight: 700; font-size: 15px; margin-top: 5px;">
                            Total Sales: ₱@Model.TodayTotalSales.ToString("N2")
                        </p>
                    </div>
                    <a href="/Admin/DailyReport" class="view-all-link">View Full Report &rarr;</a>
                </div>
                <div class="table-responsive">
                    <table class="recent-sales-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Time</th>
                                <th>Cashier</th>
                                <th>Items</th>
                                <th>Mode of Payment</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                bool hasCompleted = false;
                            }
                            @if (Model.RecentSales != null)
                            {
                                @foreach (var sale in Model.RecentSales)
                                {
                                    @if (sale.Status == "Completed")
                                    {
                                        hasCompleted = true;
                                        <tr>
                                            <td class="td-bold">#ORD-@sale.SaleId</td>
                                            <td>@sale.SaleDate.ToString("hh:mm tt")</td>
                                            <td><span class="badge-cashier" style="background: #fdf0dc; color: #a16c1b; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">@sale.CashierName</span></td>
                                            <td>@sale.ItemsSummary</td>
                                            <td><span style="font-weight: 600; color: #8c5b3e;">Cash</span></td>
                                            <td class="td-price">₱@sale.TotalAmount.ToString("N2")</td>
                                            <td><span class="badge-completed" style="background: #d1fae5; color: #065f46; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">Completed</span></td>
                                        </tr>
                                    }
                                }
                            }
                            @if (!hasCompleted)
                            {
                                <tr>
                                    <td colspan="7" style="text-align: center; padding: 25px; color: #8c5b3e;">No completed transactions yet today.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ⭐ VIEW 4: LOW STOCK ALERTS -->
            <div class="recent-sales-card hidden-view" id="lowStockViewContainer">
                <div class="card-header-flex">
                    <div>
                        <h2 class="widget-title" style="color: #e02424;">⚠️ Low Stock Items</h2>
                        <p class="widget-subtitle">Items needing immediate restock</p>
                    </div>
                    <a href="/Admin/Inventory" class="view-all-link">Manage Inventory &rarr;</a>
                </div>
                <div class="table-responsive">
                    <table class="recent-sales-table">
                        <thead>
                            <tr>
                                <th>Item ID</th>
                                <th>Category</th>
                                <th>Item Name</th>
                                <th>Current Qty</th>
                                <th>Supplier</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="td-bold">ITM-001</td>
                                <td>COFFEE</td>
                                <td>Espresso Beans</td>
                                <td><strong style="color: #e02424;">2.5 kg</strong></td>
                                <td>Local Roasters Inc.</td>
                                <td><span class="status-voided" style="background: #fee2e2; color: #b91c1c; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">Low Stock</span></td>
                            </tr>
                            <tr>
                                <td class="td-bold">ITM-045</td>
                                <td>PACKAGING</td>
                                <td>Small Cups</td>
                                <td><strong style="color: #e02424;">15 pcs</strong></td>
                                <td>PackAll Co.</td>
                                <td><span class="status-voided" style="background: #fee2e2; color: #b91c1c; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">Low Stock</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <!-- JAVASCRIPT LOGIC -->
    <script>
        let selectedSaleId = null;

        function switchView(viewName) {
        const salesView = document.getElementById('salesViewContainer');
        const pendingView = document.getElementById('pendingViewContainer');
        const completedView = document.getElementById('completedViewContainer');
        const lowStockView = document.getElementById('lowStockViewContainer');
            
        salesView.classList.add('hidden-view');
        pendingView.classList.add('hidden-view');
        completedView.classList.add('hidden-view');
        lowStockView.classList.add('hidden-view');
            
        if (viewName === 'sales') salesView.classList.remove('hidden-view');
        else if (viewName === 'pending') pendingView.classList.remove('hidden-view');
        else if (viewName === 'completed') completedView.classList.remove('hidden-view');
        else if (viewName === 'lowstock') lowStockView.classList.remove('hidden-view');
        }

        function updateStatus(saleId, status) {
        Swal.fire({
        title: 'Complete Order?',
        text: `Mark Order #ORD-${saleId} as ${status}?`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#f46a05',
        cancelButtonColor: '#4a2511',
        confirmButtonText: 'Yes, complete it'
        }).then((result) => {
        if (result.isConfirmed) {
        fetch('/Admin/UpdateSaleStatus', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ saleId: saleId, status: status })
        }).then(res => {
        if(res.ok) location.reload();
        else Swal.fire('Error', 'Update failed.', 'error');
        });
        }
        });
        }

        function openVoidModal(saleId) {
        selectedSaleId = saleId;
        document.getElementById('displayId').innerText = saleId;
        document.getElementById('voidModal').style.display = 'flex';
        }

        function closeModal() { document.getElementById('voidModal').style.display = 'none'; }

        function confirmAdminVoid() {
        const passValue = document.getElementById('adminPass').value;
        if(!passValue) {
        Swal.fire('Required', 'Please enter your password', 'warning');
        return;
        }

        fetch('/Admin/VerifyAndVoid', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ saleId: selectedSaleId, pass: passValue })
        }).then(async res => {
        if(res.ok) {
        Swal.fire({
        title: 'Voided!',
        text: 'The order has been voided.',
        icon: 'success',
        confirmButtonColor: '#f46a05'
        }).then(() => location.reload());
        } else {
        const err = await res.json();
        Swal.fire('Denied', err.message || "Unauthorized", 'error');
        }
        });
        }
    </script>
</body>
</html>