@model SaleSync.Models.CashierDashboardViewModel
@{
    Layout = null;
    string homeController = "Admin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Dashboard - Cafero</title>
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

    <div id="voidModal" class="modal-overlay">
        <div class="auth-modal">
            <h3 class="modal-title">Authorize Void</h3>
            <p class="modal-desc">Enter your Admin password to void <br><strong>Order #ORD-<span id="displayId"></span></strong></p>
            <input type="password" id="adminPass" placeholder="Admin Password" />
            <button class="auth-btn" onclick="confirmAdminVoid()">Verify & Void</button>
            <p onclick="closeModal()" class="modal-cancel">Cancel</p>
        </div>
    </div>

    <div class="dashboard-container">
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">Cafero</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <h2 class="admin-name">Admin</h2>
                        <div class="admin-role">Administrator</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="/@homeController/Dashboard" class="menu-btn active"><i class="fas fa-chart-line"></i> Dashboard</a>
                    <a href="/@homeController/PointOfSale" class="menu-btn"><i class="fas fa-shopping-cart"></i> POS</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ActivityLog" class="menu-btn"><i class="fas fa-clipboard-list"></i> Activity Log</a>
                    }

                    <a href="/Admin/Analytics" class="menu-btn"><i class="fas fa-chart-pie"></i> Analytics</a>
                    <a href="/Admin/QueueOrder" class="menu-btn"><i class="fas fa-list-ol"></i> Queue</a>
                    <a href="/Admin/Products" class="menu-btn"><i class="fas fa-tags"></i> Products</a>
                    <a href="/Admin/Inventory" class="menu-btn"><i class="fas fa-box-open"></i> Inventory</a>

                    <a href="/Admin/ArchivedProducts" class="menu-btn"><i class="fas fa-archive"></i> Archived</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ManageAccounts" class="menu-btn"><i class="fas fa-credit-card"></i> Accounts</a>
                    }
                    <a href="/Admin/WebCustomization" class="menu-btn"><i class="fas fa-tags"></i> Customization</a>
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn">
                        <i class="fas fa-sign-out-alt"></i> Log Out
                    </button>
                </form>
            </div>
        </aside>

        <main class="main-content">

            <div class="page-header dashboard-header-card">
                <div>
                    <p class="header-label">Today's Net Sales</p>
                    <h1 class="header-sales-value">₱@Model.TodayTotalSales.ToString("N2")</h1>
                </div>
                <div class="system-status-container">
                    <p class="status-label">System Status</p>
                    <div class="status-indicator-flex">
                        <span class="status-dot animate-pulse"></span>
                        <span class="status-text">Online & Syncing</span>
                    </div>
                </div>
            </div>

            <div class="summary-dashboard">
                <div class="summary-card stat-clickable" onclick="switchView('sales')">
                    <div class="card-icon-box icon-orange"><i class="fas fa-list"></i></div>
                    <div class="card-label">All Transactions</div>
                    <div class="card-value">@(Model.RecentSales?.Count ?? 0)</div>
                </div>

                <div class="summary-card stat-clickable" onclick="switchView('pending')">
                    <div class="card-icon-box icon-green"><i class="fas fa-hourglass-half"></i></div>
                    <div class="card-label">Pending Orders</div>
                    <div class="card-value">@(Model.RecentSales?.Count(s => s.Status == "Pending" || string.IsNullOrEmpty(s.Status)) ?? 0)</div>
                </div>

                <div class="summary-card stat-clickable" onclick="switchView('completed')">
                    <div class="card-icon-box icon-light-orange"><i class="fas fa-check-circle"></i></div>
                    <div class="card-label">Completed Sales</div>
                    <div class="card-value">@Model.TodayTransactionCount</div>
                </div>

                <div class="summary-card stat-clickable" onclick="switchView('lowstock')">
                    <div class="card-icon-box icon-red"><i class="fas fa-exclamation-triangle"></i></div>
                    <div class="card-label">Low Stock Alerts</div>
                    <div class="card-value">1</div>
                </div>
            </div>

            <div class="recent-sales-card" id="salesViewContainer">
                <div class="card-header-flex">
                    <div>
                        <h2 class="widget-title">All Transactions</h2>
                        <p class="widget-subtitle">Every transaction processed today</p>
                    </div>
                    <a href="/Admin/DailyReport" class="view-all-link">View Full Report &rarr;</a>
                </div>
                <div class="table-responsive">
                    <table class="recent-sales-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Time</th>
                                <th>Customer Info</th>
                                <th>Items</th>
                                <th>Payment</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentSales != null && Model.RecentSales.Any())
                            {
                                @foreach (var sale in Model.RecentSales)
                                {
                                    <tr>
                                        <td class="order-id">#ORD-@sale.SaleId</td>
                                        <td>@sale.SaleDate.ToString("hh:mm tt")</td>
                                        <td>
                                            <div class="customer-name">@(sale.CustomerName ?? "Walk-in")</div>
                                            <div class="badge-wrapper">
                                                <span class="order-type-badge">
                                                    @(sale.OrderType ?? "Dine In")
                                                </span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(sale.DeliveryAddress))
                                            {
                                                <div class="delivery-address">
                                                    📍 @sale.DeliveryAddress
                                                </div>
                                            }
                                        </td>
                                        <td>@sale.ItemsSummary</td>
                                        <td><span class="payment-method-text">@(sale.PaymentMethod ?? "Cash")</span></td>
                                        <td class="td-price">₱@sale.TotalAmount.ToString("N2")</td>
                                        <td>
                                            @if (sale.Status == "Completed")
                                            {
                                                <span class="status-badge status-completed">Completed</span>
                                            }
                                            else if (sale.Status == "Voided")
                                            {
                                                <span class="status-badge status-voided">Voided</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge status-pending">Pending</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="recent-sales-card hidden-view" id="pendingViewContainer">
                <div class="card-header-flex">
                    <div>
                        <h2 class="widget-title">Pending Orders</h2>
                        <p class="widget-subtitle">Transactions waiting to be processed</p>
                    </div>
                    <a href="/Admin/DailyReport" class="view-all-link">View Full Report &rarr;</a>
                </div>
                <div class="table-responsive">
                    <table class="recent-sales-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Time</th>
                                <th>Customer Info</th>
                                <th>Items</th>
                                <th>Payment</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                bool hasPending = false;
                            }
                            @if (Model.RecentSales != null && Model.RecentSales.Any())
                            {
                                @foreach (var sale in Model.RecentSales)
                                {
                                    @if (sale.Status == "Pending" || string.IsNullOrEmpty(sale.Status))
                                    {
                                        hasPending = true;
                                        <tr>
                                            <td class="order-id">#ORD-@sale.SaleId</td>
                                            <td>@sale.SaleDate.ToString("hh:mm tt")</td>
                                            <td>
                                                <div class="customer-name">@(sale.CustomerName ?? "Walk-in")</div>
                                                <div class="badge-wrapper">
                                                    <span class="order-type-badge">
                                                        @(sale.OrderType ?? "Dine In")
                                                    </span>
                                                </div>
                                                @if (!string.IsNullOrEmpty(sale.DeliveryAddress))
                                                {
                                                    <div class="delivery-address">
                                                        📍 @sale.DeliveryAddress
                                                    </div>
                                                }
                                            </td>
                                            <td>@sale.ItemsSummary</td>
                                            <td><span class="payment-method-text">@(sale.PaymentMethod ?? "Cash")</span></td>
                                            <td class="td-price">₱@sale.TotalAmount.ToString("N2")</td>
                                            <td><span class="status-badge status-pending">Pending</span></td>
                                            <td class="text-center">
                                                <div class="action-btn-group">
                                                    <button class="btn-mini btn-confirm-mini" onclick="updateStatus(@sale.SaleId, 'Completed')">✓</button>
                                                    <button class="btn-mini btn-void-mini" onclick="openVoidModal(@sale.SaleId)">✕</button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                            @if (!hasPending)
                            {
                                <tr>
                                    <td colspan="8" class="table-empty-state">No pending orders. You're all caught up!</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="recent-sales-card hidden-view" id="completedViewContainer">
                <div class="card-header-flex">
                    <div>
                        <h2 class="widget-title">Completed Transactions</h2>
                        <p class="widget-subtitle subtitle-highlight">
                            Total Sales: ₱@Model.TodayTotalSales.ToString("N2")
                        </p>
                    </div>
                    <a href="/Admin/DailyReport" class="view-all-link">View Full Report &rarr;</a>
                </div>
                <div class="table-responsive">
                    <table class="recent-sales-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Time</th>
                                <th>Customer Info</th>
                                <th>Items</th>
                                <th>Payment</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                bool hasCompleted = false;
                            }
                            @if (Model.RecentSales != null)
                            {
                                @foreach (var sale in Model.RecentSales)
                                {
                                    @if (sale.Status == "Completed")
                                    {
                                        hasCompleted = true;
                                        <tr>
                                            <td class="order-id">#ORD-@sale.SaleId</td>
                                            <td>@sale.SaleDate.ToString("hh:mm tt")</td>
                                            <td>
                                                <div class="customer-name">@(sale.CustomerName ?? "Walk-in")</div>
                                                <div class="badge-wrapper">
                                                    <span class="order-type-badge">
                                                        @(sale.OrderType ?? "Dine In")
                                                    </span>
                                                </div>
                                                @if (!string.IsNullOrEmpty(sale.DeliveryAddress))
                                                {
                                                    <div class="delivery-address">
                                                        📍 @sale.DeliveryAddress
                                                    </div>
                                                }
                                            </td>
                                            <td>@sale.ItemsSummary</td>
                                            <td><span class="payment-method-text">@(sale.PaymentMethod ?? "Cash")</span></td>
                                            <td class="td-price">₱@sale.TotalAmount.ToString("N2")</td>
                                            <td><span class="status-badge status-completed">Completed</span></td>
                                        </tr>
                                    }
                                }
                            }
                            @if (!hasCompleted)
                            {
                                <tr>
                                    <td colspan="7" class="table-empty-state">No completed transactions yet today.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="recent-sales-card hidden-view" id="lowStockViewContainer">
                <div class="card-header-flex">
                    <div>
                        <h2 class="widget-title title-danger">⚠️ Low Stock Items</h2>
                        <p class="widget-subtitle">Items needing immediate restock</p>
                    </div>
                    <a href="/Admin/Inventory" class="view-all-link">Manage Inventory &rarr;</a>
                </div>
                <div class="table-responsive">
                    <table class="recent-sales-table">
                        <thead>
                            <tr>
                                <th>Item ID</th>
                                <th>Category</th>
                                <th>Item Name</th>
                                <th>Current Qty</th>
                                <th>Supplier</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="order-id">ITM-001</td>
                                <td>COFFEE</td>
                                <td>Espresso Beans</td>
                                <td><strong class="text-danger">2.5 kg</strong></td>
                                <td>Local Roasters Inc.</td>
                                <td><span class="status-badge status-voided">Low Stock</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <script>
        let selectedSaleId = null;

        function switchView(viewName) {
        const views = ['salesViewContainer', 'pendingViewContainer', 'completedViewContainer', 'lowStockViewContainer'];
        views.forEach(id => document.getElementById(id).classList.add('hidden-view'));

        if (viewName === 'sales') document.getElementById('salesViewContainer').classList.remove('hidden-view');
        else if (viewName === 'pending') document.getElementById('pendingViewContainer').classList.remove('hidden-view');
        else if (viewName === 'completed') document.getElementById('completedViewContainer').classList.remove('hidden-view');
        else if (viewName === 'lowstock') document.getElementById('lowStockViewContainer').classList.remove('hidden-view');
        }

        function updateStatus(saleId, status) {
        Swal.fire({
        title: 'Complete Order?',
        text: `Mark Order #ORD-${saleId} as ${status}?`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#f46a05',
        cancelButtonColor: '#4a2511',
        confirmButtonText: 'Yes, complete it'
        }).then((result) => {
        if (result.isConfirmed) {
        fetch('/Admin/UpdateSaleStatus', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ saleId: saleId, status: status })
        }).then(res => {
        if(res.ok) location.reload();
        else Swal.fire('Error', 'Update failed.', 'error');
        });
        }
        });
        }

        function openVoidModal(saleId) {
        selectedSaleId = saleId;
        document.getElementById('displayId').innerText = saleId;
        document.getElementById('voidModal').style.display = 'flex';
        }

        function closeModal() {
        document.getElementById('voidModal').style.display = 'none';
        }

        function confirmAdminVoid() {
        const passValue = document.getElementById('adminPass').value;
        if(!passValue) {
        Swal.fire('Required', 'Please enter your password', 'warning');
        return;
        }

        fetch('/Admin/VerifyAndVoid', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ saleId: selectedSaleId, pass: passValue })
        }).then(async res => {
        if(res.ok) {
        Swal.fire({
        title: 'Voided!',
        text: 'The order has been voided.',
        icon: 'success',
        confirmButtonColor: '#f46a05'
        }).then(() => location.reload());
        } else {
        const err = await res.json();
        Swal.fire('Denied', err.message || "Unauthorized", 'error');
        }
        });
        }
    </script>
</body>
</html>