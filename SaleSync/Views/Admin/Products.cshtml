@model List<SaleSync.Models.MenuItemModel>
@{
    Layout = null;
    
    // Dynamically check if this is an Admin or Manager based on the current URL route
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Admin";
    var currentRole = currentController == "Manager" ? "Manager" : "Admin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Menu Management - SyncScale</title>
    
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Products.css" asp-append-version="true" />
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div class="dashboard-container">
        
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">SyncScale</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>
                
                <div class="profile-section" style="display: flex; align-items: center; gap: 15px; margin-bottom: 40px; padding: 0 10px;">
                    <div class="profile-circle" style="width: 45px; height: 45px; background: #f46a05; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #fff;">👤</div>
                    <div>
                        <h2 class="admin-name" style="font-size: 16px; font-weight: 700; color: #ffffff; margin: 0;">@currentRole</h2>
                        <div style="font-size: 12px; color: #dcbca5;">Administrator</div>
                    </div>
                </div>
                
                <nav class="sidebar-menu">
                    <a asp-controller="@currentController" asp-action="Dashboard" class="menu-btn">❖ Dashboard</a>
                    @if (currentController == "Admin")
                    {
                        <a asp-controller="Admin" asp-action="ActivityLog" class="menu-btn">📋 Activity Log</a>
                    }
                    <a asp-controller="@currentController" asp-action="Analytics" class="menu-btn">📊 Analytics</a>
                    <a asp-controller="@currentController" asp-action="Products" class="menu-btn active">🏷️ Products</a>
                    <a asp-controller="@currentController" asp-action="Inventory" class="menu-btn">📦 Inventory</a>

                    @if (currentController == "Admin")
                    {
                        <a asp-controller="Admin" asp-action="ManageAccounts" class="menu-btn">💳 Accounts</a>
                    }
                </nav>
            </div>

            <div class="logout-section" style="margin-top: auto;">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn" style="background: transparent; border: none; width: 100%; text-align: left; cursor: pointer; color: #dcbca5; padding: 14px 20px; font-size: 15px; font-weight: 600;">
                        ⎋ Log Out
                    </button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px;">
                <div>
                    <h1 class="greeting-title" id="pageTitle">Menu Categories 🏷️</h1>
                    <p class="greeting-subtitle" id="pageSubtitle">Manage high-level categories or drill down into items.</p>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button id="backBtn" class="btn-secondary" style="display: none;" onclick="showCategories()">← Back to Categories</button>
                    
                    <button id="mainAddBtn" class="btn-primary" style="background: #f46a05; color: white; padding: 10px 20px; border: none; border-radius: 8px; font-weight: bold; cursor: pointer;">+ Add Category</button>
                </div>
            </div>

            <div id="categoryContainer" class="product-catalog-grid">
                
                <div class="menu-item-card" onclick="openSubMenu('COFFEE')">
                    <div class="item-image-placeholder">
                        ☕
                        <button type="button" class="change-photo-btn" onclick="event.stopPropagation(); openCategoryPhotoUpload('COFFEE');">📷 Add Photo</button>
                    </div>
                    <div class="item-details"><div class="item-title">COFFEE</div></div>
                </div>
                
                <div class="menu-item-card" onclick="openSubMenu('MILKTEA')">
                    <div class="item-image-placeholder">
                        🧋
                        <button type="button" class="change-photo-btn" onclick="event.stopPropagation(); openCategoryPhotoUpload('MILK TEA');">📷 Add Photo</button>
                    </div>
                    <div class="item-details"><div class="item-title">MILK TEA</div></div>
                </div>
                
                <div class="menu-item-card" onclick="openSubMenu('FRUIT TEA')">
                    <div class="item-image-placeholder">
                        🍹
                        <button type="button" class="change-photo-btn" onclick="event.stopPropagation(); openCategoryPhotoUpload('FRUIT TEA');">📷 Add Photo</button>
                    </div>
                    <div class="item-details"><div class="item-title">FRUIT TEA</div></div>
                </div>
                
                <div class="menu-item-card" onclick="openSubMenu('RICE MEAL')">
                    <div class="item-image-placeholder">
                        🍱
                        <button type="button" class="change-photo-btn" onclick="event.stopPropagation(); openCategoryPhotoUpload('RICE MEAL');">📷 Add Photo</button>
                    </div>
                    <div class="item-details"><div class="item-title">RICE MEAL</div></div>
                </div>
                
                <div class="menu-item-card" onclick="openSubMenu('BREAD & PASTRY')">
                    <div class="item-image-placeholder">
                        🥐
                        <button type="button" class="change-photo-btn" onclick="event.stopPropagation(); openCategoryPhotoUpload('BREAD & PASTRY');">📷 Add Photo</button>
                    </div>
                    <div class="item-details"><div class="item-title">BREAD & PASTRY</div></div>
                </div>
                
                <div class="menu-item-card" onclick="openSubMenu('SNACKS & PASTA')">
                    <div class="item-image-placeholder">
                        🍝
                        <button type="button" class="change-photo-btn" onclick="event.stopPropagation(); openCategoryPhotoUpload('SNACKS & PASTA');">📷 Add Photo</button>
                    </div>
                    <div class="item-details"><div class="item-title">SNACKS & PASTA</div></div>
                </div>
            </div>

            <div id="subItemsContainer" class="product-catalog-grid" style="display: none;"></div>
        </main>
    </div>

    <div id="recipeModal" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
        <div class="modal-content" style="background: white; padding: 25px; border-radius: 15px; width: 500px; box-shadow: 0 5px 15px rgba(0,0,0,0.3);">
            <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 id="recipeItemName" style="margin: 0;">Edit Recipe</h2>
                <button onclick="closeRecipe()" class="close-btn" style="background: none; border: none; font-size: 24px; cursor: pointer;">&times;</button>
            </div>
            
            <div class="form-group" style="display: flex; gap: 10px; margin-bottom: 15px;">
                <select id="ingredientSelect" style="flex: 2; padding: 10px; border-radius: 6px; border: 1px solid #ddd;">
                    <option value="">Select Ingredient...</option>
                </select>
                <input type="number" id="ingredientQty" placeholder="Qty (e.g. 15)" style="flex: 1; padding: 10px; border-radius: 6px; border: 1px solid #ddd;">
                <button type="button" onclick="addIngredientToUI()" style="background: #4a2511; color: white; border: none; border-radius: 6px; padding: 0 15px; cursor: pointer;">Add</button>
            </div>

            <div style="background: #f9f9f9; padding: 15px; border-radius: 8px; min-height: 150px; margin-bottom: 15px;">
                <h4 style="margin-top: 0; color: #8c5b3e;">Current Recipe</h4>
                <ul id="recipeList" style="list-style: none; padding: 0; margin: 0;">
                </ul>
            </div>

            <div class="modal-actions">
                <button type="button" onclick="saveRecipeToDB()" class="btn-primary" style="background: #f46a05; width: 100%; color: white; padding: 12px; border: none; border-radius: 8px; font-weight: bold; cursor: pointer;">Save Recipe to Database</button>
            </div>
        </div>
    </div>

    <script>
        // ==========================================
        // 1. DYNAMIC DATA LOADING
        // ==========================================
        const menuData = {};
        
        @if (Model != null)
        {
            foreach (var item in Model)
            {
                @:if(!menuData["@Html.Raw(item.CategoryName.ToUpper())"]) menuData["@Html.Raw(item.CategoryName.ToUpper())"] = [];
                @:menuData["@Html.Raw(item.CategoryName.ToUpper())"].push({ id: @item.ProductId, name: "@Html.Raw(item.ProductName)" });
            }
        }

        let currentCategory = "";

        // ==========================================
        // 2. UI NAVIGATION
        // ==========================================
        function openSubMenu(cat) {
        currentCategory = cat;
        const items = menuData[cat] || [];
        const container = document.getElementById('subItemsContainer');
        const catImg = localStorage.getItem(`cat_img_${cat}`) || "";
                
        document.getElementById('pageTitle').innerText = cat;
        document.getElementById('pageSubtitle').innerText = "Managing recipes for " + cat;
                
        // DYNAMIC UI: Change the button text to + Add Item
        document.getElementById('mainAddBtn').innerText = "+ Add Item";
                
        container.innerHTML = "";
        items.forEach(item => {
        let imgTag = catImg ? `<img src="${catImg}" style="width:100%;height:100%;object-fit:cover;">` : `<span style="font-size:40px;">📦</span>`;
                        
        container.innerHTML += `
        <div class="menu-item-card">
        <div class="item-image-placeholder" style="height:120px;">
        ${imgTag}
        <button type="button" class="change-photo-btn" onclick="event.stopPropagation(); openCategoryPhotoUpload('${item.name.replace(/'/g, "\\'")}');">📷 Add Photo</button>
        </div>
        <div class="item-details">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px;">
                                                                    
        <div class="item-title" style="font-size:15px; padding-right: 10px;">${item.name}</div>
                                                                        
        <button type="button"
        onclick="event.stopPropagation(); deleteItem(${item.id})"
        style="background:none; border:none; color:red; cursor:pointer; font-weight:bold; font-size: 16px; padding: 5px; flex-shrink: 0; z-index: 10;">
        X
        </button>

        </div>
                                                                
        <button type="button"
        class="btn-primary"
        style="width:100%; font-size:11px; background:#4a2511; color: white; padding: 8px; border: none; border-radius: 6px; cursor: pointer;"
        onclick="event.stopPropagation(); openRecipe(${item.id}, '${item.name.replace(/'/g, "\\'")}')">
        Edit Recipe
        </button>
        </div>
        </div>`;
        });

        document.getElementById('categoryContainer').style.display = 'none';
        document.getElementById('subItemsContainer').style.display = 'grid';
        document.getElementById('backBtn').style.display = 'block';
        }

        function showCategories() {
        currentCategory = "";
        document.getElementById('pageTitle').innerText = "Menu Categories 🏷️";
                
        // DYNAMIC UI: Reset the button text back to + Add Category
        document.getElementById('mainAddBtn').innerText = "+ Add Category";
                
        document.getElementById('categoryContainer').style.display = 'grid';
        document.getElementById('subItemsContainer').style.display = 'none';
        document.getElementById('backBtn').style.display = 'none';
        }

        // ==========================================
        // UI FEATURE: ADD PHOTO TO CATEGORY/ITEM
        // ==========================================
        function openCategoryPhotoUpload(targetName) {
        Swal.fire({
        title: `Upload Photo`,
        html: `
        <p style="color: #b58361; font-size: 14px; margin-bottom: 15px;">Select an image for <strong>${targetName}</strong></p>
        <div style="border: 2px dashed #dcbca5; border-radius: 12px; padding: 30px; text-align: center; cursor: pointer; background: #fdfaf6; transition: 0.3s;" onmouseover="this.style.borderColor='#f46a05'" onmouseout="this.style.borderColor='#dcbca5'" onclick="document.getElementById('cat-specific-image').click()">
        <span style="font-size: 40px;">📸</span><br><br>
        <span style="font-size: 15px; color: #8c5b3e; font-weight: bold;">Click to browse files</span>
        </div>
        <input type="file" id="cat-specific-image" style="display: none;" accept="image/*">
        `,
        showCancelButton: true,
        confirmButtonColor: '#f46a05',
        cancelButtonColor: '#4a2511',
        confirmButtonText: 'Save Photo'
        }).then((result) => {
        if (result.isConfirmed) {
        Swal.fire('UI Conceptual', `Photo for ${targetName} would be uploaded here.`, 'success');
        }
        });
        }

        // ==========================================
        // 3. THE ALL-IN-ONE CRUD ACTION (ADD)
        // ==========================================
        document.querySelector('#mainAddBtn').addEventListener('click', async function() {
            
        // IF CURRENT CATEGORY IS EMPTY, WE ARE ADDING A CATEGORY
        if(!currentCategory) {
        const { value: categoryData } = await Swal.fire({
        title: 'Create New Category',
        html: `
        <div style="text-align: left; margin-bottom: 15px;">
        <label style="font-size: 13px; font-weight: 700; color: #8c5b3e; display: block; margin-bottom: 5px;">Category Name</label>
        <input id="new-cat-name" class="swal2-input" placeholder="e.g. Smoothies" style="width: 100%; margin: 0; box-sizing: border-box; font-size: 14px;">
        </div>
        <div style="text-align: left;">
        <label style="font-size: 13px; font-weight: 700; color: #8c5b3e; display: block; margin-bottom: 5px;">Category Icon/Image (Optional)</label>
        <div style="border: 2px dashed #dcbca5; border-radius: 12px; padding: 20px; text-align: center; cursor: pointer; background: #fcfaf6;" onclick="document.getElementById('new-cat-img').click()">
        <span style="font-size: 30px;">🖼️</span><br>
        <span style="font-size: 13px; color: #b58361;">Click to add thumbnail</span>
        </div>
        <input type="file" id="new-cat-img" style="display: none;" accept="image/*">
        </div>
        `,
        showCancelButton: true,
        confirmButtonColor: '#f46a05',
        cancelButtonColor: '#4a2511',
        confirmButtonText: 'Save Category',
        preConfirm: () => {
        const name = document.getElementById('new-cat-name').value.trim();
        if(!name) {
        Swal.showValidationMessage('Please enter a Category Name.');
        return false;
        }
        return { CategoryName: name };
        }
        });

        if (categoryData) {
        Swal.fire('UI Conceptual', `New category "${categoryData.CategoryName}" would be created here.`, 'success');
        }
        return;
        }
                
        // IF CURRENT CATEGORY IS SET, WE ARE ADDING AN ITEM TO IT
        let ingOptions = '<option value="">Select Ingredient...</option>';
        allIngredients.forEach(i => ingOptions += `<option value="${i.id}">${i.name}</option>`);
                    
        const { value: formValues } = await Swal.fire({
        title: `Add Item to ${currentCategory}`,
        width: '600px',
        html: `
        <div style="display: flex; gap: 10px; margin-bottom: 15px;">
        <input id="swal-name" class="swal2-input" placeholder="Name (e.g. Mocha)" style="flex: 2; margin:0;">
        <select id="swal-size" class="swal2-input" style="flex: 1; margin:0; font-size: 14px;">
        <option value="">No Size</option>
        <option value=" - Small">Small</option>
        <option value=" - Large">Large</option>
        </select>
        <input id="swal-price" type="number" class="swal2-input" placeholder="Price ₱" style="flex: 1; margin:0;">
        </div>
                                            
        <hr style="border: 0; border-top: 1px solid #eee; margin: 15px 0;">
        <h4 style="text-align:left; color:#8c5b3e; margin-bottom: 10px;">Recipe Ingredients (Optional)</h4>
                                            
        <div id="swal-recipe-rows" style="display:flex; flex-direction:column; gap:10px;">
        <div style="display: flex; gap: 10px;" class="swal-ing-row">
        <select class="swal2-input swal-ing-id" style="flex: 2; margin:0; font-size: 14px;">${ingOptions}</select>
        <input type="number" class="swal2-input swal-ing-qty" placeholder="Qty" style="flex: 1; margin:0;">
        </div>
        <div style="display: flex; gap: 10px;" class="swal-ing-row">
        <select class="swal2-input swal-ing-id" style="flex: 2; margin:0; font-size: 14px;">${ingOptions}</select>
        <input type="number" class="swal2-input swal-ing-qty" placeholder="Qty" style="flex: 1; margin:0;">
        </div>
        <div style="display: flex; gap: 10px;" class="swal-ing-row">
        <select class="swal2-input swal-ing-id" style="flex: 2; margin:0; font-size: 14px;">${ingOptions}</select>
        <input type="number" class="swal2-input swal-ing-qty" placeholder="Qty" style="flex: 1; margin:0;">
        </div>
        </div>
        `,
        focusConfirm: false,
        showCancelButton: true,
        confirmButtonColor: '#f46a05',
        confirmButtonText: 'Save Complete Item',
        preConfirm: () => {
        const name = document.getElementById('swal-name').value.trim();
        const size = document.getElementById('swal-size').value;
        const price = document.getElementById('swal-price').value;
                                                    
        if (!name || !price) {
        Swal.showValidationMessage('Please enter the Name and Price.');
        return false;
        }

        const ingredients = [];
        const rows = document.querySelectorAll('.swal-ing-row');
        rows.forEach(row => {
        const ingId = row.querySelector('.swal-ing-id').value;
        const ingQty = row.querySelector('.swal-ing-qty').value;
        if (ingId && ingQty > 0) {
        ingredients.push({ IngredientId: parseInt(ingId), Quantity: parseFloat(ingQty) });
        }
        });

        return {
        ProductName: name,
        Size: size,
        Price: parseFloat(price),
        CategoryName: currentCategory,
        Ingredients: ingredients
        };
        }
        });
                    
        if (formValues) {
        fetch('/Admin/AddFullProduct', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formValues)
        }).then(res => {
        if(res.ok) {
        Swal.fire({ title: 'Saved!', text: 'Product and recipe routed to database.', icon: 'success', timer: 1500, showConfirmButton: false })
        .then(() => location.reload());
        } else {
        Swal.fire('Error', 'Failed to save item. Check your database connection.', 'error');
        }
        });
        }
        });

        function deleteItem(id) {
        Swal.fire({
        title: 'Are you sure?',
        text: "This will remove the item from the menu!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Yes, delete it!'
        }).then((result) => {
        if (result.isConfirmed) {
        fetch('/Admin/DeleteMenuItem', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(id)
        }).then(res => {
        if(res.ok) {
        Swal.fire({ title: 'Deleted!', text: 'Item removed.', icon: 'success', timer: 1500, showConfirmButton: false })
        .then(() => location.reload());
        } else {
        Swal.fire('Cannot Delete', 'This item is tied to past sales records.', 'error');
        }
        });
        }
        });
        }

        // ==========================================
        // 4. RECIPE BUILDER LOGIC
        // ==========================================
        let currentRecipeProductId = 0;
        let currentRecipeItems = [];
        let allIngredients = [];

        window.addEventListener('DOMContentLoaded', async () => {
        const res = await fetch('/Admin/GetIngredients');
        allIngredients = await res.json();
                    
        const select = document.getElementById('ingredientSelect');
        allIngredients.forEach(ing => {
        // ⭐ THE FIX: Attach the unit directly as an HTML data attribute
        select.innerHTML += `<option value="${ing.id}" data-unit="${ing.unit}">${ing.name}</option>`;
        });
        });

        async function openRecipe(productId, productName) {
        currentRecipeProductId = productId;
        currentRecipeItems = [];
        document.getElementById('recipeItemName').innerText = productName + " Recipe";
                    
        const res = await fetch(`/Admin/GetRecipe?productId=${productId}`);
        const existingData = await res.json();
                    
        existingData.forEach(item => {
        // ⭐ THE FIX: Also store the unit when fetching existing recipe data
        currentRecipeItems.push({ id: item.id, name: item.name, qty: item.qty, unit: item.unit });
        });
                    
        renderRecipeList();
        document.getElementById('recipeModal').style.display = 'flex';
        }

        function closeRecipe() {
        document.getElementById('recipeModal').style.display = 'none';
        }

        function addIngredientToUI() {
        const select = document.getElementById('ingredientSelect');
        const qtyInput = document.getElementById('ingredientQty');
                    
        const id = parseInt(select.value);
        const name = select.options[select.selectedIndex]?.text;
            
        // ⭐ THE FIX: Extract the unit from the selected dropdown option
        const unit = select.options[select.selectedIndex]?.getAttribute("data-unit") || "unit(s)";
        const qty = parseFloat(qtyInput.value);
                    
        if(!id || !qty || qty <= 0) return Swal.fire('Wait!', 'Select an ingredient and enter a valid quantity.', 'warning');
        if(currentRecipeItems.find(i => i.id === id)) return Swal.fire('Oops', 'This ingredient is already in the recipe!', 'error');

        // ⭐ THE FIX: Push the unit into the array
        currentRecipeItems.push({ id: id, name: name, qty: qty, unit: unit });
        renderRecipeList();
                    
        select.value = "";
        qtyInput.value = "";
        }

        function removeIngredientFromUI(id) {
        currentRecipeItems = currentRecipeItems.filter(i => i.id !== id);
        renderRecipeList();
        }

        function renderRecipeList() {
        const list = document.getElementById('recipeList');
        list.innerHTML = "";
                    
        if(currentRecipeItems.length === 0) {
        list.innerHTML = "<li style='color: #999; font-size: 13px; text-align: center; margin-top: 20px;'>No ingredients added yet.</li>";
        return;
        }

        currentRecipeItems.forEach(item => {
        // ⭐ THE FIX: Render the unit variable dynamically next to the quantity
        list.innerHTML += `
        <li style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #eee;">
        <span><strong>${item.qty} ${item.unit}</strong> x ${item.name}</span>
        <button onclick="removeIngredientFromUI(${item.id})" style="color: red; border: none; background: none; cursor: pointer; font-weight: bold;">X</button>
        </li>`;
        });
        }

        function saveRecipeToDB() {
        const payload = {
        ProductId: currentRecipeProductId,
        Ingredients: currentRecipeItems.map(i => ({ IngredientId: i.id, Quantity: i.qty }))
        };

        fetch('/Admin/SaveRecipe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
        }).then(res => {
        if(res.ok) {
        Swal.fire('Saved!', 'Recipe successfully linked to inventory.', 'success');
        closeRecipe();
        } else {
        Swal.fire('Error', 'Failed to save recipe.', 'error');
        }
        });
        }
    </script>
</body>
</html>