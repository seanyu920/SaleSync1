@{
    Layout = null;
    var currentRole = "Admin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Menu Management - SyncScale</title>
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Products.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">SyncScale</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>
                <div class="profile-section" style="display: flex; align-items: center; gap: 15px; margin-bottom: 40px; padding: 0 10px;">
                    <div class="profile-circle" style="width: 45px; height: 45px; background: #f46a05; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #fff;">👤</div>
                    <div>
                        <h2 class="admin-name" style="font-size: 16px; font-weight: 700; color: #ffffff; margin: 0;">Admin</h2>
                        <div style="font-size: 12px; color: #dcbca5;">Administrator</div>
                    </div>
                </div>
                <nav class="sidebar-menu">
                    <a href="#" class="menu-btn">❖ Dashboard</a>
                    <a href="#" class="menu-btn">📊 Analytics</a>
                    <a href="#" class="menu-btn active">🏷️ Products</a>
                    <a href="#" class="menu-btn">📦 Inventory</a>
                </nav>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px;">
                <div>
                    <h1 class="greeting-title" id="pageTitle">Menu Categories 🏷️</h1>
                    <p class="greeting-subtitle" id="pageSubtitle">Manage high-level categories or drill down into items.</p>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button id="backBtn" class="btn-secondary" style="display: none;" onclick="showCategories()">← Back to Categories</button>
                    <button class="btn-primary">+ Add New</button>
                </div>
            </div>

            <div id="categoryContainer" class="product-catalog-grid">
                <div class="menu-item-card" onclick="openSubMenu('COFFEE')">
                    <div class="item-image-placeholder">☕</div>
                    <div class="item-details"><div class="item-title">COFFEE</div></div>
                </div>
                <div class="menu-item-card" onclick="openSubMenu('MILKTEA')">
                    <div class="item-image-placeholder">🧋</div>
                    <div class="item-details"><div class="item-title">MILK TEA</div></div>
                </div>
                <div class="menu-item-card" onclick="openSubMenu('FRUIT TEA')">
                    <div class="item-image-placeholder">🍹</div>
                    <div class="item-details"><div class="item-title">FRUIT TEA</div></div>
                </div>
                <div class="menu-item-card" onclick="openSubMenu('RICE MEAL')">
                    <div class="item-image-placeholder">🍱</div>
                    <div class="item-details"><div class="item-title">RICE MEAL</div></div>
                </div>
                <div class="menu-item-card" onclick="openSubMenu('BREAD & PASTRY')">
                    <div class="item-image-placeholder">🥐</div>
                    <div class="item-details"><div class="item-title">BREAD & PASTRY</div></div>
                </div>
                <div class="menu-item-card" onclick="openSubMenu('SNACKS & PASTA')">
                    <div class="item-image-placeholder">🍝</div>
                    <div class="item-details"><div class="item-title">SNACKS & PASTA</div></div>
                </div>
            </div>

            <div id="subItemsContainer" class="product-catalog-grid" style="display: none;"></div>
        </main>
    </div>

    <div id="recipeModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="recipeItemName">Recipe</h2>
                <button onclick="closeRecipe()" class="close-btn">&times;</button>
            </div>
            <div class="form-group">
                <label>Ingredients & Proportions</label>
                <textarea rows="6" placeholder="List ingredients for inventory deduction..."></textarea>
            </div>
            <div class="modal-actions">
                <button type="button" onclick="closeRecipe()" class="btn-primary">Save Recipe</button>
            </div>
        </div>
    </div>

    <script>
            const menuData = {
                "COFFEE": ["Americano", "Cappuccino", "Hot Choco", "Hot Latte", "Iced Latte", "Spanish Latte", "Hot Matcha Latte", "Iced Matcha Latte"],
                "MILKTEA": ["Wintermelon", "Okinawa", "Cookies and Cream", "Salted Caramel", "Hokkaido", "Matcha", "Thai"],
                "FRUIT TEA": ["Green Apple", "Strawberry", "Blueberry", "Mango", "Lychee", "Peach"],
                "RICE MEAL": ["Silog", "Hot Silog", "Long Silog", "Ham Silog", "Shanghai Silog", "Embotido Silog"],
                "BREAD & PASTRY": ["Chocolate Cookies", "Croissant", "Cheese Ensaymada", "Yema Ensaymada", "Ube Ensaymada", "Chocolate Donut", "Cinnamon"],
                "SNACKS & PASTA": ["Flavored Fries", "Nachos", "Siomai 4pcs", "Carbonara", "Pesto Pasta", "Gambas Pasta"]
            };

            function openSubMenu(cat) {
                const items = menuData[cat];
                const container = document.getElementById('subItemsContainer');
                const catImg = localStorage.getItem(`cat_img_${cat}`) || "";
            
                document.getElementById('pageTitle').innerText = cat;
                document.getElementById('pageSubtitle').innerText = "Managing recipes for " + cat;
            
                container.innerHTML = "";
                items.forEach(item => {
                    let imgTag = catImg ? `<img src="${catImg}" style="width:100%;height:100%;object-fit:cover;">` : `<span style="font-size:40px;">📦</span>`;
                
                    container.innerHTML += `
                        <div class="menu-item-card">
                            <div class="item-image-placeholder" style="height:120px;">${imgTag}</div>
                            <div class="item-details">
                                <div class="item-title" style="font-size:15px; margin-bottom:10px;">${item}</div>
                                <button class="btn-primary" style="width:100%; font-size:11px; background:#4a2511;" onclick="openRecipe('${item}')">Edit Recipe</button>
                            </div>
                        </div>`;
                });

                document.getElementById('categoryContainer').style.display = 'none';
                document.getElementById('subItemsContainer').style.display = 'grid';
                document.getElementById('backBtn').style.display = 'block';
            }

            function showCategories() {
                document.getElementById('pageTitle').innerText = "Menu Categories 🏷️";
                document.getElementById('categoryContainer').style.display = 'grid';
                document.getElementById('subItemsContainer').style.display = 'none';
                document.getElementById('backBtn').style.display = 'none';
            }

            function openRecipe(name) {
                document.getElementById('recipeItemName').innerText = name + " Recipe";
                document.getElementById('recipeModal').classList.add('show');
            }

            function closeRecipe() {
                document.getElementById('recipeModal').classList.remove('show');
            }
    </script>
</body>
</html>