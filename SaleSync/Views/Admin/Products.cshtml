@{
    Layout = null;
    var currentRole = "Admin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Products - SyncScale</title>
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Products.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-container">

        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">SyncScale</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section" style="display: flex; align-items: center; gap: 15px; margin-bottom: 40px; padding: 0 10px;">
                    <div class="profile-circle" style="width: 45px; height: 45px; background: #f46a05; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #fff;">👤</div>
                    <div>
                        <h2 class="admin-name" style="font-size: 16px; font-weight: 700; color: #ffffff; margin: 0;">Admin</h2>
                        <div style="font-size: 12px; color: #dcbca5;">Administrator</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a asp-controller="Admin" asp-action="Dashboard" class="menu-btn">❖ Dashboard</a>
                    <a asp-controller="Admin" asp-action="Analytics" class="menu-btn">📊 Analytics</a>
                    
                    <a asp-controller="Admin" asp-action="Products" class="menu-btn active">🏷️ Products</a>
                    
                    <a asp-controller="Admin" asp-action="Inventory" class="menu-btn">📦 Inventory</a>
                    <a asp-controller="Admin" asp-action="ManageAccounts" class="menu-btn">💳 Accounts</a>
                </nav>
            </div>

            <div class="logout-section" style="margin-top: auto;">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn" style="background: transparent; border: none; width: 100%; text-align: left; cursor: pointer; color: #dcbca5; padding: 14px 20px;">
                        ⎋ Log Out
                    </button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px;">
                <div>
                    <h1 class="greeting-title">Menu Products 🏷️</h1>
                    <p class="greeting-subtitle">Manage the items available on your Cashier POS screen.</p>
                </div>
                <button id="openModalBtn" class="btn-primary">+ Add New Product</button>
            </div>

            <div class="product-filters">
                <button class="filter-pill active">All Items</button>
                <button class="filter-pill">COFFEE</button>
                <button class="filter-pill">MILKTEA</button>
                <button class="filter-pill">PASTRIES</button>
            </div>

            <input type="file" id="categoryImgUpload" style="display:none;" accept="image/*">

            <div class="product-catalog-grid">
                <div class="menu-item-card" onclick="triggerUpload('COFFEE')">
                    <div class="item-image-placeholder">
                        <img id="img-COFFEE" src="" style="display:none; width:100%; height:100%; object-fit:cover;">
                        <span id="emoji-COFFEE" style="font-size:50px;">☕</span>
                        <div style="position:absolute; bottom:10px; background:rgba(0,0,0,0.5); color:white; font-size:10px; padding:2px 8px; border-radius:10px;">Change Photo</div>
                    </div>
                    <div class="item-details">
                        <div class="item-category">Category</div>
                        <div class="item-title">Coffee Menu</div>
                        <div class="item-price-row">
                            <span class="item-price">View Items</span>
                            <span class="edit-icon">✏️</span>
                        </div>
                    </div>
                </div>

                <div class="menu-item-card" onclick="triggerUpload('MILKTEA')">
                    <div class="item-image-placeholder">
                        <img id="img-MILKTEA" src="" style="display:none; width:100%; height:100%; object-fit:cover;">
                        <span id="emoji-MILKTEA" style="font-size:50px;">🧋</span>
                        <div style="position:absolute; bottom:10px; background:rgba(0,0,0,0.5); color:white; font-size:10px; padding:2px 8px; border-radius:10px;">Change Photo</div>
                    </div>
                    <div class="item-details">
                        <div class="item-category">Category</div>
                        <div class="item-title">Milk Tea Menu</div>
                        <div class="item-price-row">
                            <span class="item-price">View Items</span>
                            <span class="edit-icon">✏️</span>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="productModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Add New Product</h2>
                <button id="closeModalBtn" class="close-btn">&times;</button>
            </div>
            <form>
                <div class="form-group">
                    <label>Product Name</label>
                    <input type="text" placeholder="e.g. Caramel Macchiato">
                </div>
                <div class="modal-actions">
                    <button type="button" id="cancelBtn" class="btn-secondary">Cancel</button>
                    <button type="button" class="btn-primary">Save Product</button>
                </div>
            </form>
        </div>
    </div>

    <script>
            // Modal logic
            const modal = document.getElementById('productModal');
            document.getElementById('openModalBtn').onclick = () => modal.style.display = 'flex';
            document.getElementById('closeModalBtn').onclick = () => modal.style.display = 'none';
            document.getElementById('cancelBtn').onclick = () => modal.style.display = 'none';

            // Image Upload Logic
            let activeCat = "";
            const uploader = document.getElementById('categoryImgUpload');

            function triggerUpload(cat) {
                activeCat = cat;
                uploader.click();
            }

            uploader.onchange = function() {
                if (this.files && this.files[0]) {
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        const data = e.target.result;
                        localStorage.setItem(`cat_img_${activeCat}`, data);
                        updateUI(activeCat, data);
                    };
                    reader.readAsDataURL(this.files[0]);
                }
            };

            function updateUI(cat, data) {
                const img = document.getElementById(`img-${cat}`);
                const emoji = document.getElementById(`emoji-${cat}`);
                if(img && data) {
                    img.src = data;
                    img.style.display = "block";
                    emoji.style.display = "none";
                }
            }

            window.onload = () => {
                ['COFFEE', 'MILKTEA'].forEach(cat => {
                    const saved = localStorage.getItem(`cat_img_${cat}`);
                    if(saved) updateUI(cat, saved);
                });
            };
    </script>
</body>
</html>