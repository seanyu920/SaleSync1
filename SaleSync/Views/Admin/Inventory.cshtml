@model List<SaleSync.Models.InventoryItems>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Inventory</title>
    <link rel="stylesheet" href="~/css/Inventory.css" />
</head>
<body>
    <div class="dashboard-container">

        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <img src="~/images/syncsale-logo.png" class="logo-img" />
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <h2 class="admin-name">
                        @(ViewContext.RouteData.Values["controller"]?.ToString() == "Manager" ? "Manager" : "Admin")
                    </h2>
                </div>

                <nav class="sidebar-menu">
                    <a asp-controller="Admin" asp-action="Dashboard" class="menu-btn">Analysis</a>
                    <a asp-controller="Admin" asp-action="Inventory" class="menu-btn active">Inventory</a>

                    @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Admin")
                    {
                        <a asp-controller="Admin" asp-action="ManageAccounts" class="menu-btn">Accounts</a>
                    }
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn">Log Out</button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            
            <div class="inventory-content">

                <!-- Buttons -->
                <div class="action-buttons">
                    <button type="submit" form="inventoryForm" formaction="/Admin/AddInventory" class="action-btn add-btn">Add</button>
                    <button type="submit" form="inventoryForm" formaction="/Admin/UpdateInventory" class="action-btn update-btn">Update</button>
                    <button type="button" onclick="deleteItem()" class="action-btn delete-btn">Delete</button>
                </div>

                <!-- Form -->
                <div class="form-card">
                    <h1 class="form-title">Add Inventory Item</h1>

                    <form id="inventoryForm" method="post">
                        <input type="hidden" name="ProductId" id="ProductId" />

                        <div class="form-grid">
                            <input type="text" name="ItemCategory" placeholder="Item Category" required />
                            <input type="text" name="ItemName" placeholder="Item Name" required />
                            <input type="text" name="ItemID" placeholder="Item ID" required />
                            <input type="text" name="PurchasePrice" placeholder="Purchase Price" required />

                            <input type="text" name="Quantity" placeholder="Quantity" required />
                            <input type="text" name="StockSupplier" placeholder="Stock Supplier" required />
                            <input type="date" name="DateAcquired" required />
                            <input type="date" name="ExpirationDate" required />
                        </div>
                    </form>
                </div>

                <div class="search-bar">
                    <input type="text" placeholder="Search item..." />
                    <button type="button">Search</button>
                </div>

                <!-- Table -->
                <div class="table-card">
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Select</th>
                                    <th>Item Category</th>
                                    <th>Item Name</th>
                                    <th>Item ID</th>
                                    <th>Purchase Price</th>
                                    <th>Quantity</th>
                                    <th>Stock Level</th>
                                    <th>Stock Supplier</th>
                                    <th>Date Acquired</th>
                                    <th>Expiration Date</th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (Model != null && Model.Count > 0)
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                <input type="radio"
                                                       name="selectedItem"
                                                       value="@item.ItemID"
                                                       onclick="fillForm(
                                                '@item.ProductId',
                                                '@Html.Raw((item.ItemCategory ?? "").Replace("'", "\\'"))',
                                                '@Html.Raw((item.ItemName ?? "").Replace("'", "\\'"))',
                                                '@Html.Raw((item.ItemID ?? "").Replace("'", "\\'"))',
                                                '@item.PurchasePrice',
                                                '@item.Quantity',
                                                '@Html.Raw((item.StockSupplier ?? "").Replace("'", "\\'"))',
                                                '@item.DateAcquired',
                                                '@item.ExpirationDate'
                                                )" />
                                            </td>
                                            <td>@item.ItemCategory</td>
                                            <td>@item.ItemName</td>
                                            <td>@item.ItemID</td>
                                            <td>@item.PurchasePrice.ToString("0.00")</td>
                                            <td>@item.Quantity</td>
                                            <td>@item.StockLevel</td>
                                            <td>@item.StockSupplier</td>
                                            <td>@item.DateAcquired</td>
                                            <td>@item.ExpirationDate</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="10">No inventory items added yet.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <!-- Delete Form -->
    <form id="deleteForm" method="post" action="/Admin/DeleteInventory">
        <input type="hidden" name="id" id="deleteId" />
    </form>

    <script>
            function fillForm(productId, itemCategory, itemName, itemID, purchasePrice, quantity, stockSupplier, dateAcquired, expirationDate) {
                document.getElementById("ProductId").value = productId;
                document.querySelector('input[name="ItemCategory"]').value = itemCategory;
                document.querySelector('input[name="ItemName"]').value = itemName;
                document.querySelector('input[name="ItemID"]').value = itemID;
                document.querySelector('input[name="PurchasePrice"]').value = purchasePrice;
                document.querySelector('input[name="Quantity"]').value = quantity;
                document.querySelector('input[name="StockSupplier"]').value = stockSupplier;
                document.querySelector('input[name="DateAcquired"]').value = dateAcquired;
                document.querySelector('input[name="ExpirationDate"]').value = expirationDate;
            }

            function getSelectedId() {
                const selected = document.querySelector('input[name="selectedItem"]:checked');
                if (!selected) {
                    alert("Select an item first.");
                    return null;
                }
                return selected.value;
            }

            function deleteItem() {
                const id = getSelectedId();
                if (!id) return;

                if (!confirm("Delete this inventory item?")) return;

                document.getElementById("deleteId").value = id;
                document.getElementById("deleteForm").submit();
            }
    </script>
</body>
</html>