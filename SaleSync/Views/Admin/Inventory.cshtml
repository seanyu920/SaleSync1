@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Inventory</title>
    <link rel="stylesheet" href="~/css/Inventory.css" />
</head>
<body>
    <div class="dashboard-container">

        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <img src="~/images/syncsale-logo.png" class="logo-img" />
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <h2 class="admin-name">Admin</h2>
                </div>

                <nav class="sidebar-menu">
                    <a asp-controller="Admin" asp-action="Dashboard" class="menu-btn">Analysis</a>
                    <a asp-controller="Admin" asp-action="Inventory" class="menu-btn active">Inventory</a>
                </nav>
            </div>

            <div class="logout-section">
                <a asp-controller="Home" asp-action="Index" class="menu-btn">Log Out</a>
            </div>
        </aside>

        <main class="main-content">
            <div class="top-bar">
                <a asp-controller="Admin" asp-action="ManageAccounts" class="accounts-btn">Accounts</a>
            </div>

            <div class="inventory-content">

                <!-- Buttons -->
                <div class="action-buttons">
                    <button class="action-btn add-btn">Add</button>
                    <button class="action-btn update-btn">Update</button>
                    <button class="action-btn delete-btn">Delete</button>
                </div>

                <!-- Form -->
                <div class="form-card">
                    <h1 class="form-title">Add Inventory Item</h1>

                    <div class="form-grid">
                        <input type="text" placeholder="Item Category" />
                        <input type="text" placeholder="Item Name" />
                        <input type="text" placeholder="Item ID" />
                        <input type="text" placeholder="Purchase Price" />

                        <input type="text" placeholder="Quantity" />
                        <input type="text" placeholder="Stock Supplier" />
                        <input type="date" />
                        <input type="date" />
                    </div>

                    <button class="submit-btn">Add Item</button>
                </div>

                <!-- Table -->
                <div class="table-card">
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Select</th>
                                    <th>Item Category</th>
                                    <th>Item Name</th>
                                    <th>Item ID</th>
                                    <th>Purchase Price</th>
                                    <th>Quantity</th>
                                    <th>Stock Level</th>
                                    <th>Stock Supplier</th>
                                    <th>Date Acquired</th>
                                    <th>Expiration Date</th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (Model != null && Model.Count > 0)
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                <input type="radio"
                                                       name="selectedItem"
                                                       value="@item.ItemID"
                                                       onclick="fillForm(
                                                '@item.ProductId',
                                                '@item.ItemCategory',
                                                '@item.ItemName',
                                                '@item.ItemID',
                                                '@item.PurchasePrice',
                                                '@item.Quantity',
                                                '@item.StockSupplier',
                                                '@item.DateAcquired',
                                                '@item.ExpirationDate'
                                                )" />
                                            </td>
                                            <td>@item.ItemCategory</td>
                                            <td>@item.ItemName</td>
                                            <td>@item.ItemID</td>
                                            <td>@item.PurchasePrice.ToString("0.00")</td>
                                            <td>@item.Quantity</td>
                                            <td>@item.StockLevel</td>
                                            <td>@item.StockSupplier</td>
                                            <td>@item.DateAcquired</td>
                                            <td>@item.ExpirationDate</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="10">No inventory items added yet.</td>
                                    </tr>
                                }
                            </tbody>

                        </table>
                    </div>
                </div>

            </div>
        </main>
    </div>
</body>
</html>