@model SaleSync.Models.WebCustomization
@{
    Layout = null;

    // Default fallback values
    string displayRole = "Admin";
    string homeController = "Admin";

    // Explicitly check for each role sequence
    if (User.IsInRole("Manager"))
    {
        displayRole = "Manager";
        homeController = "Manager";
    }
    else if (User.IsInRole("Cashier"))
    {
        displayRole = "Cashier";
        homeController = "Cashier";
    }

    // Only Admins and Managers can change store settings; Cashiers see a read-only view.
    bool canEdit = User.IsInRole("Admin") || User.IsInRole("Manager");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Web Customization - @(Model?.StoreName ?? "Cafero")</title>

    <!-- FontAwesome Library for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- SweetAlert2 Library -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <link rel="stylesheet" href="~/css/Inventory.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/WebCustomization.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-container" id="dashboardContainer">
        <!-- SIDEBAR PANEL -->
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">@Html.Raw(Model?.StoreName ?? "Cafero")</div>
                    <div class="logo-subtitle">@Html.Raw(Model?.StoreTagline ?? "Coffee & Pastries")</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <h2 class="admin-name">@(User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? User.Identity?.Name ?? "User")</h2>
                        <div class="admin-role">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <!-- Dashboard (Visible to Everyone) -->
                    <a href="/@homeController/Dashboard" class="menu-btn">Dashboard</a>

                    <!-- POS (Only visible to the Cashier) -->
                    @if (User.IsInRole("Cashier"))
                    {
                        <a href="/@homeController/CashierMenu" class="menu-btn">POS</a>
                    }

                    <!-- Queue (Hidden from Cashier) -->
                    @if (!User.IsInRole("Cashier"))
                    {
                        <a href="/@homeController/QueueOrder" class="menu-btn">Queue</a>
                    }

                    <!-- Activity Log (Admin Only) -->
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ActivityLog" class="menu-btn">Activity Log</a>
                    }

                    <!-- Management Tabs (Hidden from Cashier) -->
                    @if (!User.IsInRole("Cashier"))
                    {
                        <a href="/@homeController/Analytics" class="menu-btn">Analytics</a>
                        <a href="/@homeController/Products" class="menu-btn">Products</a>
                        <a href="/@homeController/Inventory" class="menu-btn">Inventory</a>
                        <a href="/@homeController/ArchivedProducts" class="menu-btn">Archive</a>
                    }

                    <!-- Accounts (Admin Only) -->
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ManageAccounts" class="menu-btn">Accounts</a>
                    }

                    <!-- Customization (Visible to Everyone) -->
                    <a href="/@homeController/WebCustomization" class="menu-btn active">Customization</a>
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout" id="logoutForm">
                    <button type="button" class="menu-btn logout-btn" onclick="confirmLogout()">
                        Log Out
                    </button>
                </form>
            </div>
        </aside>

        <div class="mobile-header">
            <button class="hamburger-btn" onclick="toggleSidebar()">
                <i class="fas fa-bars"></i>
            </button>
            <div class="mobile-brand">Cafero</div>
        </div>

        <!-- MAIN CONTENT -->
        <main class="main-content slide-up">
            <div class="settings-header">
                <h2>Store Settings</h2>
                <p>@(canEdit ? "Manage your store's branding, receipt details, business hours, and app theme." : "View your store's current branding, receipt details, business hours, and app theme.")</p>
            </div>

            @if (TempData["SettingsSuccess"] != null)
            {
                <div class="settings-alert settings-alert-success">@TempData["SettingsSuccess"]</div>
            }
            @if (TempData["SettingsError"] != null)
            {
                <div class="settings-alert settings-alert-error">@TempData["SettingsError"]</div>
            }

            <form asp-controller="Admin" asp-action="UpdateSettings" method="post" enctype="multipart/form-data" class="settings-form">
                <fieldset class="settings-fieldset" @(canEdit ? "" : "disabled")>

                <!-- SECTION 1: WEB THEME DESIGN -->
                <div class="settings-card">
                    <h3>Application Web Theme</h3>
                    <p class="card-desc">Change the web application colors and layout interface positions.</p>

                    <div class="form-grid">
                        <div class="form-group">
                            <label for="PrimaryColor">Primary Highlights (Buttons, Selected Tabs)</label>
                            <input type="color" id="PrimaryColor" name="PrimaryColor" value="@(Model?.PrimaryColor ?? "#C9A84C")" class="color-picker-input" />
                        </div>

                        <div class="form-group">
                            <label for="SidebarColor">Sidebar Panel Background</label>
                            <input type="color" id="SidebarColor" name="SidebarColor" value="@(Model?.SidebarColor ?? "#141A14")" class="color-picker-input" />
                        </div>

                        <div class="form-group">
                            <label for="AccentColor">Icons & Detailed Flourishes</label>
                            <input type="color" id="AccentColor" name="AccentColor" value="@(Model?.AccentColor ?? "#C9A84C")" class="color-picker-input" />
                        </div>

                        <div class="form-group">
                            <label for="BackgroundColor">Main Application Window Background</label>
                            <input type="color" id="BackgroundColor" name="BackgroundColor" value="@(Model?.BackgroundColor ?? "#0D110D")" class="color-picker-input" />
                        </div>

                        <div class="form-group full-width">
                            <label for="SidebarPosition">Sidebar Window Dock Alignment</label>
                            <select id="SidebarPosition" name="SidebarPosition" class="select-dropdown">
                                <option value="left" selected="@(Model?.SidebarPosition == "left")">Left-aligned (Default)</option>
                                <option value="right" selected="@(Model?.SidebarPosition == "right")">Right-aligned</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- SECTION 2: STORE BRANDING -->
                <div class="settings-card">
                    <h3>Store Branding</h3>
                    <p class="card-desc">Change the identity headers that appear on your menus and login screens.</p>

                    <div class="form-grid">
                        <div class="form-group">
                            <label for="StoreName">Store Name</label>
                            <input type="text" id="StoreName" name="StoreName" value="@(Model?.StoreName)" placeholder="e.g., Cafero" required />
                        </div>

                        <div class="form-group">
                            <label for="StoreTagline">Store Tagline / Subtitle</label>
                            <input type="text" id="StoreTagline" name="StoreTagline" value="@(Model?.StoreTagline)" placeholder="e.g., Coffee & Pastries" />
                        </div>

                        <div class="form-group full-width">
                            <label for="StoreLogo">Upload Logo (Replaces default icons)</label>
                            @if (!string.IsNullOrEmpty(Model?.LogoPath))
                            {
                                <div class="current-logo-preview">
                                    <img src="@Model.LogoPath" alt="Current store logo" />
                                    <span>Current logo</span>
                                </div>
                            }
                            <div class="file-upload-wrapper">
                                <input type="file" id="StoreLogo" name="StoreLogo" accept="image/png,image/jpeg,image/webp,image/svg+xml" />
                                <div class="file-upload-btn">Choose Image...</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SECTION 3: RECEIPT CUSTOMIZATION -->
                <div class="settings-card">
                    <h3>Receipt Customization</h3>
                    <p class="card-desc">Configure information printed at the top and bottom of your POS receipts.</p>

                    <div class="form-grid">
                        <div class="form-group">
                            <label for="BusinessAddress">Business Address</label>
                            <input type="text" id="BusinessAddress" name="BusinessAddress" value="@(Model?.BusinessAddress)" placeholder="123 Main St, Manila" />
                        </div>

                        <div class="form-group">
                            <label for="ContactNumber">Contact Number</label>
                            <input type="text" id="ContactNumber" name="ContactNumber" value="@(Model?.ContactNumber)" placeholder="0917-XXXX-XXX" />
                        </div>

                        <div class="form-group">
                            <label for="TaxIdNumber">TIN (Tax Identification Number)</label>
                            <input type="text" id="TaxIdNumber" name="TaxIdNumber" value="@(Model?.TaxIdNumber)" placeholder="XXX-XXX-XXX-000" />
                        </div>

                        <div class="form-group">
                            <label for="ReceiptFooter">Receipt Footer Message</label>
                            <input type="text" id="ReceiptFooter" name="ReceiptFooter" value="@(Model?.ReceiptFooter)" placeholder="Thank you, come again!" />
                        </div>
                    </div>
                </div>

                <!-- SECTION 4: POS SYSTEM DEFAULTS -->
                <div class="settings-card">
                    <h3>POS & System Defaults</h3>
                    <p class="card-desc">Set regional currencies, tax baselines, and database threshold alerts.</p>

                    <div class="form-grid">
                        <div class="form-group-triple">
                            <div class="form-group">
                                <label for="CurrencySymbol">Currency Symbol</label>
                                <input type="text" id="CurrencySymbol" name="CurrencySymbol" value="@(Model?.CurrencySymbol)" max="3" placeholder="₱" required />
                            </div>

                            <div class="form-group">
                                <label for="VatRate">VAT Rate (%)</label>
                                <input type="number" step="0.01" id="VatRate" name="VatRate" value="@(Model?.VatRate)" placeholder="12" required />
                            </div>

                            <div class="form-group">
                                <label for="LowStockThreshold">Low Stock Alert Level</label>
                                <input type="number" id="LowStockThreshold" name="LowStockThreshold" value="@(Model?.LowStockThreshold)" placeholder="10" required />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SECTION 5: BUSINESS HOURS -->
                <div class="settings-card">
                    <h3>Business Hours</h3>
                    <p class="card-desc">Set your regular opening and closing times. The dashboard and customer-facing pages will show your store as open or closed based on this schedule.</p>

                    <div class="form-grid">
                        <div class="form-group">
                            <label for="OpeningTime">Opening Time</label>
                            <input type="time" id="OpeningTime" name="OpeningTime" value="@(Model?.OpeningTime ?? "07:00")" required />
                        </div>

                        <div class="form-group">
                            <label for="ClosingTime">Closing Time</label>
                            <input type="time" id="ClosingTime" name="ClosingTime" value="@(Model?.ClosingTime ?? "21:00")" required />
                        </div>

                        <div class="form-group full-width toggle-group">
                            <label class="toggle-label" for="IsTemporarilyClosed">
                                <input type="checkbox" id="IsTemporarilyClosed" name="IsTemporarilyClosed" value="true" checked="@(Model?.IsTemporarilyClosed == true)" />
                                <span>Mark store as temporarily closed</span>
                            </label>
                            <p class="card-desc">Turn this on for holidays, emergencies, or any day you're closed outside your regular schedule. This overrides the hours above until you turn it back off.</p>
                        </div>
                    </div>
                </div>

                </fieldset>

                <!-- ACTIONS -->
                <div class="form-actions">
                    @if (canEdit)
                    {
                        <button type="button" class="btn-secondary" onclick="window.location.reload();">Discard Changes</button>
                        <button type="submit" class="btn-primary">Save Settings</button>
                    }
                    else
                    {
                        <p class="read-only-note">Only Admins and Managers can change these settings.</p>
                    }
                </div>

            </form>
        </main>
    </div>

    <!-- Live Preview & Interaction Scripts -->
    <script>
        function confirmLogout() {
        Swal.fire({
        title: 'Are you sure?',
        text: "You will be logged out of your session.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Yes, log out',
        cancelButtonText: 'Cancel'
        }).then((result) => {
        if (result.isConfirmed) {
        document.getElementById('logoutForm').submit();
        }
        });
        }

        const root = document.documentElement;

        document.getElementById('PrimaryColor').addEventListener('input', (e) => {
        root.style.setProperty('--primary-color', e.target.value);
        });
        document.getElementById('SidebarColor').addEventListener('input', (e) => {
        root.style.setProperty('--sidebar-bg', e.target.value);
        });
        document.getElementById('AccentColor').addEventListener('input', (e) => {
        root.style.setProperty('--accent-color', e.target.value);
        });
        document.getElementById('BackgroundColor').addEventListener('input', (e) => {
        root.style.setProperty('--main-bg', e.target.value);
        });
        document.getElementById('SidebarPosition').addEventListener('change', (e) => {
        document.getElementById('dashboardContainer').style.flexDirection = e.target.value === 'right' ? 'row-reverse' : 'row';
        });

        // Safe toggle logic for mobile sidebar
        function toggleSidebar() {
        const sidebar = document.querySelector('.sidebar');
        const overlay = document.querySelector('.sidebar-overlay');

        if (sidebar) {
        sidebar.classList.toggle('mobile-open');
        }
        if (overlay) {
        overlay.classList.toggle('mobile-open');
        }
        }

        // Close sidebar when clicking outside on mobile devices
        document.addEventListener('click', function (event) {
        const sidebar = document.querySelector('.sidebar');
        const hamburger = document.querySelector('.hamburger-btn');

        if (sidebar && hamburger) {
        if (sidebar.classList.contains('mobile-open') &&
        !sidebar.contains(event.target) &&
        !hamburger.contains(event.target)) {

        sidebar.classList.remove('mobile-open');
        }
        }
        });
    </script>
</body>
</html>