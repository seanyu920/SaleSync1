@model SaleSync.Models.WebCustomization
@{
    Layout = null;
    string displayRole = User.IsInRole("Manager") ? "Manager" : "Admin";
    string homeController = User.IsInRole("Manager") ? "Manager" : "Admin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Web Customization - SyncScale</title>
    <link rel="stylesheet" href="~/css/Inventory.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/WebCustomization.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <!-- Runtime Database Token Mappings Only -->
    <style id="theme-styles">
            :root {
                --primary-color: @(Model?.PrimaryColor ?? "var(--gold)");
                --sidebar-bg: @(Model?.SidebarColor ?? "var(--bg-surface)");
                --accent-color: @(Model?.AccentColor ?? "var(--gold)");
                --main-bg: @(Model?.BackgroundColor ?? "var(--bg-base)");
            }

            .dashboard-container {
                display: flex;
                flex-direction: @(Model?.SidebarPosition == "right" ? "row-reverse" : "row");
            }
    </style>
</head>
<body>
    <div class="dashboard-container" id="dashboardContainer">
        <!-- SIDEBAR PANEL -->
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">@Html.Raw(Model?.StoreName ?? "Cafero")</div>
                    <div class="logo-subtitle">@Html.Raw(Model?.StoreTagline ?? "Coffee & Pastries")</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <h2 class="admin-name">@displayRole</h2>
                        <div class="admin-role">@displayRole Panel</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="/@homeController/Dashboard" class="menu-btn"><i class="fas fa-chart-line"></i> Dashboard</a>
                    <a href="/Admin/QueueOrder" class="menu-btn"><i class="fas fa-list-ol"></i> Queue</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ActivityLog" class="menu-btn"><i class="fas fa-clipboard-list"></i> Activity Log</a>
                    }

                    <a href="/@homeController/Analytics" class="menu-btn"><i class="fas fa-chart-pie"></i> Analytics</a>

                    <a href="/@homeController/Products" class="menu-btn"><i class="fas fa-tags"></i> Products</a>
                    <a href="/@homeController/Inventory" class="menu-btn"><i class="fas fa-box-open"></i> Inventory</a>
                    <a href="/@homeController/ArchivedProducts" class="menu-btn"><i class="fas fa-archive"></i> Archive</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ManageAccounts" class="menu-btn"><i class="fas fa-credit-card"></i> Accounts</a>
                    }

                    <a href="/@homeController/WebCustomization" class="menu-btn active"><i class="fas fa-sliders-h"></i> Customization</a>
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn">
                        <i class="fas fa-sign-out-alt"></i> Log Out
                    </button>
                </form>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="main-content">
            <div class="settings-header">
                <h2>Web Customization & Theme <i class="fas fa-sliders-h"></i></h2>
                <p>Manage application branding, receipt headers, and live UI layout properties.</p>
            </div>

            <form asp-action="UpdateSettings" method="post" enctype="multipart/form-data" class="settings-form">

                <!-- SECTION 1: WEB THEME DESIGN -->
                <div class="settings-card">
                    <div class="card-icon"><i class="fas fa-palette"></i></div>
                    <h3>Application Web Theme</h3>
                    <p class="card-desc">Change the web application colors and layout interface positions.</p>

                    <div class="form-grid">
                        <div class="form-group">
                            <label for="PrimaryColor">Primary Highlights (Buttons, Selected Tabs)</label>
                            <input type="color" id="PrimaryColor" name="PrimaryColor" value="@(Model?.PrimaryColor ?? "#C9A84C")" class="color-picker-input" />
                        </div>

                        <div class="form-group">
                            <label for="SidebarColor">Sidebar Panel Background</label>
                            <input type="color" id="SidebarColor" name="SidebarColor" value="@(Model?.SidebarColor ?? "#141A14")" class="color-picker-input" />
                        </div>

                        <div class="form-group">
                            <label for="AccentColor">Icons & Detailed Flourishes</label>
                            <input type="color" id="AccentColor" name="AccentColor" value="@(Model?.AccentColor ?? "#C9A84C")" class="color-picker-input" />
                        </div>

                        <div class="form-group">
                            <label for="BackgroundColor">Main Application Window Background</label>
                            <input type="color" id="BackgroundColor" name="BackgroundColor" value="@(Model?.BackgroundColor ?? "#0D110D")" class="color-picker-input" />
                        </div>

                        <div class="form-group full-width">
                            <label for="SidebarPosition">Sidebar Window Dock Alignment</label>
                            <select id="SidebarPosition" name="SidebarPosition" class="select-dropdown">
                                <option value="left" selected="@(Model?.SidebarPosition == "left")">Left-aligned (Default)</option>
                                <option value="right" selected="@(Model?.SidebarPosition == "right")">Right-aligned</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- SECTION 2: STORE BRANDING -->
                <div class="settings-card">
                    <div class="card-icon"><i class="fas fa-store"></i></div>
                    <h3>Store Branding</h3>
                    <p class="card-desc">Change the identity headers that appear on your menus and login screens.</p>

                    <div class="form-grid">
                        <div class="form-group">
                            <label for="StoreName">Store Name</label>
                            <input type="text" id="StoreName" name="StoreName" value="@(Model?.StoreName)" placeholder="e.g., Cafero" required />
                        </div>

                        <div class="form-group">
                            <label for="StoreTagline">Store Tagline / Subtitle</label>
                            <input type="text" id="StoreTagline" name="StoreTagline" value="@(Model?.StoreTagline)" placeholder="e.g., Coffee & Pastries" />
                        </div>

                        <div class="form-group full-width">
                            <label for="StoreLogo">Upload Logo (Replaces default icons)</label>
                            <div class="file-upload-wrapper">
                                <input type="file" id="StoreLogo" name="StoreLogo" accept="image/*" />
                                <div class="file-upload-btn"><i class="fas fa-cloud-upload-alt"></i> Choose Image...</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SECTION 3: RECEIPT CUSTOMIZATION -->
                <div class="settings-card">
                    <div class="card-icon"><i class="fas fa-receipt"></i></div>
                    <h3>Receipt Customization</h3>
                    <p class="card-desc">Configure information printed at the top and bottom of your POS receipts.</p>

                    <div class="form-grid">
                        <div class="form-group">
                            <label for="BusinessAddress">Business Address</label>
                            <input type="text" id="BusinessAddress" name="BusinessAddress" value="@(Model?.BusinessAddress)" placeholder="123 Main St, Manila" />
                        </div>

                        <div class="form-group">
                            <label for="ContactNumber">Contact Number</label>
                            <input type="text" id="ContactNumber" name="ContactNumber" value="@(Model?.ContactNumber)" placeholder="0917-XXXX-XXX" />
                        </div>

                        <div class="form-group">
                            <label for="TaxIdNumber">TIN (Tax Identification Number)</label>
                            <input type="text" id="TaxIdNumber" name="TaxIdNumber" value="@(Model?.TaxIdNumber)" placeholder="XXX-XXX-XXX-000" />
                        </div>

                        <div class="form-group">
                            <label for="ReceiptFooter">Receipt Footer Message</label>
                            <input type="text" id="ReceiptFooter" name="ReceiptFooter" value="@(Model?.ReceiptFooter)" placeholder="Thank you, come again!" />
                        </div>
                    </div>
                </div>

                <!-- SECTION 4: POS SYSTEM DEFAULTS -->
                <div class="settings-card">
                    <div class="card-icon"><i class="fas fa-cogs"></i></div>
                    <h3>POS & System Defaults</h3>
                    <p class="card-desc">Set regional currencies, tax baselines, and database threshold alerts.</p>

                    <div class="form-grid">
                        <div class="form-group-triple">
                            <div class="form-group">
                                <label for="CurrencySymbol">Currency Symbol</label>
                                <input type="text" id="CurrencySymbol" name="CurrencySymbol" value="@(Model?.CurrencySymbol)" max="3" placeholder="₱" required />
                            </div>

                            <div class="form-group">
                                <label for="VatRate">VAT Rate (%)</label>
                                <input type="number" step="0.01" id="VatRate" name="VatRate" value="@(Model?.VatRate)" placeholder="12" required />
                            </div>

                            <div class="form-group">
                                <label for="LowStockThreshold">Low Stock Alert Level</label>
                                <input type="number" id="LowStockThreshold" name="LowStockThreshold" value="@(Model?.LowStockThreshold)" placeholder="10" required />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ACTIONS -->
                <div class="form-actions">
                    <button type="button" class="btn-secondary" onclick="window.location.reload();">Discard Changes</button>
                    <button type="submit" class="btn-primary">Save Settings</button>
                </div>

            </form>
        </main>
    </div>

    <!-- Live Preview Script -->
    <script>
            const root = document.documentElement;

            document.getElementById('PrimaryColor').addEventListener('input', (e) => {
                root.style.setProperty('--primary-color', e.target.value);
            });
            document.getElementById('SidebarColor').addEventListener('input', (e) => {
                root.style.setProperty('--sidebar-bg', e.target.value);
            });
            document.getElementById('AccentColor').addEventListener('input', (e) => {
                root.style.setProperty('--accent-color', e.target.value);
            });
            document.getElementById('BackgroundColor').addEventListener('input', (e) => {
                root.style.setProperty('--main-bg', e.target.value);
            });
            document.getElementById('SidebarPosition').addEventListener('change', (e) => {
                document.getElementById('dashboardContainer').style.flexDirection = e.target.value === 'right' ? 'row-reverse' : 'row';
            });
    </script>
</body>
</html>