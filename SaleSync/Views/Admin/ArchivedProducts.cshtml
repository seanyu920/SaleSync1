@model SaleSync.Models.ArchiveViewModel
@{
    Layout = null;
    bool isManager = User.IsInRole("Manager");
    string homeController = isManager ? "Manager" : "Admin";
    string displayRole = isManager ? "Manager" : "Admin";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>System Archive - SyncScale</title>

    <!-- FontAwesome Library for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Products.css" asp-append-version="true" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* Custom Table Styling overrides to align nicely with the unified CSS structure */
        .archive-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        background: var(--bg-surface);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 10px;
        }

        .archive-table th {
        background: #4a2511;
        color: #fff;
        padding: 14px 18px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        }

        .archive-table td {
        padding: 14px 18px;
        border-bottom: 1px solid var(--border-sub);
        color: var(--cream);
        font-size: 14px;
        }

        .restore-btn {
        background: #d1fae5;
        color: #065f46;
        border: none;
        padding: 8px 16px;
        border-radius: 8px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s ease;
        font-family: 'Outfit', sans-serif;
        }

        .restore-btn:hover {
        background: #a7f3d0;
        transform: translateY(-1px);
        }

        .table-card-wrapper {
        background: var(--bg-surface);
        border: 1px solid var(--border-sub);
        border-radius: 14px;
        padding: 8px;
        box-shadow: var(--shadow-sm);
        margin-bottom: 40px;
        }

        .section-divider-title {
        font-size: 18px;
        font-weight: 700;
        color: var(--gold);
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
        }
    </style>
</head>
<body>
    <div class="dashboard-container">

        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">Cafero</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <h2 class="admin-name">@(User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? User.Identity?.Name ?? "User")</h2>
                        <div class="admin-role">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="/@homeController/Dashboard" class="menu-btn @(currentAction == "Dashboard" ? "active" : "")">
                        Dashboard
                    </a>
                    <a href="/Admin/QueueOrder" class="menu-btn @(currentAction == "QueueOrder" ? "active" : "")">Queue</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ActivityLog" class="menu-btn @(currentAction == "ActivityLog" ? "active" : "")">
                            Activity Log
                        </a>
                    }

                    <a href="/Admin/Analytics" class="menu-btn @(currentAction == "Analytics" ? "active" : "")">
                        Analytics
                    </a>

                    <a href="/Admin/Products" class="menu-btn @(currentAction == "Products" ? "active" : "")">
                        Products
                    </a>

                    <a href="/Admin/Inventory" class="menu-btn @(currentAction == "Inventory" ? "active" : "")">
                        Inventory
                    </a>

                    <a href="/Admin/ArchivedProducts" class="menu-btn @(currentAction == "ArchivedProducts" || currentAction == "Archive" ? "active" : "")">
                        Archived
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ManageAccounts" class="menu-btn @(currentAction == "ManageAccounts" ? "active" : "")">
                            Accounts
                        </a>
                    }
                    <a href="/Admin/WebCustomization" class="menu-btn @(currentAction == "WebCustomization" ? "active" : "")">Customization</a>
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout" id="logoutForm">
                    <button type="button" class="menu-btn logout-btn" onclick="confirmLogout()">
                        Log Out
                    </button>
                </form>
            </div>
        </aside>

        <div class="mobile-header">
            <button class="hamburger-btn" onclick="toggleSidebar()">
                <i class="fas fa-bars"></i>
            </button>
            <div class="mobile-brand">Cafero</div>
        </div>

        <main class="main-content slide-up">
            <div class="card-header-flex" style="align-items: flex-end; margin-bottom: 30px;">
                <div>
                    <h1 class="greeting-title" style="font-size: 22px; font-weight: 800; letter-spacing: -0.5px;">
                        System Archives
                    </h1>
                    <p class="widget-subtitle">Completely isolated data states. Restore layers to bring them back to live POS tracking or stock calculations.</p>
                </div>
            </div>

            <h2 class="section-divider-title">Archived Menu Items</h2>
            <div class="table-card-wrapper">
                <table class="archive-table">
                    <thead>
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th>Category</th>
                            <th>Product Name</th>
                            <th>Historical Price</th>
                            <th>System State</th>
                            <th style="text-align: center; width: 140px;">Action Lifecycle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ArchivedProducts != null && Model.ArchivedProducts.Any())
                        {
                            foreach (var item in Model.ArchivedProducts)
                            {
                                var safeName = System.Web.HttpUtility.JavaScriptStringEncode(item.ProductName);

                                <tr class="inventory-row">
                                    <td><strong style="color: var(--gold); font-family: 'Outfit';">#@item.ProductId</strong></td>
                                    <td><span style="font-size: 11px; text-transform: uppercase; background: var(--border-sub); padding: 4px 8px; border-radius: 4px; font-weight: 600;">@item.CategoryName</span></td>
                                    <td style="color: var(--cream); font-weight: 500;">@item.ProductName</td>
                                    <td style="font-weight: 600; color: var(--gold-light);">₱@item.Price.ToString("0.00")</td>
                                    <td>
                                        <span style="background: rgba(239, 68, 68, 0.15); color: #ef4444; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: bold; border: 1px solid rgba(239, 68, 68, 0.25);">Archived</span>
                                    </td>
                                    <td style="text-align: center;">
                                        <button type="button" class="restore-btn" onclick="restoreProduct(@item.ProductId, '@safeName')">
                                            Restore
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" style="text-align:center; padding: 48px; color: var(--muted); font-size: 14px;">
                                    No isolated product lines currently matching archive parameters.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <h2 class="section-divider-title">Archived Inventory Ingredients</h2>
            <div class="table-card-wrapper">
                <table class="archive-table">
                    <thead>
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th>Class</th>
                            <th>Ingredient Name</th>
                            <th>Last Unit Cost</th>
                            <th>Remaining Volume</th>
                            <th style="text-align: center; width: 140px;">Action Lifecycle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ArchivedIngredients != null && Model.ArchivedIngredients.Any())
                        {
                            foreach (var item in Model.ArchivedIngredients)
                            {
                                var safeName = System.Web.HttpUtility.JavaScriptStringEncode(item.ItemName);

                                <tr class="inventory-row">
                                    <td><strong style="color: var(--gold); font-family: 'Outfit';">#@item.ProductId</strong></td>
                                    <td><span style="font-size: 11px; text-transform: uppercase; background: var(--border-sub); padding: 4px 8px; border-radius: 4px; font-weight: 600; color: #b45309;">@item.ItemCategory</span></td>
                                    <td style="color: var(--cream); font-weight: 500;">@item.ItemName</td>
                                    <td style="font-weight: 600; color: var(--gold-light);">₱@item.PurchasePrice.ToString("0.00")</td>
                                    <td style="font-weight: 700;">@item.Quantity.ToString("0.##") @item.Unit</td>
                                    <td style="text-align: center;">
                                        <button type="button" class="restore-btn" onclick="restoreIngredient(@item.ProductId, '@safeName')">
                                            Restore
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" style="text-align:center; padding: 48px; color: var(--muted); font-size: 14px;">
                                    No ingredient profiles or recipes locked in the historical archive.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script>
        function confirmLogout() {
        Swal.fire({
        title: 'Are you sure?',
        text: "You will be logged out of your session.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Yes, log out',
        cancelButtonText: 'Cancel'
        }).then((result) => {
        if (result.isConfirmed) {
        document.getElementById('logoutForm').submit();
        }
        });
        }

        function restoreProduct(id, name) {
        Swal.fire({
        title: 'Restore Product Layer?',
        text: `Commiting sequence will push "${name}" back into active POS listings context.`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#0b8a53',
        cancelButtonColor: '#4a2511',
        confirmButtonText: 'Yes, restore active tracking'
        }).then((result) => {
        if (result.isConfirmed) {
        fetch('/Admin/RestoreMenuItem', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(id)
        }).then(res => {
        if(res.ok) {
        Swal.fire({
        title: 'Database Restored',
        text: `${name} state updated back to active array tracking loop.`,
        icon: 'success',
        timer: 1500,
        showConfirmButton: false
        }).then(() => location.reload());
        } else {
        Swal.fire('Database Drop Error', 'The remote instance dropped the operation update payload.', 'error');
        }
        });
        }
        });
        }

        function restoreIngredient(id, name) {
        Swal.fire({
        title: 'Restore Inventory Stock Profile?',
        text: `Returning "${name}" will map its calculations back into active stock levels and recipe deductions.`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#0b8a53',
        cancelButtonColor: '#4a2511',
        confirmButtonText: 'Yes, restore stock line'
        }).then((result) => {
        if (result.isConfirmed) {
        fetch('/Admin/RestoreInventoryItem', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(id)
        }).then(res => {
        if(res.ok) {
        Swal.fire({
        title: 'Stock Line Restored',
        text: `${name} is back in operational matrices.`,
        icon: 'success',
        timer: 1500,
        showConfirmButton: false
        }).then(() => location.reload());
        } else {
        Swal.fire('Database Update Error', 'Failed to update ingredient status tracking states.', 'error');
        }
        });
        }
        });
        }

        // Safe toggle logic for mobile sidebar
        function toggleSidebar() {
        const sidebar = document.querySelector('.sidebar');
        const overlay = document.querySelector('.sidebar-overlay');

        if (sidebar) {
        sidebar.classList.toggle('mobile-open');
        }
        if (overlay) {
        overlay.classList.toggle('mobile-open');
        }
        }

        // Close sidebar when clicking outside on mobile screen
        document.addEventListener('click', function (event) {
        const sidebar = document.querySelector('.sidebar');
        const hamburger = document.querySelector('.hamburger-btn');

        if (sidebar && hamburger) {
        if (sidebar.classList.contains('mobile-open') &&
        !sidebar.contains(event.target) &&
        !hamburger.contains(event.target)) {

        sidebar.classList.remove('mobile-open');
        }
        }
        });
    </script>
</body>
</html>