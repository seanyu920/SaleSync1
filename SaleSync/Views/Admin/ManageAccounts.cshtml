@model List<SaleSync.Models.UserAccount>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Manage Accounts - SyncScale</title>
    <link rel="stylesheet" href="~/css/ManageAccounts.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-container">

        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title">SyncScale</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <div class="admin-name">Admin</div>
                        <div class="admin-role">Administrator</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a asp-controller="Admin" asp-action="Dashboard" class="menu-btn">❖ Dashboard</a>
                    <a asp-controller="Admin" asp-action="Analytics" class="menu-btn">📊 Analytics</a>
                    
                    <a asp-controller="Admin" asp-action="Products" class="menu-btn">🏷️ Products</a>
                    
                    <a asp-controller="Admin" asp-action="Inventory" class="menu-btn">📦 Inventory</a>
                    <a asp-controller="Admin" asp-action="ManageAccounts" class="menu-btn active">💳 Accounts</a>
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn">⎋ Log Out</button>
                </form>
            </div>
        </aside>

        <main class="main-content">

            <div class="page-header">
                <h1 class="greeting-title">User Accounts 💳</h1>
                <p class="greeting-subtitle">Add, update, or remove system access.</p>
            </div>

            <div class="accounts-content">
                
                <div class="form-card">
                    <h2 class="widget-title">Account Details</h2>

                    <form id="accountForm" method="post" class="account-form">
                        <input type="hidden" id="UserId" name="UserId" />

                        <div class="form-grid">
                            <div class="input-group">
                                <label for="FullName">Full Name</label>
                                <input id="FullName" name="FullName" type="text" placeholder="e.g. Jane Doe" required />
                            </div>

                            <div class="input-group">
                                <label for="Username">Username</label>
                                <input id="Username" name="Username" type="text" placeholder="Username" required />
                            </div>

                            <div class="input-group">
                                <label for="Email">Email Address</label>
                                <input id="Email" name="Email" type="email" placeholder="name@email.com" required />
                            </div>

                            <div class="input-group">
                                <label for="Password">Password</label>
                                <input id="Password" name="Password" type="password" placeholder="••••••••" required />
                            </div>

                            <div class="input-group">
                                <label for="Role">System Role</label>
                                <select id="Role" name="Role" required>
                                    <option value="" disabled selected>Select Role...</option>
                                    <option value="Admin">Admin</option>
                                    <option value="Manager">Manager</option>
                                    <option value="Cashier">Cashier</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-actions-row">
                            <button type="submit" formaction="/Admin/UpdateAccount" class="btn update-btn">Update Selected</button>
                            <button type="submit" formaction="/Admin/DeleteAccount" class="btn delete-btn" onclick="return prepareDelete();">Delete Selected</button>
                            <button type="submit" formaction="/Admin/AddAccount" class="btn save-btn">+ Add Account</button>
                        </div>
                    </form>
                </div>

                <div class="table-card">
                    <h2 class="widget-title">Active Directory</h2>
                    <div class="table-wrap">
                        <table class="accounts-table">
                            <thead>
                                <tr>
                                    <th>Full Name</th>
                                    <th>Username</th>
                                    <th>Email</th>
                                    <th>Password</th>
                                    <th>Role</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Count > 0)
                                {
                                    foreach (var user in Model)
                                    {
                                        <tr class="clickable-row"
                                            onclick="selectUser('@user.UserId', '@user.FullName', '@user.Username', '@user.Email', '@user.Password', '@user.Role')">
                                            <td><strong>@user.FullName</strong></td>
                                            <td>@user.Username</td>
                                            <td>@user.Email</td>
                                            <td style="color: #b58361;">••••••••</td>
                                            <td>
                                                @{
                                                    string badgeClass = user.Role == "Admin" ? "role-admin" : (user.Role == "Manager" ? "role-manager" : "role-cashier");
                                                }
                                                <span class="role-badge @badgeClass">@user.Role</span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" style="text-align: center; padding: 40px; color: #b58361;">No accounts found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
            function selectUser(userId, fullName, username, email, password, role) {
                document.getElementById('UserId').value = userId;
                document.getElementById('FullName').value = fullName;
                document.getElementById('Username').value = username;
                document.getElementById('Email').value = email;
                document.getElementById('Password').value = password;
                document.getElementById('Role').value = role;
            }

            function prepareDelete() {
                const userId = document.getElementById('UserId').value;
                if (!userId) {
                    alert('Please select an account from the table first.');
                    return false;
                }
                return confirm('Are you sure you want to permanently delete this account?');
            }
    </script></body>
</html>