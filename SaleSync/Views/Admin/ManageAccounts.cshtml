@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Manage Accounts</title>
    <link rel="stylesheet" href="~/css/Inventory.css" asp-append-version="true" />
</head>
<body>

    <div class="inventory-container">
        <h1 class="page-title">Manage Accounts</h1>

        <!-- NAV -->
        <div class="top-nav">
            <a href="/Admin/Dashboard" class="nav-btn">Analytics</a>
            <a href="/Admin/Inventory" class="nav-btn">Inventory</a>
            
        </div>

        <!-- FORM ONLY -->
        <div class="form-card" style="max-width:600px; margin:auto;">
            <form class="add-form" style="grid-template-columns: 1fr;">
                
                <input placeholder="Full Name"/>
                <input placeholder="Username" />
                <input placeholder="Email" />
                <input placeholder="Password" type="password" />
                <select name="Role" required>
                    <option value="">Select Role</option>
                    <option value="Admin">Admin</option>
                    <option value="Manager">Manager</option>
                    <option value="Cashier">Cashier</option>
                </select>

                <button type="button" class="add-btn">Save Account</button>

            </form>
        </div>

        <div class="action-bar">
            <button class="btn update-btn">Update</button>
            <button class="btn delete-btn">Delete</button>
        </div>

        <!-- TABLE -->
        <div class="table-card" style="max-width:1100px; margin:auto;">
            <table class="inventory-table">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Password</th>
                        <th>Role</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.Name</td>
                                <td>@user.Username</td>
                                <td>@user.Email</td>
                                <td>@user.Password</td>
                                <td>@user.Role</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">No accounts found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
    <form method="get" action="/Admin/Logout">
        <button type="submit">Logout</button>
    </form>
</body>
</html>