@model List<SaleSync.Models.UserAccount>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Manage Accounts</title>
    <link rel="stylesheet" href="~/css/ManageAccounts.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-container">

        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <img src="~/images/syncsale-logo.png" alt="SyncSale Logo" class="logo-img" />
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <h2 class="admin-name">Admin</h2>
                </div>

                <nav class="sidebar-menu">
                    <a asp-controller="Admin" asp-action="Dashboard" class="menu-btn">Analysis</a>
                    <a asp-controller="Admin" asp-action="Inventory" class="menu-btn">Inventory</a>
                    <a asp-controller="Admin" asp-action="ManageAccounts" class="menu-btn active">Accounts</a>
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn">Log Out</button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            <div class="top-bar">
                <a asp-controller="Admin" asp-action="ManageAccounts" class="accounts-btn">Accounts</a>
            </div>

            <div class="accounts-content">
                <div class="action-bar">
                    <button type="submit" form="accountForm" formaction="/Admin/UpdateAccount" class="btn update-btn">Update</button>
                    <button type="submit" form="accountForm" formaction="/Admin/DeleteAccount" class="btn delete-btn" onclick="return prepareDelete();">Delete</button>
                </div>

                <div class="form-card">
                    <h1 class="form-title">Manage Accounts</h1>

                    <form id="accountForm" method="post" class="account-form">
                        <input type="hidden" id="UserId" name="UserId" />

                        <div class="form-grid">
                            <input id="FullName" name="FullName" type="text" placeholder="Full Name" required />
                            <input id="Username" name="Username" type="text" placeholder="Username" required />
                            <input id="Email" name="Email" type="email" placeholder="Email" required />
                            <input id="Password" name="Password" type="password" placeholder="Password" required />

                            <select id="Role" name="Role" required>
                                <option value="">Select Role</option>
                                <option value="Admin">Admin</option>
                                <option value="Manager">Manager</option>
                                <option value="Cashier">Cashier</option>
                            </select>

                            <button type="submit" formaction="/Admin/SaveAccount" class="save-btn">Save Account</button>
                        </div>
                    </form>
                </div>

                <div class="table-card">
                    <div class="table-wrap">
                        <table class="accounts-table">
                            <thead>
                                <tr>
                                    <th>Full Name</th>
                                    <th>Username</th>
                                    <th>Email</th>
                                    <th>Password</th>
                                    <th>Role</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Count > 0)
                                {
                                    foreach (var user in Model)
                                    {
                                        <tr class="clickable-row"
                                            onclick="selectUser('@user.UserId', '@user.FullName', '@user.Username', '@user.Email', '@user.Password', '@user.Role')">
                                            <td>@user.FullName</td>
                                            <td>@user.Username</td>
                                            <td>@user.Email</td>
                                            <td>@user.Password</td>
                                            <td>@user.Role</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5">No accounts found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
            function selectUser(userId, fullName, username, email, password, role) {
                document.getElementById('UserId').value = userId;
                document.getElementById('FullName').value = fullName;
                document.getElementById('Username').value = username;
                document.getElementById('Email').value = email;
                document.getElementById('Password').value = password;
                document.getElementById('Role').value = role;
            }

            function prepareDelete() {
                const userId = document.getElementById('UserId').value;
                if (!userId) {
                    alert('Please select an account first.');
                    return false;
                }
                return confirm('Are you sure you want to delete this account?');
            }
    </script>
</body>
</html>