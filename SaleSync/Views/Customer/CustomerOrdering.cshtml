@model List<SaleSync.Models.MenuItemModel>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Order Now | Cafero</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/CustomerOrdering.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div class="dashboard-container">

        <!-- ===== SIDEBAR ===== -->
        <aside class="sidebar">
            <div class="sidebar-top">

                <!-- Logo -->
                <div class="logo-section">
                    <div class="brand-name">Cafero</div>
                    <div class="brand-sub">Coffee & Pastries</div>
                </div>

                <!-- Store status banner -->
                <div class="store-status-banner" id="storeBanner">
                    <span class="store-dot"></span>
                    <span id="storeStatusText">We're Open</span>
                </div>

                <!-- Tab switcher -->
                <div class="sidebar-tabs">
                    <button class="tab-btn active" onclick="switchTab('menu', this)">🍽️ Order</button>
                    <button class="tab-btn" onclick="switchTab('orders', this)">📦 My Orders</button>
                </div>

                <!-- Category nav (shown on menu tab) -->
                <div id="catNav">
                    <p class="sidebar-section-label">Categories</p>
                    <nav class="sidebar-menu">
                        <button class="menu-btn cat-btn active" onclick="filterMenu('all', this)">All Items</button>
                        <button class="menu-btn cat-btn" onclick="filterMenu('coffee', this)">☕ Coffee</button>
                        <button class="menu-btn cat-btn" onclick="filterMenu('milktea', this)">🧋 Milktea</button>
                        <button class="menu-btn cat-btn" onclick="filterMenu('fruittea', this)">🍹 Fruit Tea</button>
                        <button class="menu-btn cat-btn" onclick="filterMenu('ricemeal', this)">🍱 Rice Meals</button>
                        <button class="menu-btn cat-btn" onclick="filterMenu('bread&pastry', this)">🥐 Bread & Pastry</button>
                        <button class="menu-btn cat-btn" onclick="filterMenu('snacks&pasta', this)">🍝 Snacks & Pasta</button>
                        <button class="menu-btn cat-btn fav-btn" onclick="filterMenu('favorites', this)">❤️ My Favorites</button>
                    </nav>
                </div>

                <!-- Loyalty points -->
                <div class="loyalty-box" id="loyaltyBox">
                    <div class="loyalty-header">
                        <span>⭐ Loyalty Points</span>
                        <strong id="loyaltyPoints">0 pts</strong>
                    </div>
                    <div class="loyalty-bar-bg">
                        <div class="loyalty-bar-fill" id="loyaltyBarFill" style="width:0%"></div>
                    </div>
                    <p class="loyalty-hint" id="loyaltyHint">Earn points on every order!</p>
                </div>
            </div>

            <div class="logout-section">
                <a href="/Home/Logout" class="menu-btn logout-btn">🚪 Log Out</a>
            </div>
        </aside>

        <!-- ===== MAIN CONTENT ===== -->
        <main class="main-content slide-up">

            <!-- Announcement banner -->
            <div class="announcement-banner" id="announcementBanner">
                🎉 <strong>Welcome to Cafero!</strong> Free delivery on orders ₱300+
                <button class="close-announcement" onclick="this.parentElement.style.display='none'">✕</button>
            </div>

            <!-- ── TAB 1: MENU ── -->
            <div id="tabMenu">
                <header class="pos-header">
                    <div>
                        <h1>Place an Order</h1>
                        <p>Handcrafted beverages and meals made with love</p>
                    </div>
                    <div class="header-actions">
                        <div class="search-container">
                            <span class="search-icon">🔍</span>
                            <input type="text" id="menuSearch" placeholder="Search menu items..." onkeyup="filterMenu()">
                        </div>
                        <button class="cart-icon-btn" onclick="toggleCart()">
                            🛒
                            <span class="cart-badge" id="cartBadge" style="display:none;">0</span>
                        </button>
                    </div>
                </header>

                <div class="product-container" id="menuGrid" data-current-cat="all">
                    @if (Model != null && Model.Count > 0)
                    {
                        // Best seller list — customize as needed
                        var bestSellers = new[] { "Americano - Small", "Spanish Latte", "Iced Latte", "Wintermelon", "Carbonara" };
                        var newItems = new[] { "Hot Matcha Latte", "Iced Matcha Latte", "Gambas Pasta" };

                        foreach (var item in Model)
                        {
                            string catRaw = (item.CategoryName ?? "Uncategorized").ToLower().Replace(" ", "");
                            bool isBest = bestSellers.Contains(item.ProductName);
                            bool isNew = newItems.Contains(item.ProductName);
                            string badgeHtml = isBest ? "<span class='item-badge badge-best'>🔥 Best Seller</span>"
                                             : isNew ? "<span class='item-badge badge-new'>✨ New</span>"
                                             : "";

                            <div class="product-card"
                                 data-category="@catRaw"
                                 data-name="@item.ProductName.ToLower()"
                                 data-id="@item.ProductId"
                                 data-price="@item.Price">
                                @Html.Raw(badgeHtml)
                                <button class="fav-heart" onclick="toggleFav(this, '@item.ProductId')" title="Add to favorites">♡</button>
                                <div class="product-img-placeholder">
                                    <span class="product-img-emoji">@GetCategoryEmoji(item.CategoryName)</span>
                                </div>
                                <div class="product-info">
                                    <div class="info-top">
                                        <h3>@item.ProductName</h3>
                                        <span class="price">₱@item.Price.ToString("0.##")</span>
                                    </div>
                                    <p class="description">Freshly prepared @item.ProductName.</p>
                                    <button class="btn-add-order"
                                            onclick="openModal('@item.ProductId','@Html.Raw(item.ProductName.Replace("'", "\\'"))','@item.Price')">
                                        + Add to Order
                                    </button>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="no-items-fallback"><p>No menu items found.</p></div>
                    }
                </div>
            </div>

            <!-- ── TAB 2: MY ORDERS ── -->
            <div id="tabOrders" style="display:none;">
                <header class="pos-header">
                    <div>
                        <h1>My Orders</h1>
                        <p>Track your active orders and view past purchases</p>
                    </div>
                    <button class="refresh-btn" onclick="loadMyOrders()">↻ Refresh</button>
                </header>

                <!-- Active order tracker -->
                <div class="orders-section">
                    <h2 class="section-title">Active Orders</h2>
                    <div id="activeOrdersList">
                        <div class="empty-orders-msg">No active orders right now.</div>
                    </div>
                </div>

                <!-- Order history -->
                <div class="orders-section">
                    <h2 class="section-title">Order History</h2>
                    <div id="orderHistoryList">
                        <div class="empty-orders-msg">No past orders yet.</div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- ===== SIZE + NOTES MODAL ===== -->
    <div id="sizeModal" class="modal-overlay">
        <div class="modal-card">
            <div class="modal-header">
                <h2 id="modalItemName">Item Name</h2>
                <button class="close-modal" onclick="closeModal()">✕</button>
            </div>

            <div id="sizeSection">
                <p class="modal-label">Select Size</p>
                <div class="size-options">
                    <label class="size-box">
                        <input type="radio" name="itemSize" value="Small" checked>
                        <div class="size-content">
                            <span class="size-label">Small</span>
                            <span class="size-price-mod" id="smallPrice">₱0</span>
                        </div>
                    </label>
                    <label class="size-box">
                        <input type="radio" name="itemSize" value="Large">
                        <div class="size-content">
                            <span class="size-label">Large</span>
                            <span class="size-price-mod" id="largePrice">₱0</span>
                        </div>
                    </label>
                </div>
            </div>

            <p class="modal-label">Quantity</p>
            <div class="quantity-selector">
                <button type="button" class="qty-btn" onclick="updateQty(-1)">−</button>
                <input type="number" id="itemQty" value="1" min="1" readonly>
                <button type="button" class="qty-btn" onclick="updateQty(1)">+</button>
            </div>

            <!-- Special instructions -->
            <p class="modal-label">Special Instructions <span class="optional-tag">(Optional)</span></p>
            <textarea id="itemNotes" class="notes-textarea" placeholder="e.g. less sugar, no ice, extra hot..."></textarea>

            <button class="btn-confirm-add" onclick="confirmAddToCart()">Add to Cart</button>
        </div>
    </div>

    <!-- ===== CART SIDEBAR ===== -->
    <div id="cartSidebar" class="cart-sidebar">
        <div class="cart-header">
            <h2>🛒 Your Order</h2>
            <button class="close-cart-btn" onclick="toggleCart()">✕</button>
        </div>
        <div class="cart-items-container" id="customerCartList">
            <div class="empty-cart-msg">Your cart is empty.</div>
        </div>
        <div class="cart-footer">
            <div class="cart-total-row">
                <span>Total</span>
                <span id="customerCartTotal">₱0.00</span>
            </div>
            <div class="min-order-note" id="minOrderNote" style="display:none;">
                ⚠️ Minimum ₱200 for delivery
            </div>
            <select id="customerOrderType" class="cart-select" onchange="toggleAddressField()">
                <option value="Dine In">🍽️ Dine In</option>
                <option value="Pick-up">🛍️ Pick-up</option>
                <option value="Delivery">🚴 Delivery</option>
            </select>
            <div id="addressContainer" style="display:none;">
                <textarea id="customerAddress" class="cart-textarea" placeholder="Enter full delivery address..." rows="2"></textarea>
            </div>
            <select id="customerPaymentMethod" class="cart-select">
                <option value="Cash">💵 Pay at Counter (Cash)</option>
                <option value="GCash">🔵 GCash</option>
                <option value="Maya">🟢 Maya</option>
                <option value="Card">💳 Card</option>
            </select>
            <button class="btn-checkout" id="checkoutBtn" onclick="submitOnlineOrder()">
                Send Order to Kitchen
            </button>
        </div>
    </div>
<div id="cartOverlay" class="cart-overlay" onclick="toggleCart()"></div>

@functions {
    string GetCategoryEmoji(string category)
    {
        if (string.IsNullOrEmpty(category)) return "🍴";
        return category.ToLower() switch
        {
            var c when c.Contains("coffee") => "☕",
            var c when c.Contains("milk") => "🧋",
            var c when c.Contains("fruit") => "🍹",
            var c when c.Contains("rice") => "🍱",
            var c when c.Contains("bread") || c.Contains("pastry") => "🥐",
            var c when c.Contains("snack") || c.Contains("pasta") => "🍝",
            _ => "🍴"
        };
    }
}

<script>
    // ── DATA from Razor ────────────────────────────────────────────────────────
    const allItems = {};
    @if (Model != null)
    {
        foreach (var item in Model)
        {
            @:allItems[@item.ProductId] = {
            @:    id: @item.ProductId,
            @:    name: "@Html.Raw(item.ProductName.Replace("\"", "\\\"").Replace("'", "\\'"))",
            @:    price: @item.Price,
            @:    cat: "@Html.Raw((item.CategoryName ?? "").ToLower().Replace(" ", "").Replace("\"", "\\\""))"
            @:};
        }
    }

    // ── STATE ──────────────────────────────────────────────────────────────────
    let customerCart   = JSON.parse(localStorage.getItem('caferoCustomerCart')   || '[]');
    let favoriteIds    = JSON.parse(localStorage.getItem('caferoFavorites')      || '[]');
    let loyaltyPts     = parseInt(localStorage.getItem('caferoLoyaltyPoints')    || '0');
    let activeModalId  = null;
    let sizedCategories = ['coffee','milktea','fruittea'];

    // ── STORE STATUS ───────────────────────────────────────────────────────────
    function checkStoreStatus() {
    const now  = new Date();
    const hour = now.getHours();
    const open = hour >= 7 && hour < 21; // 7AM–9PM
    const banner = document.getElementById('storeBanner');
    const text   = document.getElementById('storeStatusText');
    if (open) {
    banner.classList.add('open');
    text.innerText = "We're Open · Closes 9PM";
    } else {
    banner.classList.remove('open');
    text.innerText = "We're Closed · Opens 7AM";
    }
    }

    // ── LOYALTY ────────────────────────────────────────────────────────────────
    function updateLoyaltyUI() {
    const goal = 500;
    document.getElementById('loyaltyPoints').innerText = loyaltyPts + ' pts';
    const pct = Math.min((loyaltyPts / goal) * 100, 100);
    document.getElementById('loyaltyBarFill').style.width = pct + '%';
    const remaining = goal - loyaltyPts;
    document.getElementById('loyaltyHint').innerText =
    loyaltyPts >= goal ? '🎁 You have a reward ready!'
    : `${remaining} pts until your next reward`;
    }

    // ── FAVORITES ─────────────────────────────────────────────────────────────
    function toggleFav(btn, itemId) {
    event.stopPropagation();
    const id  = String(itemId);
    const idx = favoriteIds.indexOf(id);
    if (idx > -1) {
    favoriteIds.splice(idx, 1);
    btn.innerText = '♡';
    btn.classList.remove('fav-active');
    } else {
    favoriteIds.push(id);
    btn.innerText = '❤️';
    btn.classList.add('fav-active');
    }
    localStorage.setItem('caferoFavorites', JSON.stringify(favoriteIds));
    if (document.getElementById('menuGrid').getAttribute('data-current-cat') === 'favorites') {
    filterMenu('favorites');
    }
    }

    function restoreFavHearts() {
    document.querySelectorAll('.product-card').forEach(card => {
    const id = card.getAttribute('data-id');
    if (favoriteIds.includes(String(id))) {
    const btn = card.querySelector('.fav-heart');
    if (btn) { btn.innerText = '❤️'; btn.classList.add('fav-active'); }
    }
    });
    }

    // ── TAB SWITCHER ──────────────────────────────────────────────────────────
    function switchTab(tab, btn) {
    document.getElementById('tabMenu').style.display   = tab === 'menu'   ? 'block' : 'none';
    document.getElementById('tabOrders').style.display = tab === 'orders' ? 'block' : 'none';
    document.getElementById('catNav').style.display    = tab === 'menu'   ? 'block' : 'none';
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    if (tab === 'orders') loadMyOrders();
    }

    // ── CART TOGGLE ───────────────────────────────────────────────────────────
    function toggleCart() {
    document.getElementById('cartSidebar').classList.toggle('open');
    document.getElementById('cartOverlay').classList.toggle('open');
    renderCustomerCart();
    }

    function toggleAddressField() {
    const v = document.getElementById('customerOrderType').value;
    document.getElementById('addressContainer').style.display  = v === 'Delivery' ? 'block' : 'none';
    document.getElementById('minOrderNote').style.display      = v === 'Delivery' ? 'block' : 'none';
    }

    // ── MODAL ─────────────────────────────────────────────────────────────────
    function openModal(itemId, itemName, basePrice) {
    activeModalId = parseInt(itemId);
    const price   = parseFloat(basePrice);
    const cat     = allItems[activeModalId]?.cat || '';
    const hasSizes = sizedCategories.some(c => cat.includes(c));

    document.getElementById('modalItemName').innerText = itemName;
    document.getElementById('sizeSection').style.display = hasSizes ? 'block' : 'none';
    document.getElementById('smallPrice').innerText = '₱' + price.toFixed(2);
    document.getElementById('largePrice').innerText = '₱' + (price + 20).toFixed(2);
    document.getElementById('itemQty').value = 1;
    document.getElementById('itemNotes').value = '';

    if (!hasSizes) {
    const radios = document.querySelectorAll('input[name="itemSize"]');
    radios.forEach(r => r.checked = (r.value === 'Small'));
    }

    document.getElementById('sizeModal').style.display = 'flex';
    }

    function closeModal() { document.getElementById('sizeModal').style.display = 'none'; }

    function updateQty(change) {
    const el = document.getElementById('itemQty');
    el.value = Math.max(1, parseInt(el.value) + change);
    }

    function confirmAddToCart() {
    const item   = allItems[activeModalId];
    if (!item) { Swal.fire('Error','Item not found in menu.','error'); return; }

    const cat      = item.cat || '';
    const hasSizes = sizedCategories.some(c => cat.includes(c));
    const size     = hasSizes ? document.querySelector('input[name="itemSize"]:checked').value : 'Regular';
    const qty      = parseInt(document.getElementById('itemQty').value);
    const notes    = document.getElementById('itemNotes').value.trim();
    const price    = size === 'Large' ? item.price + 20 : item.price;

    const existingIdx = customerCart.findIndex(
    i => i.id === item.id && i.size === size && i.notes === notes
    );

    if (existingIdx > -1) {
    customerCart[existingIdx].qty += qty;
    } else {
    customerCart.push({ id: item.id, name: item.name, size, qty, price, notes });
    }

    localStorage.setItem('caferoCustomerCart', JSON.stringify(customerCart));
    updateCartBadge();
    closeModal();

    Swal.fire({
    title: 'Added! 🛒',
    text: `${qty}× ${item.name} (${size}) added to your order.`,
    icon: 'success',
    timer: 1200,
    showConfirmButton: false
    });
    }

    // ── CART RENDER ───────────────────────────────────────────────────────────
    function updateCartBadge() {
    const total  = customerCart.reduce((s, i) => s + i.qty, 0);
    const badge  = document.getElementById('cartBadge');
    badge.style.display = total > 0 ? 'flex' : 'none';
    badge.innerText = total;
    }

    function renderCustomerCart() {
    const container    = document.getElementById('customerCartList');
    const totalDisplay = document.getElementById('customerCartTotal');
    updateCartBadge();

    if (customerCart.length === 0) {
    container.innerHTML = '<div class="empty-cart-msg">Your cart is empty.</div>';
    totalDisplay.innerText = '₱0.00';
    return;
    }

    let html = '', grandTotal = 0;
    customerCart.forEach((item, idx) => {
    const sub = item.qty * item.price;
    grandTotal += sub;
    html += `
    <div class="cart-item-row">
    <div class="cart-item-info">
    <h4>${item.name}</h4>
    <p>${item.size} · ₱${item.price.toFixed(2)}/ea${item.notes ? '<br><em class="cart-notes">📝 ' + item.notes + '</em>' : ''}</p>
    </div>
    <div class="cart-item-controls">
    <button class="cart-qty-btn" onclick="updateCustomerQty(${idx},-1)">-</button>
    <span class="cart-qty-val">${item.qty}</span>
    <button class="cart-qty-btn" onclick="updateCustomerQty(${idx},1)">+</button>
    </div>
    <div class="cart-subtotal-val">₱${sub.toFixed(2)}</div>
    </div>`;
    });

    container.innerHTML = html;
    totalDisplay.innerText = '₱' + grandTotal.toFixed(2);
    }

    function updateCustomerQty(index, change) {
    customerCart[index].qty += change;
    if (customerCart[index].qty <= 0) customerCart.splice(index, 1);
    localStorage.setItem('caferoCustomerCart', JSON.stringify(customerCart));
    renderCustomerCart();
    }

    // ── SUBMIT ORDER ──────────────────────────────────────────────────────────
    async function submitOnlineOrder() {
    if (customerCart.length === 0) {
    Swal.fire('Empty Cart', 'Please add items before checking out.', 'warning');
    return;
    }

    const orderType     = document.getElementById('customerOrderType').value;
    const paymentMethod = document.getElementById('customerPaymentMethod').value;
    const address       = document.getElementById('customerAddress')?.value.trim() || '';
    const grandTotal    = customerCart.reduce((s, i) => s + i.qty * i.price, 0);

    if (orderType === 'Delivery' && !address) {
    Swal.fire('Missing Address', 'Please enter your delivery address.', 'warning'); return;
    }
    if (orderType === 'Delivery' && grandTotal < 200) {
    Swal.fire('Minimum Order', 'Delivery requires a minimum order of ₱200.', 'warning'); return;
    }

    const btn = document.getElementById('checkoutBtn');
    btn.disabled = true;
    btn.innerText = 'Sending to kitchen...';

    const payload = {
    OrderType:       orderType,
    PaymentMethod:   paymentMethod,
    DeliveryAddress: orderType === 'Delivery' ? address : null,
    Items: customerCart.map(i => ({
    ProductId:   i.id,
    Quantity:    i.qty,
    Price:       i.price,
    SpecialNote: i.notes || ''
    }))
    };

    try {
    const response = await fetch('/Customer/PlaceOnlineOrder', {
    method:  'POST',
    headers: { 'Content-Type': 'application/json' },
    body:    JSON.stringify(payload)
    });

    if (response.ok) {
    const result = await response.json();

    // Award loyalty points (1 pt per ₱10)
    const earned = Math.floor(grandTotal / 10);
    loyaltyPts  += earned;
    localStorage.setItem('caferoLoyaltyPoints', loyaltyPts);
    updateLoyaltyUI();

    // Save to local order history
    const history = JSON.parse(localStorage.getItem('caferoOrderHistory') || '[]');
    history.unshift({
    orderId:     result.orderId,
    status:      'Pending',
    orderType,
    totalAmount: grandTotal,
    placedAt:    new Date().toISOString(),
    items:       [...customerCart]
    });
    localStorage.setItem('caferoOrderHistory', JSON.stringify(history));

    Swal.fire({
    title: 'Order Received! 🎉',
    html:  `<b>Order #${result.orderId}</b> sent to the kitchen.<br>
    Estimated wait: <b>15–20 minutes</b><br>
    <small>+${earned} loyalty points earned!</small>`,
    icon:  'success'
    }).then(() => {
    customerCart = [];
    localStorage.removeItem('caferoCustomerCart');
    if (document.getElementById('customerAddress'))
    document.getElementById('customerAddress').value = '';
    renderCustomerCart();
    toggleCart();
    });
    } else {
    const err = await response.json().catch(() => ({}));
    Swal.fire('Checkout Failed', err.message || 'Something went wrong. Please try again.', 'error');
    }
    } catch (e) {
    Swal.fire('Network Error', 'Could not reach the server. Please check your connection.', 'error');
    } finally {
    btn.disabled = false;
    btn.innerText = 'Send Order to Kitchen';
    }
    }

    // ── ORDER TRACKER ─────────────────────────────────────────────────────────
    async function loadMyOrders() {
    renderOrderHistory();
    await fetchLiveStatuses();
    }

    async function fetchLiveStatuses() {
    const history = JSON.parse(localStorage.getItem('caferoOrderHistory') || '[]');
    if (!history.length) {
    document.getElementById('activeOrdersList').innerHTML =
    '<div class="empty-orders-msg">No active orders right now.</div>';
    return;
    }

    try {
    const ids = history.map(o => o.orderId);
    const res = await fetch('/Customer/GetOrderStatuses', {
    method:  'POST',
    headers: { 'Content-Type': 'application/json' },
    body:    JSON.stringify(ids)
    });
    if (res.ok) {
    const statuses = await res.json();
    statuses.forEach(s => {
    const match = history.find(o => o.orderId === s.orderId);
    if (match) match.status = s.status;
    });
    localStorage.setItem('caferoOrderHistory', JSON.stringify(history));
    }
    } catch (e) { /* fall back to local */ }

    renderActiveOrders(history);
    }

    function renderActiveOrders(history) {
    const active    = history.filter(o => !['Completed','Voided','Delivered'].includes(o.status));
    const container = document.getElementById('activeOrdersList');

    if (!active.length) {
    container.innerHTML = '<div class="empty-orders-msg">No active orders right now.</div>';
    return;
    }

    container.innerHTML = active.map(order => {
    const { step, labelClass, label, eta } = getTrackInfo(order.status);
    const items = (order.items || []).map(i => `<span class="track-item-tag">${i.qty}× ${i.name}</span>`).join('');
    return `
    <div class="track-card">
    <div class="track-header">
    <span class="track-id">Order #${order.orderId}</span>
    <span class="track-badge ${labelClass}">${label}</span>
    </div>
    <div class="track-meta">
    <span class="track-price">₱${parseFloat(order.totalAmount).toFixed(2)}</span>
    <span class="track-time">${formatTime(order.placedAt)}</span>
    </div>
    <div class="eta-bar">⏱ ${eta}</div>
    <div class="track-steps">
    <div class="track-step ${step >= 1 ? 'done' : ''}">
    <div class="step-dot">${step >= 1 ? '✓' : '1'}</div>
    <span>Received</span>
    </div>
    <div class="track-line ${step >= 2 ? 'done' : ''}"></div>
    <div class="track-step ${step >= 2 ? 'done' : ''}">
    <div class="step-dot">${step >= 2 ? '✓' : '2'}</div>
    <span>Preparing</span>
    </div>
    <div class="track-line ${step >= 3 ? 'done' : ''}"></div>
    <div class="track-step ${step >= 3 ? 'done' : ''}">
    <div class="step-dot">${step >= 3 ? '✓' : '3'}</div>
    <span>Ready</span>
    </div>
    </div>
    <div class="track-items">${items}</div>
    </div>`;
    }).join('');
    }

    function renderOrderHistory() {
    const history   = JSON.parse(localStorage.getItem('caferoOrderHistory') || '[]');
    const container = document.getElementById('orderHistoryList');
    if (!history.length) {
    container.innerHTML = '<div class="empty-orders-msg">No past orders yet.</div>'; return;
    }
    container.innerHTML = history.map((order, idx) => {
    const { labelClass, label } = getTrackInfo(order.status);
    const items = (order.items || []).map(i => `${i.qty}× ${i.name} (${i.size})`).join(', ');
    return `
    <div class="history-row">
    <div class="history-left">
    <div class="history-id">Order #${order.orderId}</div>
    <div class="history-items">${items}</div>
    <div class="history-time">${formatDate(order.placedAt)}</div>
    </div>
    <div class="history-right">
    <span class="track-badge ${labelClass}">${label}</span>
    <div class="history-total">₱${parseFloat(order.totalAmount).toFixed(2)}</div>
    <button class="reorder-btn" onclick="reorder(${idx})">🔄 Reorder</button>
    </div>
    </div>`;
    }).join('');
    }

    function getTrackInfo(status) {
    const s = (status || '').toLowerCase();
    if (s === 'completed' || s === 'delivered')
    return { step: 3, labelClass: 'badge-delivered', label: 'Completed', eta: 'Order completed!' };
    if (s === 'ready' || s === 'on the way')
    return { step: 3, labelClass: 'badge-ready',     label: 'Ready / On the Way', eta: 'Ready for pickup!' };
    if (s === 'preparing')
    return { step: 2, labelClass: 'badge-preparing', label: 'Preparing', eta: 'Est. 10–15 mins' };
    if (s === 'voided')
    return { step: 0, labelClass: 'badge-voided',    label: 'Voided', eta: '—' };
    return   { step: 1, labelClass: 'badge-pending',   label: 'Pending', eta: 'Est. 15–20 mins' };
    }

    function formatTime(iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function formatDate(iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleString([], { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
    }

    function reorder(idx) {
    const history = JSON.parse(localStorage.getItem('caferoOrderHistory') || '[]');
    const order   = history[idx];
    if (!order?.items) return;
    order.items.forEach(item => {
    const existIdx = customerCart.findIndex(i => i.id === item.id && i.size === item.size);
    if (existIdx > -1) customerCart[existIdx].qty += item.qty;
    else customerCart.push({ ...item });
    });
    localStorage.setItem('caferoCustomerCart', JSON.stringify(customerCart));
    updateCartBadge();
    Swal.fire({ title: 'Added to Cart!', text: 'Previous order items have been added.', icon: 'success', timer: 1500, showConfirmButton: false });
    }

    // ── MENU FILTER ───────────────────────────────────────────────────────────
    function filterMenu(category, btnEl) {
    if (category) {
    document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
    if (btnEl) btnEl.classList.add('active');
    document.getElementById('menuGrid').setAttribute('data-current-cat', category);
    }

    const currentCat = document.getElementById('menuGrid').getAttribute('data-current-cat');
    const search     = (document.getElementById('menuSearch').value || '').toLowerCase();

    document.querySelectorAll('.product-card').forEach(card => {
    const cardCat  = (card.getAttribute('data-category') || '').toLowerCase().replace(/\s/g, '');
    const cardName = (card.getAttribute('data-name') || '').toLowerCase();
    const cardId   = card.getAttribute('data-id');

    let matchCat;
    if      (currentCat === 'all')       matchCat = true;
    else if (currentCat === 'favorites')  matchCat = favoriteIds.includes(String(cardId));
    else matchCat = cardCat.includes(currentCat.replace(/\s/g, ''));

    const matchSearch = !search || cardName.includes(search);
    card.style.display = (matchCat && matchSearch) ? '' : 'none';
    });
    }

    // ── INIT ──────────────────────────────────────────────────────────────────
    window.onload = () => {
    updateCartBadge();
    updateLoyaltyUI();
    checkStoreStatus();
    restoreFavHearts();
    };

    window.onclick = e => {
    if (e.target === document.getElementById('sizeModal')) closeModal();
    };
</script>
</body>
</html>
