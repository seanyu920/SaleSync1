namespace SaleSync.Views.Home
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Dashboard</title>
    <style>
            html, body {
                margin: 0;
                padding: 0;
                font-family: Arial, sans-serif;
                background: #e7e1dd;
                min-height: 100vh;
            }

            .page {
                min-height: 100vh;
                padding: 30px 40px;
                box-sizing: border-box;
            }

            .title {
                text-align: center;
                font-size: 32px;
                margin-bottom: 60px;
                color: #2f2f2f;
            }

            .left-buttons {
                display: flex;
                flex-direction: column;
                gap: 28px;
                width: 220px;
            }

            .dashboard-btn {
                display: inline-block;
                background: #d9d9d9;
                color: #222;
                text-decoration: none;
                font-size: 20px;
                padding: 14px 18px;
                border-radius: 4px;
                width: fit-content;
            }

            .top-right {
                position: absolute;
                top: 110px;
                right: 60px;
            }

            .layout {
                position: relative;
            }
    </style>
</head>
<body>
    <div class="page">
        <div class="title">Admin Dashboard</div>

        <div class="layout">
            <div class="left-buttons">
                <a href="#" class="dashboard-btn">Sales Report</a>
                <a href="#" class="dashboard-btn">Sales History</a>
                <a href="#" class="dashboard-btn">Inventory</a>
            </div>

            <div class="top-right">
                <a href="#" class="dashboard-btn">Manage Accounts</a>
            </div>
        </div>
    </div>
</body>
</html>
