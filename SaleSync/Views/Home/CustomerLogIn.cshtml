@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Customer Login - Cafero</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=Playfair+Display:wght@800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/CustomerLogIn.css" asp-append-version="true" />
</head>
<body>
    <div class="customer-split-container">
        
        <div class="customer-left">
            <div class="customer-brand-content">
                <div class="brand-lockup-block">
                    <h1 class="brand-title">Cafero</h1>
                    <div class="branding-sync-tag">Powered by <strong>SaleSync</strong></div>
                </div>
                <p>Your daily escape is just a login away. Track your rewards, reorder your favorites, and experience a retreat where every sip feels like home.</p>
            </div>
        </div>

        <div class="customer-right">
            <div class="customer-card">
                <div class="customer-header-block">
                    <span class="user-profile-icon">👤</span>
                    <h2>Hello There!</h2>
                    <p>Enter your details to manage your ordering profile.</p>
                </div>

                <form action="/Customer/CustomerOrdering" method="get">
                    <div class="customer-form-actions">
                        
                        <div class="input-container-group">
                            <label for="Email">Email Address</label>
                            <div class="input-field-wrapper">
                                <span class="input-icon-glyph">✉️</span>
                                <input type="email" id="Email" name="Email" placeholder="hello@example.com" />
                            </div>
                        </div>

                        <div class="input-container-group">
                            <label for="Password">Password</label>
                            <div class="input-field-wrapper">
                                <span class="input-icon-glyph">🔒</span>
                                <input type="password" id="Password" name="Password" placeholder="••••••••" />
                            </div>
                        </div>
                    </div>

                    <div class="customer-actions-wrapper">
                        <button type="submit" class="btn-primary-orange">LOG IN</button>
                    </div>

                    <div class="customer-aux-links" style="margin-top: 15px; text-align: center;">
                        <a href="#" class="customer-forgot-link">Forgot password?</a>
                    </div>
                </form>

                <div class="new-account-register" style="margin-top: 30px; text-align: center;">
                    New to Cafero? <a href="/Home/Register">Create an account</a>
                </div>
            </div>
        </div>

    </div>
</body>
</html>