@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SyncSale Login</title>
    <link rel="stylesheet" href="~/css/logInPage.css" />
</head>
<body>
    <div class="page">
        <div class="left-panel">
            <img src="~/images/syncsale-logo.png" alt="SyncSale Logo" class="brand-logo" />
        </div>

        <div class="login-card">
            <div class="user-icon">👤</div>

            <h1 class="title">SaleSync</h1>
            <p class="subtitle">Log in to your account</p>

            <div class="form-group">
                <label for="username">Username</label>
                <div class="input-wrap">
                    <input type="email" id="email" placeholder="Enter username here" />
                    <span class="field-icon">✉</span>
                </div>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <div class="input-wrap">
                    <input type="password" id="password" placeholder="Enter password here" />
                    <span class="field-icon">🔒</span>
                </div>
            </div>

            <button class="login-button">Login</button>

            <button class="forgot-button">Forgot Password?</button>

           
        </div>
    </div>
</body>
</html>