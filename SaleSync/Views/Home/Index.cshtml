@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SaleSync Home</title>
    <link rel="stylesheet" href="~/css/HomePage.css" />
</head>
<body>
    <header class="top-bar">
        <div class="logo">SaleSync</div>

        <nav class="nav-menu">
            <a href="#home">Home</a>
            <a href="#about">About</a>
            <a href="#contact">Contact Us</a>
        </nav>

        <div class="nav-login">
            <a asp-controller="Home" asp-action="Login" class="login-btn">Log In</a>
        </div>
    </header>

    <main class="hero-section" id="home">
        <div class="hero-content">
            <h1>Welcome to SaleSync</h1>
            <p>
                Track your sales, manage your inventory, and control your business
                with ease using SaleSync.
            </p>
            <a asp-controller="Home" asp-action="Login" class="hero-btn">Get Started</a>
        </div>
    </main>

    <section class="about-section" id="about">
        <div class="section-container">
            <h2>About SaleSync</h2>
            <p>
                SaleSync is a modern Point of Sale system designed to help businesses
                handle daily operations more efficiently. It allows users to monitor
                sales, manage inventory, and maintain accounts in one organized platform.
            </p>

            <div class="feature-grid">
                <div class="feature-card">
                    <h3>Sales Tracking</h3>
                    <p>Monitor business performance with clear and simple sales records.</p>
                </div>

                <div class="feature-card">
                    <h3>Inventory Management</h3>
                    <p>Track stock levels and product availability in an organized way.</p>
                </div>

                <div class="feature-card">
                    <h3>Account Management</h3>
                    <p>Manage admin and staff access with a secure login system.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="contact-section" id="contact">
        <div class="section-container">
            <h2>Contact Us</h2>
            <p>Email: support@salesync.com</p>
            <p>Phone: +63 912 345 6789</p>
            <p>Location: Your City, Philippines</p>
        </div>
    </section>

    <footer class="footer">
        <p>© 2026 SaleSync. All rights reserved.</p>
    </footer>
</body>
</html>