                        <a href="javascript:void(0)" onclick="openCategoryModal('snacks', 'Snacks & Pasta')">🍝 Snacks & Pasta</a>
                    </div>
                </div>

                <a href="#about" onclick="closeNav()">About</a>
                <a href="#contact" onclick="closeNav()">Contact</a>
            </nav>

            <div class="nav-login">
