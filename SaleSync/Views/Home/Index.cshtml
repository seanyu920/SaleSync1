@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SaleSync Home</title>
    <link rel="stylesheet" href="~/css/HomePage.css" />
</head>
<body>
    <header class="top-bar">
        <div class="logo">Cafero</div>

        <nav class="nav-menu">
            <a href="#home">Home</a>
            <a href="#about">About</a>
            <a href="#contact">Contact Us</a>
        </nav>

        <div class="nav-login">
            <a asp-controller="Home" asp-action="Login" class="login-btn">Log In</a>
        </div>
    </header>

    <main class="hero-section" id="home">
        <div class="hero-content">
            <h1>Welcome to Cafero</h1>
            <p>
                From cozy vibes to carefully brewed cups.
                Get ready for a cozy escape where every sip feels like home.
            </p>
            <a asp-controller="Home" asp-action="Login" class="hero-btn">Get Started</a>
        </div>
    </main>

    <section class="about-section" id="about">
        <div class="section-container">
            <h2>About Cafero</h2>
            <p>
                Cafero specializes in the art of craft coffee, offering a space purposefully designed for connection.
                From our signature coffee to delicious bread and pastries, every menu at Cafero tells a story.
            </p>

            <div class="feature-grid">
                <div class="feature-card">
                    <h3>Coffee</h3>
                    <p>Delicious </p>
                </div>

                <div class="feature-card">
                    <h3>Milk Tea</h3>
                    <p>Delicious</p>
                </div>

                <div class="feature-card">
                    <h3>Fruit Tea</h3>
                    <p>Delicious.</p>
                </div>

                <div class="feature-card">
                    <h3>Rice Meal</h3>
                    <p>Delicious</p>
                </div>

                <div class="feature-card">
                    <h3>Snacks and Pasta</h3>
                    <p>Delicious</p>
                </div>

                <div class="feature-card">
                    <h3>Bread and Pastries</h3>
                    <p>Delicious</p>
                </div>
            </div>
        </div>
    </section>

    <section class="contact-section" id="contact">
        <div class="section-container">
            <h2>Contact Us</h2>
            <p>Email: Cafero@gmail.com</p>
            <p>Phone: +63 912 345 6789</p>
            <p>Location: B.A Cruz Street near Barangay Hall of Sta.Ana, Taytay, Philippines, 1920</p>
        </div>
    </section>

    <footer class="footer">
        <p>© 2026 Cafero. All rights reserved.</p>
    </footer>
</body>
</html>