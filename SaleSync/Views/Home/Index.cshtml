    <script>
        function toggleNav() {
            const nav = document.getElementById('navContainer');
            const hamburger = document.getElementById('hamburger');
            nav.classList.toggle('active');
            hamburger.classList.toggle('active');
        }

        function closeNav() {
            if (window.innerWidth <= 768) {
                document.getElementById('navContainer').classList.remove('active');
                document.getElementById('hamburger').classList.remove('active');
            }
        }

        window.onclick = function(event) {
            const modal = document.getElementById('categoryModal');
            if (event.target == modal) closeCategoryModal();
        }

        function openCategoryModal(category, title) {
            document.getElementById('categoryModalTitle').innerText = title;
            document.querySelectorAll('#categoryModalGrid .product-card').forEach(card => {
                card.style.display = card.getAttribute('data-category') === category ? 'flex' : 'none';
            });
            document.getElementById('categoryModal').style.display = 'flex';
        }

        function closeCategoryModal() {
            document.getElementById('categoryModal').style.display = 'none';
        }
    </script>
