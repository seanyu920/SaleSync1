@model SaleSync.Models.CashierDashboardViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cashier Dashboard - Cafero</title>
    <link rel="stylesheet" href="~/css/CashierDashboard.css" asp-append-version="true" />
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        /* Modal Styles for Admin Verification */
        .modal-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(74, 37, 17, 0.6); z-index: 1000; justify-content: center; align-items: center;
        }
        .auth-modal {
            background: #ffffff; padding: 30px; border-radius: 20px; width: 350px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2); text-align: center;
        }
        .auth-modal input {
            width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #f0e6dd; border-radius: 10px;
        }
        .auth-btn {
            background: #4a2511; color: white; border: none; padding: 12px; 
            width: 100%; border-radius: 10px; cursor: pointer; font-weight: 700; margin-top: 10px;
        }
        .cancel-link { display: block; margin-top: 15px; color: #8c5b3e; cursor: pointer; font-size: 13px; }
        
        /* New Status Badges */
        .status-voided { background: #fee2e2; color: #b91c1c; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700; }
    </style>
</head>
<body>

    <div id="voidModal" class="modal-overlay">
        <div class="auth-modal">
            <h3 style="color: #4a2511; margin-bottom: 10px;">Admin Verification</h3>
            <p style="font-size: 13px; color: #8c5b3e; margin-bottom: 20px;">Manager or Admin credentials required to void this order.</p>
            <input type="text" id="adminUser" placeholder="Username" />
            <input type="password" id="adminPass" placeholder="Password" />
            <button class="auth-btn" onclick="verifyAndVoid()">Confirm Void</button>
            <span class="cancel-link" onclick="closeModal()">Cancel</span>
        </div>
    </div>

    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="logo-section">
                <div class="logo-title">Cafero</div>
                <div class="logo-subtitle">Coffee & Pastries</div>
            </div>
            <div class="profile-section">
                <div class="profile-circle">👤</div>
                <h2 style="font-size: 16px; font-weight: 700; color: #ffffff; margin: 0;">Cashier</h2>
                <div style="font-size: 12px; color: #dcbca5;">Front Desk Access</div>
            </div>
            <nav class="sidebar-menu">
                <a href="/Cashier/Dashboard" class="menu-btn active">❖ Dashboard</a>
                <a href="/Cashier/CashierMenu" class="menu-btn">📋 Menu</a>
                <a href="/Cashier/CashierMenu" class="menu-btn">📄 Receipt</a>
            </nav>
            <div style="margin-top: auto;">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn">⎋ Log Out</button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-header">
                <h1 class="greeting-title">Cashier Dashboard 📊</h1>
                <p class="greeting-subtitle">Your sales summarization and recent transactions.</p>
            </div>

            <div class="summary-grid">
                <div class="summary-card">
                    <div class="card-icon-box icon-sales">📈</div>
                    <div>
                        <div class="card-label">Your Sales Today</div>
                        <div class="card-value">₱@Model.TodayTotalSales.ToString("N2")</div>
                    </div>
                </div>
                <div class="summary-card">
                    <div class="card-icon-box icon-trans">🧾</div>
                    <div>
                        <div class="card-label">Transactions</div>
                        <div class="card-value">@Model.TodayTransactionCount</div>
                    </div>
                </div>
            </div>

            <div class="table-card">
                <div class="table-header-row">
                    <h2 class="table-title">Recent Sales</h2>
                    <button class="btn-full-report">View Full Report &rarr;</button>
                </div>
                
                <table class="recent-sales-table">
                    <thead>
                        <tr>
                            <th>ORDER ID</th>
                            <th>TIME</th>
                            <th>CASHIER</th>
                            <th>ITEMS</th>
                            <th>TOTAL AMOUNT</th>
                            <th>STATUS</th>
                            <th style="text-align: center;">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentSales != null && Model.RecentSales.Any())
                        {
                            @foreach (var sale in Model.RecentSales)
                            {
                                <tr onclick="toggleDetails(@sale.SaleId)" style="cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='#fcf9f5'" onmouseout="this.style.background='transparent'">
                                    <td class="td-bold">#ORD-@sale.SaleId</td>
                                    <td>@sale.SaleDate.ToString("hh:mm tt")</td>
                                    <td><span class="badge-cashier">@sale.CashierName</span></td>
                                    <td>@sale.ItemsSummary</td>
                                    <td class="td-price">₱@sale.TotalAmount.ToString("N2")</td>
                                    <td>
                                        @if (sale.Status == "Completed") { <span class="badge-completed">Completed</span> }
                                        else if (sale.Status == "Voided") { <span class="status-voided">Voided</span> }
                                        else { <span class="badge-pending">Pending</span> }
                                    </td>
                                    <td style="text-align: center;">
                                        <div class="action-btn-group">
                                            @if (sale.Status == "Pending" || string.IsNullOrEmpty(sale.Status))
                                            {
                                                <button class="btn-mini btn-confirm-mini" onclick="event.stopPropagation(); updateStatus(@sale.SaleId, 'Completed')">✓</button>
                                                <button class="btn-mini btn-void-mini" onclick="event.stopPropagation(); openVoidModal(@sale.SaleId)">✕</button>
                                            }
                                            else
                                            {
                                                <span style="color: #dcbca5; font-size: 11px;">No Actions</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                
                                <tr id="details-@sale.SaleId" class="details-row" style="display: none; background: #faf8f5;">
                                    <td colspan="7" style="padding: 0;">
                                        <div style="padding: 15px 25px; border-left: 4px solid #f46a05; display: flex; gap: 50px; text-align: left; margin: 5px 15px 15px 15px; background: white; border-radius: 8px; box-shadow: inset 0 0 10px rgba(0,0,0,0.02);">
                                            <div style="flex: 1;">
                                                <h4 style="margin: 0 0 8px 0; color: #8c5b3e; font-size: 13px; text-transform: uppercase;">📦 Items Sold</h4>
                                                <ul id="items-list-@sale.SaleId" style="margin: 0; padding-left: 20px; font-size: 14px; color: #4a2511; line-height: 1.6;">
                                                    <li>Loading...</li>
                                                </ul>
                                            </div>
                                            <div style="flex: 1.5;">
                                                <h4 style="margin: 0 0 8px 0; color: #8c5b3e; font-size: 13px; text-transform: uppercase;">📉 Ingredients Deducted</h4>
                                                <ul id="ing-list-@sale.SaleId" style="margin: 0; padding-left: 20px; font-size: 14px; color: #4a2511; line-height: 1.6;">
                                                    <li>Loading...</li>
                                                </ul>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script>
        let currentSaleId = null;

        function updateStatus(saleId, status) {
            // CHANGE: Replaced confirm() with Swal.fire()
            Swal.fire({
                title: 'Confirm Order?',
                text: `Mark Order #ORD-${saleId} as ${status}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#f46a05',
                cancelButtonColor: '#4a2511',
                confirmButtonText: 'Yes, update it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Cashier/UpdateSaleStatus', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ saleId: saleId, status: status })
                    }).then(res => {
                        if (res.ok) {
                            location.reload();
                        } else {
                            // CHANGE: Replaced alert() with Swal.fire()
                            Swal.fire('Error', 'Update failed.', 'error');
                        }
                    });
                }
            });
        }

        function openVoidModal(saleId) {
            currentSaleId = saleId;
            document.getElementById('voidModal').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('voidModal').style.display = 'none';
            document.getElementById('adminUser').value = '';
            document.getElementById('adminPass').value = '';
        }

        function verifyAndVoid() {
            const user = document.getElementById('adminUser').value;
            const pass = document.getElementById('adminPass').value;

            if (!user || !pass) {
                Swal.fire('Required', 'Please enter credentials.', 'warning');
                return;
            }

            fetch('/Cashier/VerifyAndVoid', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    saleId: currentSaleId, 
                    adminUser: user, 
                    adminPass: pass 
                })
            }).then(async res => {
                if (res.ok) {
                    // CHANGE: Added success popup before reload
                    Swal.fire({
                        title: 'Voided!',
                        text: 'The order has been voided.',
                        icon: 'success',
                        confirmButtonColor: '#4a2511'
                    }).then(() => location.reload());
                } else {
                    const data = await res.json();
                    // CHANGE: Replaced alert() with Swal.fire()
                    Swal.fire('Unauthorized', data.message || "Unauthorized access", 'error');
                }
            });
        }

        async function toggleDetails(saleId) {
            const row = document.getElementById(`details-${saleId}`);
            const isExpanding = row.style.display === 'none';
            
            document.querySelectorAll('.details-row').forEach(r => r.style.display = 'none');
            
            if (isExpanding) {
                row.style.display = 'table-row';
                
                try {
                    const res = await fetch(`/Cashier/GetOrderDetails?saleId=${saleId}`);
                    if(res.ok) {
                        const data = await res.json();
                        
                        const itemsUl = document.getElementById(`items-list-${saleId}`);
                        itemsUl.innerHTML = data.items.map(i => `<li>${i}</li>`).join('');
                        
                        const ingUl = document.getElementById(`ing-list-${saleId}`);
                        if (data.ingredients.length > 0) {
                            ingUl.innerHTML = data.ingredients.map(i => `<li>${i}</li>`).join('');
                        } else {
                            ingUl.innerHTML = `<li style="color: #999; list-style: none; margin-left: -20px;">No ingredients tied to this order.</li>`;
                        }
                    }
                } catch (err) {
                    console.error("Failed to load details");
                }
            }
        }
    </script>
</body>
</html>