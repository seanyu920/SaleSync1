@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cashier Dashboard - Cafero</title>
    <link rel="stylesheet" href="~/css/CashierDashboard.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-container">
        
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title" style="font-size: 24px; font-weight: 800; color: #ffffff;">Cafero</div>
                    <div class="logo-subtitle" style="font-size: 13px; color: #dcbca5;">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <h2 class="admin-name" style="font-size: 16px; font-weight: 700; color: #ffffff; margin: 0;">Cashier</h2>
                        <div style="font-size: 12px; color: #dcbca5;">Front Desk Access</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="javascript:void(0)" onclick="showMenu()" id="btnMenu" class="menu-btn active">❖ Menu</a>
                    <a href="javascript:void(0)" onclick="showCart()" id="btnCart" class="menu-btn">📄 Receipt</a>
                </nav>
            </div>

            <div class="logout-section" style="margin-top: auto;">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn" style="background: transparent; border: none; width: 100%; text-align: left; cursor: pointer; color: #dcbca5; padding: 14px 20px;">
                        ⎋ Log Out
                    </button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            
            <div id="menuSection" class="section-container">
                <div id="categoryGrid">
                    <h1 class="form-title">Menu Categories</h1>
                    <div class="product-grid">
                        <div class="product-card" onclick="openSubMenu('COFFEE')">
                            <div class="product-thumb">☕</div>
                            <div class="product-info"><h3>COFFEE</h3></div>
                        </div>
                        <div class="product-card" onclick="openSubMenu('MILKTEA')">
                            <div class="product-thumb">🧋</div>
                            <div class="product-info"><h3>MILK TEA</h3></div>
                        </div>
                        <div class="product-card" onclick="openSubMenu('FRUIT TEA')">
                            <div class="product-thumb">🍹</div>
                            <div class="product-info"><h3>FRUIT TEA</h3></div>
                        </div>
                        <div class="product-card" onclick="openSubMenu('RICE MEAL')">
                            <div class="product-thumb">🍱</div>
                            <div class="product-info"><h3>RICE MEAL</h3></div>
                        </div>
                        <div class="product-card" onclick="openSubMenu('BREAD & PASTRY')">
                            <div class="product-thumb">🥐</div>
                            <div class="product-info"><h3>BREAD & PASTRY</h3></div>
                        </div>
                        <div class="product-card" onclick="openSubMenu('SNACKS & PASTA')">
                            <div class="product-thumb">🍝</div>
                            <div class="product-info"><h3>SNACKS & PASTA</h3></div>
                        </div>
                    </div>
                </div>

                <div id="subMenuGridSection" class="form-card" style="display:none;">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:25px;">
                        <h1 class="form-title" id="subCategoryName" style="margin-bottom:0;">Items</h1>
                        <div style="display:flex; gap:10px;">
                            <button onclick="openAddProductModal()" class="action-btn add-btn">+ Add Item</button>
                            <button onclick="backToCategories()" class="action-btn update-btn" style="background:#4a2511;">&larr; Back</button>
                        </div>
                    </div>
                    <div class="product-grid" id="itemsList"></div>
                </div>

                <div class="form-card" id="selectionDetails" style="display:none; margin-top:30px; border-top: 4px solid #f46a05;">
                    <div class="item-display-flex">
                        <div class="item-image-container">
                            <img id="displayImg" src="" style="width:100%; height:100%; object-fit:cover; display:none;" />
                            <div id="displayEmoji" style="font-size: 80px; display: flex; align-items: center; justify-content: center; height: 100%; background: #fdfaf6;">☕</div>
                        </div>
                        <div class="item-details-controls">
                            <h2 id="displayName" class="form-title" style="margin-bottom: 10px;">Product Name</h2>
                            <div class="size-selector-grid">
                                <label class="custom-radio-card">
                                    <input type="radio" name="size" value="Medium" id="sizeM" checked />
                                    <span class="radio-tile">Medium</span>
                                </label>
                                <label class="custom-radio-card">
                                    <input type="radio" name="size" value="Large" id="sizeL" />
                                    <span class="radio-tile">Large</span>
                                </label>
                            </div>
                            <div class="qty-flex">
                                <button type="button" onclick="decreaseQty()">-</button>
                                <input id="qty" value="1" readonly style="width: 60px; text-align: center; border: 1px solid #f0e6dd; border-radius: 8px; font-weight: bold;" />
                                <button type="button" onclick="increaseQty()">+</button>
                            </div>
                            <button type="button" class="action-btn add-btn" style="width:100%; padding: 15px;" onclick="addToCart()">Add to Receipt</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="cartSection" class="section-container" style="display:none;">
                <div style="display:flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
                    <h1 class="form-title" style="margin-bottom:0;">Current Order</h1>
                    <div style="display:flex; gap:12px;">
                        <button type="button" onclick="removeSelectedItem()" class="action-btn delete-btn">Remove Item</button>
                        <button type="button" onclick="checkoutOrder()" class="action-btn add-btn" style="background:#0b8a53;">Complete Checkout</button>
                    </div>
                </div>
                
                <div class="table-card">
                    <table>
                        <thead>
                            <tr>
                                <th style="width: 50px;">Sel</th>
                                <th>Item Name</th>
                                <th>Size</th>
                                <th>Qty</th>
                                <th>Price</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody id="receiptList"></tbody>
                    </table>
                    
                    <div class="total-footer">
                        <div style="font-size: 14px; color: #8c5b3e; font-weight: 600;">Grand Total</div>
                        <div id="total" style="font-size: 32px; font-weight: 800; color: #4a2511;">₱0.00</div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="addProductModal" class="modal-overlay" style="display:none;">
        <div class="modal-content">
            <h2 class="form-title">Quick Add Product</h2>
            <div style="margin-bottom:15px;">
                <label style="display:block; margin-bottom:8px; font-weight:700; color:#8c5b3e; font-size:13px;">Product Name</label>
                <input type="text" id="newProductName" placeholder="e.g. Spanish Latte" style="width:100%; padding:12px; border-radius:10px; border:1px solid #f0e6dd; background:#fdfaf6;">
            </div>
            <div style="margin-bottom:15px;">
                <label style="display:block; margin-bottom:8px; font-weight:700; color:#8c5b3e; font-size:13px;">Image Filename (Optional)</label>
                <input type="text" id="newProductImg" placeholder="e.g. latte.jpg" style="width:100%; padding:12px; border-radius:10px; border:1px solid #f0e6dd; background:#fdfaf6;">
            </div>
            <div style="display:flex; gap:12px; margin-top:25px;">
                <button onclick="saveNewProduct()" class="action-btn add-btn" style="flex:1;">Save</button>
                <button onclick="closeAddProductModal()" class="action-btn update-btn" style="flex:1; background:#8c5b3e;">Cancel</button>
            </div>
        </div>
    </div>

    <script>
            // Updated Data Structure: Name and Image
            let menuData = {
                "COFFEE": [
                    { name: "Spanish Latte", img: "coffee.jpg" },
                    { name: "Americano", img: "americano.jpg" },
                    { name: "Cappuccino", img: "" } // Empty means use default emoji
                ],
                "MILKTEA": [{ name: "Wintermelon", img: "milktea.jpg" }],
                "FRUIT TEA": [{ name: "Strawberry", img: "fruittea.jpg" }],
                "RICE MEAL": [{ name: "Silog", img: "rice.jpg" }],
                "BREAD & PASTRY": [{ name: "Croissant", img: "bread.jpg" }],
                "SNACKS & PASTA": [{ name: "Carbonara", img: "pasta.jpg" }]
            };

            let cart = [];
            let selectedReceiptIndex = -1;
            let activeItemName = "";
            let activeItemImg = "";
            let currentCategory = "";

            function showMenu() {
                backToCategories();
                document.getElementById("menuSection").style.display = "block";
                document.getElementById("cartSection").style.display = "none";
                document.getElementById("btnMenu").classList.add("active");
                document.getElementById("btnCart").classList.remove("active");
            }

            function showCart() {
                document.getElementById("menuSection").style.display = "none";
                document.getElementById("cartSection").style.display = "block";
                document.getElementById("btnCart").classList.add("active");
                document.getElementById("btnMenu").classList.remove("active");
                renderReceipt();
            }

            function openSubMenu(category) {
                currentCategory = category;
                document.getElementById("categoryGrid").style.display = "none";
                document.getElementById("subMenuGridSection").style.display = "block";
                document.getElementById("subCategoryName").innerText = category;
                refreshSubMenuGrid();
            }

            function refreshSubMenuGrid() {
                const itemsList = document.getElementById("itemsList");
                itemsList.innerHTML = "";
            
                // Check if category exists in data
                if(!menuData[currentCategory]) menuData[currentCategory] = [];

                menuData[currentCategory].forEach(item => {
                    let imgHtml = item.img
                        ? `<img src="/images/${item.img}" style="width:100%; height:100%; object-fit:cover;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">`
                        : "";
                    let emoji = getCategoryEmoji(currentCategory);

                    itemsList.innerHTML += `
                        <div class="product-card" onclick="selectProductItem('${item.name}', '${item.img}')">
                            <div class="product-thumb">
                                ${imgHtml}
                                <span style="display:${item.img ? 'none' : 'flex'}; font-size:40px;">${emoji}</span>
                            </div>
                            <div class="product-info">
                                <h3>${item.name}</h3>
                            </div>
                        </div>`;
                });
            }

            function getCategoryEmoji(cat) {
                if(cat === "MILKTEA") return "🧋";
                if(cat === "RICE MEAL") return "🍱";
                if(cat === "BREAD & PASTRY") return "🥐";
                if(cat === "FRUIT TEA") return "🍹";
                if(cat === "SNACKS & PASTA") return "🍝";
                return "☕";
            }

            function backToCategories() {
                document.getElementById("categoryGrid").style.display = "block";
                document.getElementById("subMenuGridSection").style.display = "none";
                document.getElementById("selectionDetails").style.display = "none";
            }

            function selectProductItem(name, img) {
                activeItemName = name;
                activeItemImg = img;
                document.getElementById("selectionDetails").style.display = "block";
                document.getElementById("displayName").innerText = name;
                document.getElementById("qty").value = 1;

                const dispImg = document.getElementById("displayImg");
                const dispEmoji = document.getElementById("displayEmoji");

                if(img) {
                    dispImg.src = "/images/" + img;
                    dispImg.style.display = "block";
                    dispEmoji.style.display = "none";
                } else {
                    dispImg.style.display = "none";
                    dispEmoji.style.display = "flex";
                    dispEmoji.innerText = getCategoryEmoji(currentCategory);
                }

                document.getElementById("selectionDetails").scrollIntoView({ behavior: 'smooth' });
            }

            function openAddProductModal() { document.getElementById("addProductModal").style.display = "flex"; }
            function closeAddProductModal() {
                document.getElementById("addProductModal").style.display = "none";
                document.getElementById("newProductName").value = "";
                document.getElementById("newProductImg").value = "";
            }

            function saveNewProduct() {
                const name = document.getElementById("newProductName").value;
                const img = document.getElementById("newProductImg").value;
                if (!name) { alert("Enter product name"); return; }
            
                menuData[currentCategory].push({ name: name, img: img });
                refreshSubMenuGrid();
                closeAddProductModal();
            }

            function increaseQty() { let q = document.getElementById("qty"); q.value = parseInt(q.value) + 1; }
            function decreaseQty() { let q = document.getElementById("qty"); if (parseInt(q.value) > 1) q.value = parseInt(q.value) - 1; }

            function addToCart() {
                let selectedSize = document.querySelector('input[name="size"]:checked').value;
                let qty = parseInt(document.getElementById("qty").value);
                let price = (selectedSize === "Medium") ? 75 : 95;
                cart.push({ name: activeItemName, size: selectedSize, qty: qty, price: price });
                alert(activeItemName + " added to receipt!");
                backToCategories();
            }

            function renderReceipt() {
                let receipt = document.getElementById("receiptList");
                let totalEl = document.getElementById("total");
                if (cart.length === 0) {
                    receipt.innerHTML = "<tr><td colspan='6' style='text-align:center; padding:40px; color:#b58361;'>Your receipt is currently empty.</td></tr>";
                    totalEl.textContent = "₱0.00";
                    return;
                }
                let html = "";
                let total = 0;
                cart.forEach((item, index) => {
                    let subtotal = item.qty * item.price;
                    total += subtotal;
                    html += `
                        <tr onclick="selectReceiptItem(${index})" class="${selectedReceiptIndex === index ? 'selected-row' : ''}">
                            <td><input type="radio" name="cartSel" ${selectedReceiptIndex === index ? 'checked' : ''}></td>
                            <td>${item.name}</td>
                            <td><span class="status-badge" style="background:#fdf0dc; color:#ab4a03; padding:4px 10px; border-radius:6px;">${item.size}</span></td>
                            <td>${item.qty}</td>
                            <td>₱${item.price.toFixed(2)}</td>
                            <td style="color:#f46a05; font-weight:800;">₱${subtotal.toFixed(2)}</td>
                        </tr>`;
                });
                receipt.innerHTML = html;
                totalEl.textContent = "₱" + total.toFixed(2);
            }

            function selectReceiptItem(index) { selectedReceiptIndex = index; renderReceipt(); }
            function removeSelectedItem() {
                if (selectedReceiptIndex === -1) { alert("Select an item to remove"); return; }
                cart.splice(selectedReceiptIndex, 1);
                selectedReceiptIndex = -1;
                renderReceipt();
            }
            function checkoutOrder() {
                if (cart.length === 0) { alert("Receipt is empty"); return; }
                alert("Transaction Complete!");
                cart = [];
                selectedReceiptIndex = -1;
                showMenu();
            }
    </script>
</body>
</html>