@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cashier Terminal - Cafero</title>
    <link rel="stylesheet" href="~/css/CashierDashboard.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-container">
        
        <aside class="sidebar">
            <div>
                <div class="logo-section">
                    <div class="logo-title" style="font-size: 24px; font-weight: 800; color: #ffffff;">Cafero</div>
                    <div class="logo-subtitle" style="font-size: 13px; color: #dcbca5;">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div>
                        <h2 class="admin-name" style="font-size: 16px; font-weight: 700; color: #ffffff; margin: 0;">Cashier</h2>
                        <div style="font-size: 12px; color: #dcbca5;">Front Desk Access</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="javascript:void(0)" onclick="showMenu()" id="btnMenu" class="menu-btn active">❖ Menu</a>
                    <a href="javascript:void(0)" onclick="showCart()" id="btnCart" class="menu-btn">📄 Receipt</a>
                </nav>
            </div>

            <div class="logout-section" style="margin-top: auto;">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn">⎋ Log Out</button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            
            <div id="menuSection" class="section-container">
                <div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px;">
                    <div>
                        <h1 class="form-title" id="cashierTitle" style="margin-bottom:5px;">Menu Categories</h1>
                        <p id="cashierSubtitle" style="color:#8c5b3e; font-size:14px;">Select a category to view items.</p>
                    </div>
                    <button id="backBtn" class="btn-secondary" style="display: none; background:#4a2511; color:white; border:none; padding:10px 20px; border-radius:10px; cursor:pointer;" onclick="backToCategories()">← Back</button>
                </div>

                <div id="categoryGrid" class="product-grid">
                    <div class="product-card" onclick="openSubMenu('COFFEE')">
                        <div class="product-thumb" id="thumb-COFFEE">☕</div>
                        <div class="product-info"><h3>COFFEE</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('MILKTEA')">
                        <div class="product-thumb" id="thumb-MILKTEA">🧋</div>
                        <div class="product-info"><h3>MILK TEA</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('FRUIT TEA')">
                        <div class="product-thumb" id="thumb-FRUIT TEA">🍹</div>
                        <div class="product-info"><h3>FRUIT TEA</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('RICE MEAL')">
                        <div class="product-thumb" id="thumb-RICE MEAL">🍱</div>
                        <div class="product-info"><h3>RICE MEAL</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('BREAD & PASTRY')">
                        <div class="product-thumb" id="thumb-BREAD & PASTRY">🥐</div>
                        <div class="product-info"><h3>BREAD & PASTRY</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('SNACKS & PASTA')">
                        <div class="product-thumb" id="thumb-SNACKS & PASTA">🍝</div>
                        <div class="product-info"><h3>SNACKS & PASTA</h3></div>
                    </div>
                </div>

                <div id="subItemsGrid" class="product-grid" style="display:none;">
                </div>

                <div class="form-card" id="selectionDetails" style="display:none; margin-top:30px; border-top: 4px solid #f46a05;">
                    <div class="item-display-flex">
                        <div class="item-image-container" id="detailImageContainer"></div>
                        <div class="item-details-controls">
                            <h2 id="displayName" class="item-name-display">Product Name</h2>
                            <div class="size-selector-grid">
                                <label class="custom-radio-card"><input type="radio" name="size" value="Medium" checked /><span class="radio-tile">Medium</span></label>
                                <label class="custom-radio-card"><input type="radio" name="size" value="Large" /><span class="radio-tile">Large</span></label>
                            </div>
                            <div class="qty-flex">
                                <button type="button" onclick="decreaseQty()">-</button>
                                <input id="qty" value="1" readonly />
                                <button type="button" onclick="increaseQty()">+</button>
                            </div>
                            <button type="button" class="add-btn-large" onclick="addToCart()">Add to Receipt</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="cartSection" class="section-container" style="display:none;">
                <div style="display:flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
                    <h1 class="form-title" style="margin-bottom:0;">Current Order</h1>
                    <div style="display:flex; gap:12px;">
                        <button type="button" onclick="removeSelectedItem()" class="action-btn delete-btn">Remove Item</button>
                        <button type="button" onclick="checkoutOrder()" class="action-btn add-btn" style="background:#0b8a53;">Complete Checkout</button>
                    </div>
                </div>
                <div class="table-card">
                    <table>
                        <thead>
                            <tr><th>Sel</th><th>Item Name</th><th>Size</th><th>Qty</th><th>Price</th><th>Subtotal</th></tr>
                        </thead>
                        <tbody id="receiptList"></tbody>
                    </table>
                    <div class="total-footer">
                        <div style="font-size: 14px; color: #8c5b3e; font-weight: 600;">Grand Total</div>
                        <div id="total">₱0.00</div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
            const menuData = {
                "COFFEE": ["Americano", "Cappuccino", "Hot Choco", "Hot Latte", "Iced Latte", "Spanish Latte", "Hot Matcha Latte", "Iced Matcha Latte"],
                "MILKTEA": ["Wintermelon", "Okinawa", "Cookies and Cream", "Salted Caramel", "Hokkaido", "Matcha", "Thai"],
                "FRUIT TEA": ["Green Apple", "Strawberry", "Blueberry", "Mango", "Lychee", "Peach"],
                "RICE MEAL": ["Silog", "Hot Silog", "Long Silog", "Ham Silog", "Shanghai Silog", "Embotido Silog"],
                "BREAD & PASTRY": ["Chocolate Cookies", "Croissant", "Cheese Ensaymada", "Yema Ensaymada", "Ube Ensaymada", "Chocolate Donut", "Cinnamon"],
                "SNACKS & PASTA": ["Flavored Fries", "Nachos", "Siomai 4pcs", "Carbonara", "Pesto Pasta", "Gambas Pasta"]
            };

            let cart = [], selectedReceiptIndex = -1, activeItemName = "", currentCategory = "";

            function openSubMenu(cat) {
                currentCategory = cat;
                const items = menuData[cat];
                const grid = document.getElementById('subItemsGrid');
                const customImg = localStorage.getItem(`cat_img_${cat}`);
            
                document.getElementById('cashierTitle').innerText = cat;
                document.getElementById('cashierSubtitle').innerText = "Select an item to customize";
            
                grid.innerHTML = "";
                items.forEach(item => {
                    let imgContent = customImg ? `<img src="${customImg}" style="width:100%;height:100%;object-fit:cover;">` : `<span style="font-size:40px;">${getCategoryEmoji(cat)}</span>`;
                    grid.innerHTML += `
                        <div class="product-card" onclick="selectProductItem('${item}')">
                            <div class="product-thumb">${imgContent}</div>
                            <div class="product-info"><h3>${item}</h3></div>
                        </div>`;
                });

                document.getElementById('categoryGrid').style.display = 'none';
                document.getElementById('subItemsGrid').style.display = 'grid';
                document.getElementById('backBtn').style.display = 'block';
            }

            function backToCategories() {
                document.getElementById('cashierTitle').innerText = "Menu Categories";
                document.getElementById('categoryGrid').style.display = 'grid';
                document.getElementById('subItemsGrid').style.display = 'none';
                document.getElementById('backBtn').style.display = 'none';
                document.getElementById('selectionDetails').style.display = 'none';
            }

            function selectProductItem(name) {
                activeItemName = name;
                document.getElementById('selectionDetails').style.display = 'block';
                document.getElementById('displayName').innerText = name;
                document.getElementById('qty').value = 1;
            
                const customImg = localStorage.getItem(`cat_img_${currentCategory}`);
                const container = document.getElementById('detailImageContainer');
                container.innerHTML = customImg ? `<img src="${customImg}" style="width:100%;height:100%;object-fit:cover;">` : `<div style="font-size:60px; text-align:center; padding-top:40px;">${getCategoryEmoji(currentCategory)}</div>`;
            
                document.getElementById('selectionDetails').scrollIntoView({ behavior: 'smooth' });
            }

            function getCategoryEmoji(cat) {
                const emojis = { "MILKTEA": "🧋", "RICE MEAL": "🍱", "BREAD & PASTRY": "🥐", "FRUIT TEA": "🍹", "SNACKS & PASTA": "🍝" };
                return emojis[cat] || "☕";
            }

            function showMenu() { backToCategories(); document.getElementById("menuSection").style.display = "block"; document.getElementById("cartSection").style.display = "none"; document.getElementById("btnMenu").classList.add("active"); document.getElementById("btnCart").classList.remove("active"); }
            function showCart() { document.getElementById("menuSection").style.display = "none"; document.getElementById("cartSection").style.display = "block"; document.getElementById("btnCart").classList.add("active"); document.getElementById("btnMenu").classList.remove("active"); renderReceipt(); }
            function increaseQty() { let q = document.getElementById("qty"); q.value = parseInt(q.value) + 1; }
            function decreaseQty() { let q = document.getElementById("qty"); if (parseInt(q.value) > 1) q.value = parseInt(q.value) - 1; }

            function addToCart() {
                let size = document.querySelector('input[name="size"]:checked').value;
                let qty = parseInt(document.getElementById("qty").value);
                let price = (size === "Medium") ? 75 : 95;
                cart.push({ name: activeItemName, size: size, qty: qty, price: price });
                backToCategories();
            }

            function renderReceipt() {
                let receipt = document.getElementById("receiptList");
                let totalEl = document.getElementById("total");
                if (cart.length === 0) { receipt.innerHTML = "<tr><td colspan='6' style='text-align:center; padding:40px;'>No items</td></tr>"; totalEl.textContent = "₱0.00"; return; }
                let html = "", total = 0;
                cart.forEach((item, index) => {
                    let sub = item.qty * item.price;
                    total += sub;
                    html += `<tr onclick="selectReceiptItem(${index})" class="${selectedReceiptIndex === index ? 'selected-row' : ''}">
                        <td><input type="radio" name="cartSel" ${selectedReceiptIndex === index ? 'checked' : ''}></td>
                        <td>${item.name}</td><td>${item.size}</td><td>${item.qty}</td><td>₱${item.price.toFixed(2)}</td><td style="color:#f46a05;">₱${sub.toFixed(2)}</td>
                    </tr>`;
                });
                receipt.innerHTML = html;
                totalEl.textContent = "₱" + total.toFixed(2);
            }

            function selectReceiptItem(index) { selectedReceiptIndex = index; renderReceipt(); }
            function removeSelectedItem() { if (selectedReceiptIndex === -1) return; cart.splice(selectedReceiptIndex, 1); selectedReceiptIndex = -1; renderReceipt(); }
            function checkoutOrder() { if (cart.length === 0) return; alert("Checkout Done!"); cart = []; selectedReceiptIndex = -1; showMenu(); }

            window.onload = () => {
                const cats = ['COFFEE', 'MILKTEA', 'FRUIT TEA', 'RICE MEAL', 'BREAD & PASTRY', 'SNACKS & PASTA'];
                cats.forEach(cat => {
                    const saved = localStorage.getItem(`cat_img_${cat}`);
                    if(saved) {
                        const thumb = document.getElementById(`thumb-${cat}`);
                        if(thumb) thumb.innerHTML = `<img src="${saved}" style="width:100%;height:100%;object-fit:cover;">`;
                    }
                });
            };
    </script>
</body>
</html>