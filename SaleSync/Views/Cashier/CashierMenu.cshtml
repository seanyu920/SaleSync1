@model List<SaleSync.Models.MenuItemModel>
@{
    Layout = null;
    
    // ⭐ SHAPE-SHIFTER LOGIC: Detects who is looking at the POS and adjusts the sidebar
    string roleName = "Cashier";
    string homeController = "Cashier";
    string subtitle = "Front Desk Access";

    if (User.IsInRole("Admin"))
    {
        roleName = "Admin";
        homeController = "Admin";
        subtitle = "Administrator";
    }
    else if (User.IsInRole("Manager"))
    {
        roleName = "Manager";
        homeController = "Manager";
        subtitle = "System Access";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Point of Sale - Cafero</title>
    <link rel="stylesheet" href="~/css/CashierMenu.css" asp-append-version="true" />
    
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        /* Force identical sidebar styling to prevent the "Shift" */
        .sidebar .profile-section { border: none !important; padding: 0 10px !important; margin-bottom: 40px !important; }
        .sidebar-menu .menu-btn { background: transparent !important; border: none !important; box-shadow: none !important; margin-bottom: 5px !important; }
        .sidebar-menu .menu-btn.active { background: #f46a05 !important; color: white !important; }
    </style>
</head>
<body>
    <div class="dashboard-container">
        
        <aside class="sidebar">
            <div class="logo-section" style="margin-bottom: 30px;">
                <div class="logo-title">Cafero</div>
                <div class="logo-subtitle">Coffee & Pastries</div>
            </div>

            <div class="profile-section" style="display: flex; align-items: center; justify-content: flex-start; gap: 15px;">
                <div class="profile-circle" style="width: 45px; height: 45px; flex-shrink: 0; background: #f46a05; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #fff;">👤</div>
                <div style="text-align: left;">
                    <div style="font-size: 16px; font-weight: 700; color: #ffffff; margin: 0;">@roleName</div>
                    <div style="font-size: 12px; color: #dcbca5;">@subtitle</div>
                </div>
            </div>

            <nav class="sidebar-menu" style="margin-top: 40px;">
                <a href="/@homeController/Dashboard" class="menu-btn">❖ Dashboard</a>
                
                <a href="javascript:void(0)" class="menu-btn active">🛒 Point of Sale</a>

                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/ActivityLog" class="menu-btn">📋 Activity Log</a>
                }
                
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <a href="/Admin/Analytics" class="menu-btn">📊 Analytics</a>
                    <a href="/Admin/Products" class="menu-btn">🏷️ Products</a>
                    <a href="/Admin/Inventory" class="menu-btn">📦 Inventory</a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/ManageAccounts" class="menu-btn">💳 Accounts</a>
                }
            </nav>

            <div style="margin-top: auto;">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn" style="background:transparent; border:none; color:#dcbca5; text-align:left; cursor:pointer; width:100%; padding:14px 20px;">⎋ Log Out</button>
                </form>
            </div>
        </aside>

        <main class="menu-side">
            <div id="menuSection">
                <div class="page-header">
                    <div>
                        <h1 class="form-title" id="cashierTitle">Menu Categories</h1>
                        <p id="cashierSubtitle" style="color:#8c5b3e; font-size:14px;">Select an item to add to the order.</p>
                    </div>
                    <button id="backBtn" class="btn-secondary" style="display: none;" onclick="backToCategories()">← Back to Categories</button>
                </div>

                <div id="categoryGrid" class="product-grid">
                    <div class="product-card" onclick="openSubMenu('COFFEE')">
                        <div class="product-thumb" id="thumb-COFFEE">☕</div>
                        <div class="product-info"><h3>COFFEE</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('MILKTEA')">
                        <div class="product-thumb" id="thumb-MILKTEA">🧋</div>
                        <div class="product-info"><h3>MILK TEA</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('FRUIT TEA')">
                        <div class="product-thumb" id="thumb-FRUIT TEA">🍹</div>
                        <div class="product-info"><h3>FRUIT TEA</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('RICE MEAL')">
                        <div class="product-thumb" id="thumb-RICE MEAL">🍱</div>
                        <div class="product-info"><h3>RICE MEAL</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('BREAD & PASTRY')">
                        <div class="product-thumb" id="thumb-BREAD & PASTRY">🥐</div>
                        <div class="product-info"><h3>BREAD & PASTRY</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('SNACKS & PASTA')">
                        <div class="product-thumb" id="thumb-SNACKS & PASTA">🍝</div>
                        <div class="product-info"><h3>SNACKS & PASTA</h3></div>
                    </div>
                </div>

                <div id="subItemsGrid" class="product-grid" style="display:none;"></div>
            </div>
        </main>

        <aside class="receipt-side">
            <h2 class="widget-title" style="margin-bottom: 5px;">🛒 Current Order</h2>
            <p style="font-size: 12px; color: #b58361; margin-bottom: 15px;">Tap an item to select for removal</p>
            
            <div class="order-items-list" id="receiptList">
                <div class="empty-msg">No items in order</div>
            </div>

            <div class="checkout-footer">
                <div class="total-row">
                    <span style="font-size: 14px; color: #8c5b3e; font-weight: 600;">Grand Total</span>
                    <span id="total">₱0.00</span>
                </div>
                
                <button type="button" onclick="openPaymentModal()" class="payment-select-btn">
                    <span style="color: #8c5b3e; font-weight: 600;">Payment Method</span>
                    <span id="activePaymentLabel">💵 Cash</span>
                </button>
                
                <div style="display: flex; gap: 10px; margin-bottom: 12px;">
                    <button type="button" onclick="removeSelectedItem()" class="delete-btn" style="flex: 1;">Remove Item</button>
                </div>
                
                <div id="cashSection" style="display: block; background: #fdfaf6; padding: 15px; border-radius: 8px; border: 1px solid #dcbca5; margin-bottom: 15px; text-align: left;">
                    <label style="font-weight: 600; color: #8c5b3e; display: block; margin-bottom: 5px; font-size: 12px;">Amount Tendered (₱):</label>
                    <input type="number" id="amountTendered" onkeyup="calculateChange()" placeholder="0.00" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #dcbca5; font-size: 16px; font-weight: bold; margin-bottom: 10px; box-sizing: border-box;" />
                    
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 12px; color: #8c5b3e; font-weight: 600;">Change Due:</span>
                        <span id="changeDisplay" style="font-size: 18px; font-weight: 800; color: #f46a05;">₱0.00</span>
                    </div>
                </div>
                
                <button type="button" onclick="checkoutOrder()" class="btn-checkout">
                    Complete Checkout
                </button>
            </div>
        </aside>
    </div>

    <div id="selectionModal" class="modal-overlay" style="display:none;">
        <div class="form-card" style="margin: 0; position: relative; width: 460px; max-width: 90%; z-index: 2001; padding: 25px;">
            <button type="button" onclick="closeSelectionModal()" style="position: absolute; top: 12px; right: 18px; background: transparent; border: none; font-size: 28px; color: #8c5b3e; cursor: pointer; line-height: 1;">&times;</button>
            <div class="item-display-flex" style="flex-direction: row; text-align: left; gap: 25px;">
                <div class="item-image-container" id="detailImageContainer" style="width: 130px; height: 130px; flex-shrink: 0; margin: 0; font-size: 60px;"></div>
                <div class="item-details-controls" style="align-items: flex-start; width: 100%; gap: 8px;">
                    <h2 id="displayName" class="item-name-display" style="margin-bottom: 0; font-size: 22px;">Product Name</h2>
                    <div class="size-selector-grid" id="sizeSelector" style="justify-content: flex-start;"></div>
                    <div class="qty-flex" style="justify-content: flex-start; margin: 5px 0;">
                        <button type="button" onclick="decreaseQty()" style="width: 35px; height: 35px;">-</button>
                        <input id="qty" value="1" readonly style="width: 45px; height: 35px; font-size: 16px;" />
                        <button type="button" onclick="increaseQty()" style="width: 35px; height: 35px;">+</button>
                    </div>
                    <button type="button" class="add-btn-large" onclick="addToCart()" style="padding: 12px; font-size: 15px;">Add to Receipt</button>
                </div>
            </div>
        </div>
    </div>

    <div id="paymentModal" class="modal-overlay" style="display:none;">
        <div class="form-card" style="margin: 0; position: relative; width: 500px; max-width: 90%; z-index: 2001; padding: 30px;">
            <button type="button" onclick="closePaymentModal()" style="position: absolute; top: 15px; right: 20px; background: transparent; border: none; font-size: 28px; color: #8c5b3e; cursor: pointer; line-height: 1;">&times;</button>
            <h2 class="widget-title" style="text-align: center; margin-bottom: 25px;">Select Payment Method</h2>
            <div class="payment-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin-bottom: 25px;">
                <label class="custom-radio-card"><input type="radio" name="paymentOption" value="Cash" checked /><span class="radio-tile" style="display: block; text-align: center; width: 100%; padding: 15px;">💵 Cash</span></label>
                <label class="custom-radio-card"><input type="radio" name="paymentOption" value="GCash" /><span class="radio-tile" style="display: block; text-align: center; width: 100%; padding: 15px;">🔵 GCash</span></label>
                <label class="custom-radio-card"><input type="radio" name="paymentOption" value="Maya" /><span class="radio-tile" style="display: block; text-align: center; width: 100%; padding: 15px;">🟢 Maya</span></label>
                <label class="custom-radio-card"><input type="radio" name="paymentOption" value="Card" /><span class="radio-tile" style="display: block; text-align: center; width: 100%; padding: 15px;">💳 Card</span></label>
                <label class="custom-radio-card"><input type="radio" name="paymentOption" value="QR Ph" /><span class="radio-tile" style="display: block; text-align: center; width: 100%; padding: 15px;">🔳 QR Ph</span></label>
                <label class="custom-radio-card"><input type="radio" name="paymentOption" value="Google Pay" /><span class="radio-tile" style="display: block; text-align: center; width: 100%; padding: 15px;">📱 Google Pay</span></label>
            </div>
            <button type="button" class="add-btn-large" onclick="confirmPaymentMethod()">Confirm Selection</button>
        </div>
    </div>

    <script>
        const menuData = {};
        const productIdMap = {};
        const basePrices = {};

        @if (Model != null)
        {
            foreach (var item in Model)
            {
                @:var cat = "@Html.Raw(item.CategoryName?.Trim().ToUpper())";
                @:if (!menuData[cat]) menuData[cat] = [];
                @:var rawName = "@Html.Raw(item.ProductName)";
                @:var baseName = rawName.replace(" - Small", "").replace(" - Large", "").replace(" - Regular", "");
                @:if (!menuData[cat].includes(baseName)) menuData[cat].push(baseName);
                @:productIdMap[rawName] = @item.ProductId;
                @:basePrices[rawName] = parseFloat("@item.Price");
                @:basePrices[baseName] = parseFloat("@item.Price");
            }
        }

        const sizedCategories = ["COFFEE", "MILKTEA", "FRUIT TEA"];
        let cart = [], selectedReceiptIndex = -1, activeItemName = "", currentCategory = "";
        let finalPaymentMethod = "Cash";
        let currentCartTotal = 0;

        function openPaymentModal() { document.getElementById('paymentModal').style.display = 'flex'; }
        function closePaymentModal() { document.getElementById('paymentModal').style.display = 'none'; }

        function confirmPaymentMethod() {
            const selectedOption = document.querySelector('input[name="paymentOption"]:checked');
            if (selectedOption) {
                finalPaymentMethod = selectedOption.value;
                const icons = {"Cash": "💵", "GCash": "🔵", "Maya": "🟢", "Card": "💳", "QR Ph": "🔳", "Google Pay": "📱"};
                document.getElementById('activePaymentLabel').innerText = `${icons[finalPaymentMethod]} ${finalPaymentMethod}`;
                document.getElementById('cashSection').style.display = (finalPaymentMethod === "Cash") ? 'block' : 'none';
                if(finalPaymentMethod === "Cash") document.getElementById('amountTendered').focus();
                calculateChange();
            }
            closePaymentModal();
        }

        function calculateChange() {
            const tendered = parseFloat(document.getElementById('amountTendered').value) || 0;
            const changeDisplay = document.getElementById('changeDisplay');
            if (!document.getElementById('amountTendered').value) { changeDisplay.innerText = '₱0.00'; return; }
            const change = tendered - currentCartTotal;
            changeDisplay.innerText = change < 0 ? 'Insufficient' : '₱' + change.toFixed(2);
            changeDisplay.style.color = change < 0 ? 'red' : '#2e7d32';
        }

        function openSubMenu(cat) {
            currentCategory = cat.toUpperCase();
            const items = menuData[currentCategory] || [];
            document.getElementById('cashierTitle').innerText = currentCategory;
            document.getElementById('backBtn').style.display = 'block';
            document.getElementById('categoryGrid').style.display = 'none';
            const grid = document.getElementById('subItemsGrid');
            grid.style.display = 'grid';
            grid.innerHTML = items.map(item => `
                <div class="product-card" onclick="selectProductItem('${item}')">
                    <div class="product-thumb">${getCategoryEmoji(currentCategory)}</div>
                    <div class="product-info"><h3>${item}</h3></div>
                </div>`).join('');
        }

        function backToCategories() {
            document.getElementById('cashierTitle').innerText = "Menu Categories";
            document.getElementById('categoryGrid').style.display = 'grid';
            document.getElementById('subItemsGrid').style.display = 'none';
            document.getElementById('backBtn').style.display = 'none';
        }

        function selectProductItem(name) {
            activeItemName = name;
            document.getElementById('selectionModal').style.display = 'flex';
            document.getElementById('displayName').innerText = name;
            document.getElementById('qty').value = 1;
            const sizeSelector = document.getElementById('sizeSelector');
            if (sizedCategories.includes(currentCategory)) {
                sizeSelector.style.display = 'flex';
                sizeSelector.innerHTML = `<label class="custom-radio-card"><input type="radio" name="size" value="Small" checked /><span class="radio-tile">Small</span></label>
                                          <label class="custom-radio-card"><input type="radio" name="size" value="Large" /><span class="radio-tile">Large</span></label>`;
            } else {
                sizeSelector.style.display = 'none';
                sizeSelector.innerHTML = `<input type="radio" name="size" value="Regular" checked style="display:none;">`;
            }
            document.getElementById('detailImageContainer').innerHTML = getCategoryEmoji(currentCategory);
        }

        function closeSelectionModal() { document.getElementById('selectionModal').style.display = 'none'; }
        function getCategoryEmoji(cat) { return {"COFFEE": "☕", "MILKTEA": "🧋", "RICE MEAL": "🍱", "BREAD & PASTRY": "🥐", "FRUIT TEA": "🍹", "SNACKS & PASTA": "🍝"}[cat] || "🍴"; }
        function increaseQty() { let q = document.getElementById("qty"); q.value = parseInt(q.value) + 1; }
        function decreaseQty() { let q = document.getElementById("qty"); if (parseInt(q.value) > 1) q.value = parseInt(q.value) - 1; }

        function addToCart() {
            let size = document.querySelector('input[name="size"]:checked').value;
            let qty = parseInt(document.getElementById("qty").value);
            let dbKey = (sizedCategories.includes(currentCategory) && size !== "Regular") ? `${activeItemName} - ${size}` : activeItemName;
            let price = basePrices[dbKey] || basePrices[activeItemName] || 0;
            cart.push({ name: activeItemName, dbKey: dbKey, size: size, qty: qty, price: price });
            Toastify({ text: `📦 ${qty}x ${activeItemName} added!`, duration: 1500, style: { background: "#f46a05" } }).showToast();
            renderReceipt();
            closeSelectionModal();
        }

        function renderReceipt() {
            const receipt = document.getElementById("receiptList");
            if (cart.length === 0) { receipt.innerHTML = `<div class="empty-msg">No items in order</div>`; document.getElementById("total").textContent = "₱0.00"; currentCartTotal = 0; return; }
            let total = 0;
            receipt.innerHTML = cart.map((item, index) => {
                let sub = item.qty * item.price; total += sub;
                return `<div class="order-item-row ${selectedReceiptIndex === index ? 'selected-row' : ''}" onclick="selectReceiptItem(${index})">
                    <div><div style="font-weight:700;">${item.qty}x ${item.name}</div><div style="font-size:11px;">${item.size} • ₱${item.price.toFixed(2)}</div></div>
                    <div style="font-weight:800; color:#f46a05;">₱${sub.toFixed(2)}</div></div>`;
            }).join('');
            document.getElementById("total").textContent = "₱" + total.toFixed(2);
            currentCartTotal = total; calculateChange();
        }

        function selectReceiptItem(index) { selectedReceiptIndex = (selectedReceiptIndex === index) ? -1 : index; renderReceipt(); }
        function removeSelectedItem() { if (selectedReceiptIndex === -1) return; cart.splice(selectedReceiptIndex, 1); selectedReceiptIndex = -1; renderReceipt(); }

        async function checkoutOrder() {
            if (cart.length === 0) return;
            let amountPaid = (finalPaymentMethod === "Cash") ? parseFloat(document.getElementById('amountTendered').value) || 0 : currentCartTotal;
            if (finalPaymentMethod === "Cash" && amountPaid < currentCartTotal) { Swal.fire("Insufficient Cash", "", "warning"); return; }
            const payload = cart.map(item => ({ productId: productIdMap[item.dbKey] || productIdMap[item.name] || 0, quantity: item.qty, price: item.price }));
            try {
                const response = await fetch('/Cashier/Checkout', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: payload, paymentMethod: finalPaymentMethod, amountPaid: amountPaid }) });
                if (response.ok) {
                    Swal.fire("Sale Complete!", "", "success");
                    cart = []; document.getElementById('amountTendered').value = ''; renderReceipt(); backToCategories();
                }
            } catch (err) { Swal.fire("Error", "Server error", "error"); }
        }
    </script>
</body>
</html>