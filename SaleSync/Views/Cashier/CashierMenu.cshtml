@model List<SaleSync.Models.MenuItemModel>
@{
    Layout = null;
    
    // ⭐ SHAPE-SHIFTER LOGIC: Detects who is looking at the POS and adjusts the sidebar
    string roleName = "Cashier";
    string homeController = "Cashier";
    string subtitle = "Front Desk Access";

    if (User.IsInRole("Admin"))
    {
        roleName = "Admin";
        homeController = "Admin";
        subtitle = "System Access";
    }
    else if (User.IsInRole("Manager"))
    {
        roleName = "Manager";
        homeController = "Manager";
        subtitle = "System Access";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Point of Sale - SyncScale</title>
    <link rel="stylesheet" href="~/css/CashierMenu.css" asp-append-version="true" />
    
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div class="dashboard-container">
        
        <!-- SIDEBAR -->
        <aside class="sidebar no-print">
            <div>
                <div class="logo-section">
                    <div class="logo-title">SyncScale</div>
                    <div class="logo-subtitle">Coffee & Pastries</div>
                </div>

                <div class="profile-section">
                    <div class="profile-circle">👤</div>
                    <div class="profile-text">
                        <h2 class="admin-name">@roleName</h2>
                        <div class="admin-role">@subtitle</div>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="/@homeController/Dashboard" class="menu-btn">❖ Dashboard</a>
                    <a href="javascript:void(0)" class="menu-btn active">🛒 POS</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ActivityLog" class="menu-btn">📋 Activity Log</a>
                    }
                    
                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                    {
                        <a href="/Admin/Analytics" class="menu-btn">📊 Analytics</a>
                        <a href="/Admin/Products" class="menu-btn">🏷️ Products</a>
                        <a href="/Admin/Inventory" class="menu-btn">📦 Inventory</a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/ManageAccounts" class="menu-btn">💳 Accounts</a>
                    }
                </nav>
            </div>

            <div class="logout-section">
                <form method="post" action="/Home/Logout">
                    <button type="submit" class="menu-btn logout-btn">⎋ Log Out</button>
                </form>
            </div>
        </aside>

        <!-- MAIN POS AREA -->
        <main class="menu-side no-print">
            <div id="menuSection">
                <div class="page-header">
                    <div>
                        <h1 class="form-title" id="cashierTitle">Menu Categories</h1>
                        <p class="form-subtitle" id="cashierSubtitle">Select an item to add to the order.</p>
                    </div>
                    <button id="backBtn" class="btn-secondary" style="display: none;" onclick="backToCategories()">← Back to Categories</button>
                </div>

                <div id="categoryGrid" class="product-grid">
                    <div class="product-card" onclick="openSubMenu('COFFEE')">
                        <div class="product-thumb" id="thumb-COFFEE">☕</div>
                        <div class="product-info"><h3>COFFEE</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('MILKTEA')">
                        <div class="product-thumb" id="thumb-MILKTEA">🧋</div>
                        <div class="product-info"><h3>MILK TEA</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('FRUIT TEA')">
                        <div class="product-thumb" id="thumb-FRUIT TEA">🍹</div>
                        <div class="product-info"><h3>FRUIT TEA</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('RICE MEAL')">
                        <div class="product-thumb" id="thumb-RICE MEAL">🍱</div>
                        <div class="product-info"><h3>RICE MEAL</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('BREAD & PASTRY')">
                        <div class="product-thumb" id="thumb-BREAD & PASTRY">🥐</div>
                        <div class="product-info"><h3>BREAD & PASTRY</h3></div>
                    </div>
                    <div class="product-card" onclick="openSubMenu('SNACKS & PASTA')">
                        <div class="product-thumb" id="thumb-SNACKS & PASTA">🍝</div>
                        <div class="product-info"><h3>SNACKS & PASTA</h3></div>
                    </div>
                </div>

                <div id="subItemsGrid" class="product-grid" style="display:none;"></div>
            </div>
        </main>

        <!-- RECEIPT SIDEBAR -->
        <aside class="receipt-side no-print">
            <h2 class="widget-title receipt-title">🛒 Current Order</h2>
            <p class="receipt-subtitle">Tap an item to select for removal</p>
            
            <div class="order-items-list" id="receiptList">
                <div class="empty-msg">No items in order</div>
            </div>

            <div class="checkout-footer">
                <div class="total-row">
                    <span class="total-label">Grand Total</span>
                    <span id="total">₱0.00</span>
                </div>

                <!-- ⭐ CUSTOMER NAME INPUT -->
                <div style="margin-bottom: 12px;">
                    <input type="text" id="customerName" class="customer-name-input" placeholder="Customer Name (Optional)" autocomplete="off" />
                </div>

                <!-- ⭐ ORDER TYPE TOGGLE -->
                <div style="display: flex; gap: 10px; margin-bottom: 12px;">
                    <label class="custom-radio-card" style="flex: 1;">
                        <input type="radio" name="orderType" value="Dine In" checked onchange="updateOrderType()" />
                        <span class="radio-tile" style="padding: 12px; font-size: 14px;">🍽️ Dine In</span>
                    </label>
                    <label class="custom-radio-card" style="flex: 1;">
                        <input type="radio" name="orderType" value="Take Out" onchange="updateOrderType()" />
                        <span class="radio-tile" style="padding: 12px; font-size: 14px;">🛍️ Take Out</span>
                    </label>
                </div>
                
                <button type="button" onclick="openPaymentModal()" class="payment-select-btn">
                    <span class="payment-label">Payment Method</span>
                    <span id="activePaymentLabel">💵 Cash</span>
                </button>
                
                <div class="receipt-actions">
                    <button type="button" onclick="removeSelectedItem()" class="delete-btn">Remove Item</button>
                </div>
                
                <div id="cashSection" class="cash-section">
                    <label class="cash-label">Amount Tendered (₱):</label>
                    <input type="number" id="amountTendered" class="cash-input" onkeyup="calculateChange()" placeholder="0.00" />
                    
                    <div class="change-row">
                        <span class="change-label">Change Due:</span>
                        <span id="changeDisplay" class="change-amount">₱0.00</span>
                    </div>
                </div>
                
                <button type="button" onclick="checkoutOrder()" class="btn-checkout">Complete Checkout</button>
            </div>
        </aside>
    </div>

    <!-- MODALS -->
    <div id="selectionModal" class="modal-overlay no-print" style="display:none;">
        <div class="form-card modal-card">
            <button type="button" onclick="closeSelectionModal()" class="modal-close-btn">&times;</button>
            
            <div class="item-display-flex">
                <div class="item-image-container" id="detailImageContainer"></div>
                <div class="item-details-controls">
                    <h2 id="displayName" class="item-name-display">Product Name</h2>
                    <div class="size-selector-grid" id="sizeSelector"></div>
                    
                    <div class="qty-flex">
                        <button type="button" onclick="decreaseQty()">-</button>
                        <input id="qty" value="1" readonly />
                        <button type="button" onclick="increaseQty()">+</button>
                    </div>
                    
                    <button type="button" class="add-btn-large" onclick="addToCart()">Add to Receipt</button>
                </div>
            </div>
        </div>
    </div>

    <div id="paymentModal" class="modal-overlay no-print" style="display:none;">
        <div class="form-card modal-card payment-card">
            <button type="button" onclick="closePaymentModal()" class="modal-close-btn">&times;</button>
            <h2 class="widget-title text-center">Select Payment Method</h2>
            
            <div class="payment-grid">
                <label class="custom-radio-card"><input type="radio" name="paymentOption" value="Cash" checked /><span class="radio-tile">💵 Cash</span></label>
                <label class="custom-radio-card"><input type="radio" name="paymentOption" value="GCash" /><span class="radio-tile">🔵 GCash</span></label>
                <label class="custom-radio-card"><input type="radio" name="paymentOption" value="Maya" /><span class="radio-tile">🟢 Maya</span></label>
                <label class="custom-radio-card"><input type="radio" name="paymentOption" value="Card" /><span class="radio-tile">💳 Card</span></label>
                <label class="custom-radio-card"><input type="radio" name="paymentOption" value="QR Ph" /><span class="radio-tile">🔳 QR Ph</span></label>
                <label class="custom-radio-card"><input type="radio" name="paymentOption" value="Google Pay" /><span class="radio-tile">📱 Google Pay</span></label>
            </div>
            
            <button type="button" class="add-btn-large" onclick="confirmPaymentMethod()">Confirm Selection</button>
        </div>
    </div>

    <!-- FINAL RECEIPT PREVIEW MODAL -->
    <div id="receiptModal" class="modal-overlay" style="display:none;">
        <div class="receipt-paper">
            <div class="receipt-header-print">
                <h2>CAFÉRO</h2>
                <p>Coffee & Pastries</p>
                <p>Taytay, Rizal</p>
            </div>
            
            <div class="receipt-meta">
                <p>Date: <span id="receiptDate"></span></p>
                <p>Receipt #: <span id="receiptNumber"></span></p>
                <p>Cashier: @roleName</p>
                <p>Type: <strong id="receiptOrderType"></strong></p>
                <!-- CUSTOMER NAME ON RECEIPT -->
                <p id="receiptCustomerRow" style="display: none;">Customer: <strong id="receiptCustomerName"></strong></p>
            </div>
            
            <div class="receipt-divider"></div>
            
            <table class="receipt-table" id="receiptItemsTable">
                <!-- Items injected by JS -->
            </table>
            
            <div class="receipt-divider"></div>
            
            <div class="receipt-row"><span>Subtotal:</span><span id="receiptSubtotal"></span></div>
            <div class="receipt-row"><span>VAT (12%):</span><span id="receiptVat"></span></div>
            <div class="receipt-row receipt-grand-total"><span>TOTAL:</span><span id="receiptTotal"></span></div>
            
            <div class="receipt-divider"></div>
            
            <div class="receipt-row"><span>Method:</span><span id="receiptPayMethod"></span></div>
            <div class="receipt-row"><span>Tendered:</span><span id="receiptTendered"></span></div>
            <div class="receipt-row"><span>Change:</span><span id="receiptChange"></span></div>
            
            <div class="receipt-divider"></div>
            
            <div class="receipt-footer-print">
                <p>Thank you for your purchase!</p>
                <p>Please come again.</p>
            </div>
            
            <!-- ⭐ 3 BUTTON LAYOUT -->
            <div class="receipt-modal-actions no-print" style="display: flex; gap: 10px;">
                <button onclick="cancelCheckout()" class="btn-cancel" style="flex: 1; padding: 12px; font-size: 14px;">Cancel</button>
                <button onclick="finalizeOrder(false)" style="flex: 1; padding: 12px; font-size: 14px; font-weight: bold; border-radius: 8px; margin: 0; background: #8c5b3e; color: white; border: none; cursor: pointer;">No Print</button>
                <button onclick="finalizeOrder(true)" class="btn-confirm" style="flex: 1; padding: 12px; font-size: 14px;">Print</button>
            </div>
        </div>
    </div>

    <!-- SCRIPTS -->
    <script>
        const menuData = {};
        const productIdMap = {};
        const basePrices = {};

        @if (Model != null)
        {
            foreach (var item in Model)
            {
                @:var cat = "@Html.Raw(item.CategoryName?.Trim().ToUpper())";
                @:if (!menuData[cat]) menuData[cat] = [];
                @:var rawName = "@Html.Raw(item.ProductName)";
                @:var baseName = rawName.replace(" - Small", "").replace(" - Large", "").replace(" - Regular", "");
                @:if (!menuData[cat].includes(baseName)) menuData[cat].push(baseName);
                @:productIdMap[rawName] = @item.ProductId;
                @:basePrices[rawName] = parseFloat("@item.Price");
                @:basePrices[baseName] = parseFloat("@item.Price");
            }
        }

        const sizedCategories = ["COFFEE", "MILKTEA", "FRUIT TEA"];
        let cart = [], selectedReceiptIndex = -1, activeItemName = "", currentCategory = "";
        let finalPaymentMethod = "Cash";
        let currentCartTotal = 0;
        let pendingAmountPaid = 0;
        
        let currentOrderType = "Dine In";
        let currentCustomerName = "";

        function updateOrderType() {
        currentOrderType = document.querySelector('input[name="orderType"]:checked').value;
        }

        function openPaymentModal() { document.getElementById('paymentModal').style.display = 'flex'; }
        function closePaymentModal() { document.getElementById('paymentModal').style.display = 'none'; }

        function confirmPaymentMethod() {
        const selectedOption = document.querySelector('input[name="paymentOption"]:checked');
        if (selectedOption) {
        finalPaymentMethod = selectedOption.value;
        const icons = {"Cash": "💵", "GCash": "🔵", "Maya": "🟢", "Card": "💳", "QR Ph": "🔳", "Google Pay": "📱"};
        document.getElementById('activePaymentLabel').innerText = `${icons[finalPaymentMethod]} ${finalPaymentMethod}`;
        document.getElementById('cashSection').style.display = (finalPaymentMethod === "Cash") ? 'block' : 'none';
        if(finalPaymentMethod === "Cash") document.getElementById('amountTendered').focus();
        calculateChange();
        }
        closePaymentModal();
        }

        function calculateChange() {
        const tendered = parseFloat(document.getElementById('amountTendered').value) || 0;
        const changeDisplay = document.getElementById('changeDisplay');
        if (!document.getElementById('amountTendered').value) { changeDisplay.innerText = '₱0.00'; return; }
        const change = tendered - currentCartTotal;
        changeDisplay.innerText = change < 0 ? 'Insufficient' : '₱' + change.toFixed(2);
        changeDisplay.style.color = change < 0 ? 'red' : '#2e7d32';
        }

        function openSubMenu(cat) {
        currentCategory = cat.toUpperCase();
        const items = menuData[currentCategory] || [];
        document.getElementById('cashierTitle').innerText = currentCategory;
        document.getElementById('backBtn').style.display = 'block';
        document.getElementById('categoryGrid').style.display = 'none';
        const grid = document.getElementById('subItemsGrid');
        grid.style.display = 'grid';
        grid.innerHTML = items.map(item => `
        <div class="product-card" onclick="selectProductItem('${item}')">
        <div class="product-thumb">${getCategoryEmoji(currentCategory)}</div>
        <div class="product-info"><h3>${item}</h3></div>
        </div>`).join('');
        }

        function backToCategories() {
        document.getElementById('cashierTitle').innerText = "Menu Categories";
        document.getElementById('categoryGrid').style.display = 'grid';
        document.getElementById('subItemsGrid').style.display = 'none';
        document.getElementById('backBtn').style.display = 'none';
        }

        function selectProductItem(name) {
        activeItemName = name;
        document.getElementById('selectionModal').style.display = 'flex';
        document.getElementById('displayName').innerText = name;
        document.getElementById('qty').value = 1;
        const sizeSelector = document.getElementById('sizeSelector');
        if (sizedCategories.includes(currentCategory)) {
        sizeSelector.style.display = 'flex';
        sizeSelector.innerHTML = `<label class="custom-radio-card"><input type="radio" name="size" value="Small" checked /><span class="radio-tile">Small</span></label>
        <label class="custom-radio-card"><input type="radio" name="size" value="Large" /><span class="radio-tile">Large</span></label>`;
        } else {
        sizeSelector.style.display = 'none';
        sizeSelector.innerHTML = `<input type="radio" name="size" value="Regular" checked style="display:none;">`;
        }
        document.getElementById('detailImageContainer').innerHTML = getCategoryEmoji(currentCategory);
        }

        function closeSelectionModal() { document.getElementById('selectionModal').style.display = 'none'; }
        function getCategoryEmoji(cat) { return {"COFFEE": "☕", "MILKTEA": "🧋", "RICE MEAL": "🍱", "BREAD & PASTRY": "🥐", "FRUIT TEA": "🍹", "SNACKS & PASTA": "🍝"}[cat] || "🍴"; }
        function increaseQty() { let q = document.getElementById("qty"); q.value = parseInt(q.value) + 1; }
        function decreaseQty() { let q = document.getElementById("qty"); if (parseInt(q.value) > 1) q.value = parseInt(q.value) - 1; }

        function addToCart() {
        let size = document.querySelector('input[name="size"]:checked').value;
        let qty = parseInt(document.getElementById("qty").value);
        let dbKey = (sizedCategories.includes(currentCategory) && size !== "Regular") ? `${activeItemName} - ${size}` : activeItemName;
        let price = basePrices[dbKey] || basePrices[activeItemName] || 0;
        cart.push({ name: activeItemName, dbKey: dbKey, size: size, qty: qty, price: price });
        Toastify({ text: `📦 ${qty}x ${activeItemName} added!`, duration: 1500, style: { background: "#f46a05" } }).showToast();
        renderReceipt();
        closeSelectionModal();
        }

        function renderReceipt() {
        const receipt = document.getElementById("receiptList");
        if (cart.length === 0) { receipt.innerHTML = `<div class="empty-msg">No items in order</div>`; document.getElementById("total").textContent = "₱0.00"; currentCartTotal = 0; return; }
        let total = 0;
        receipt.innerHTML = cart.map((item, index) => {
        let sub = item.qty * item.price; total += sub;
        return `<div class="order-item-row ${selectedReceiptIndex === index ? 'selected-row' : ''}" onclick="selectReceiptItem(${index})">
        <div><div style="font-weight:700;">${item.qty}x ${item.name}</div><div style="font-size:11px;">${item.size} • ₱${item.price.toFixed(2)}</div></div>
        <div style="font-weight:800; color:#f46a05;">₱${sub.toFixed(2)}</div></div>`;
        }).join('');
        document.getElementById("total").textContent = "₱" + total.toFixed(2);
        currentCartTotal = total; calculateChange();
        }

        function selectReceiptItem(index) { selectedReceiptIndex = (selectedReceiptIndex === index) ? -1 : index; renderReceipt(); }
        function removeSelectedItem() { if (selectedReceiptIndex === -1) return; cart.splice(selectedReceiptIndex, 1); selectedReceiptIndex = -1; renderReceipt(); }

        function checkoutOrder() {
        if (cart.length === 0) return;
        let amountPaid = (finalPaymentMethod === "Cash") ? parseFloat(document.getElementById('amountTendered').value) || 0 : currentCartTotal;
            
        if (finalPaymentMethod === "Cash" && amountPaid < currentCartTotal) {
        Swal.fire("Insufficient Cash", "Please enter a valid amount tendered.", "warning");
        return;
        }
            
        pendingAmountPaid = amountPaid;
        currentCustomerName = document.getElementById("customerName").value.trim();
        generateReceiptUI(amountPaid);
        }

        function generateReceiptUI(amountPaid) {
        const dateObj = new Date();
        const dateStr = dateObj.toLocaleDateString() + ' ' + dateObj.toLocaleTimeString();
        const receiptNum = "ORD-" + dateObj.getFullYear() + (dateObj.getMonth()+1).toString().padStart(2, '0') + dateObj.getDate().toString().padStart(2, '0') + "-" + Math.floor(1000 + Math.random() * 9000);

        document.getElementById("receiptDate").innerText = dateStr;
        document.getElementById("receiptNumber").innerText = receiptNum;
        document.getElementById("receiptOrderType").innerText = currentOrderType;

        const custRow = document.getElementById("receiptCustomerRow");
        if (currentCustomerName !== "") {
        document.getElementById("receiptCustomerName").innerText = currentCustomerName;
        custRow.style.display = "block";
        } else {
        custRow.style.display = "none";
        }

        const tbody = document.getElementById("receiptItemsTable");
        tbody.innerHTML = `<tr><th style="text-align:left; padding-bottom:5px;">Qty</th><th style="text-align:left; padding-bottom:5px;">Item</th><th style="text-align:right; padding-bottom:5px;">Total</th></tr>`;
            
        cart.forEach(item => {
        let sub = item.qty * item.price;
        tbody.innerHTML += `<tr><td style="vertical-align:top; width:40px;">${item.qty}x</td><td style="padding-bottom:5px;">${item.name} <br><small style="font-size:10px; color:#555;">${item.size}</small></td><td style="text-align:right; vertical-align:top;">₱${sub.toFixed(2)}</td></tr>`;
        });

        let total = currentCartTotal;
        let vatableSales = total / 1.12;
        let vatAmount = total - vatableSales;

        document.getElementById("receiptSubtotal").innerText = "₱" + vatableSales.toFixed(2);
        document.getElementById("receiptVat").innerText = "₱" + vatAmount.toFixed(2);
        document.getElementById("receiptTotal").innerText = "₱" + total.toFixed(2);
        document.getElementById("receiptPayMethod").innerText = finalPaymentMethod;
        document.getElementById("receiptTendered").innerText = "₱" + amountPaid.toFixed(2);
            
        let change = amountPaid - total;
        document.getElementById("receiptChange").innerText = "₱" + (change > 0 ? change.toFixed(2) : "0.00");

        document.getElementById("receiptModal").style.display = "flex";
        }

        function cancelCheckout() {
        document.getElementById("receiptModal").style.display = "none";
        }

        // ⭐ UPDATED SMART FINALIZE FUNCTION
        async function finalizeOrder(shouldPrint) {
        const payload = cart.map(item => ({ productId: productIdMap[item.dbKey] || productIdMap[item.name] || 0, quantity: item.qty, price: item.price }));
            
        // Disable buttons to prevent double-clicks
        const buttons = document.querySelectorAll('.receipt-modal-actions button');
        buttons.forEach(btn => {
        btn.disabled = true;
        btn.style.opacity = '0.5';
        });

        try {
        const response = await fetch('/Cashier/Checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
        items: payload,
        paymentMethod: finalPaymentMethod,
        amountPaid: pendingAmountPaid,
        orderType: currentOrderType,
        customerName: currentCustomerName
        })
        });
                
        if (response.ok) {
        // Trigger print only if they clicked the Print button
        if (shouldPrint) {
        window.print();
        }
                    
        document.getElementById("receiptModal").style.display = "none";
        Swal.fire("Order Completed!", "The system is ready for the next customer.", "success");
                    
        document.querySelector('input[name="orderType"][value="Dine In"]').checked = true;
        currentOrderType = "Dine In";
                    
        document.getElementById("customerName").value = "";
        currentCustomerName = "";
                    
        cart = [];
        document.getElementById('amountTendered').value = '';
        renderReceipt();
        backToCategories();
        } else {
        Swal.fire("Error", "Failed to save transaction.", "error");
        }
        } catch (err) {
        Swal.fire("Error", "Server error", "error");
        } finally {
        // Re-enable buttons just in case print is cancelled and modal stays open
        buttons.forEach(btn => {
        btn.disabled = false;
        btn.style.opacity = '1';
        });
        }
        }
    </script>
</body>
</html>