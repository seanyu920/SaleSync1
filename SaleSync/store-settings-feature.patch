diff --git a/SaleSync/Sql/create_store_settings_table.sql b/SaleSync/Sql/create_store_settings_table.sql
new file mode 100644
index 0000000..f6d1f5c
--- /dev/null
+++ b/SaleSync/Sql/create_store_settings_table.sql
@@ -0,0 +1,30 @@
+-- Run this once against your SaleSync database (e.g. in SSMS or Azure Data Studio)
+-- before using the updated Web Customization feature. It creates the single-row
+-- table that stores branding, receipt, theme, and business-hours settings.
+
+IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name = 'store_settings')
+BEGIN
+    CREATE TABLE store_settings (
+        id INT PRIMARY KEY,                          -- always 1; this table only ever holds one row
+        store_name NVARCHAR(100) NOT NULL DEFAULT 'Cafero',
+        store_tagline NVARCHAR(150) NOT NULL DEFAULT 'Coffee & Pastries',
+        business_address NVARCHAR(255) NOT NULL DEFAULT '',
+        contact_number NVARCHAR(50) NOT NULL DEFAULT '',
+        tax_id_number NVARCHAR(50) NOT NULL DEFAULT '',
+        receipt_footer NVARCHAR(255) NOT NULL DEFAULT '',
+        logo_path NVARCHAR(255) NULL,
+        currency_symbol NVARCHAR(5) NOT NULL DEFAULT '₱',
+        vat_rate DECIMAL(5,2) NOT NULL DEFAULT 12.00,
+        low_stock_threshold INT NOT NULL DEFAULT 10,
+        opening_time VARCHAR(5) NOT NULL DEFAULT '07:00',   -- stored as 'HH:mm'
+        closing_time VARCHAR(5) NOT NULL DEFAULT '21:00',   -- stored as 'HH:mm'
+        is_temporarily_closed BIT NOT NULL DEFAULT 0,
+        primary_color VARCHAR(7) NOT NULL DEFAULT '#4a2511',
+        sidebar_color VARCHAR(7) NOT NULL DEFAULT '#2b1b17',
+        accent_color VARCHAR(7) NOT NULL DEFAULT '#b58361',
+        background_color VARCHAR(7) NOT NULL DEFAULT '#fdfbf7',
+        sidebar_position VARCHAR(5) NOT NULL DEFAULT 'left'
+    );
+
+    INSERT INTO store_settings (id) VALUES (1);
+END
